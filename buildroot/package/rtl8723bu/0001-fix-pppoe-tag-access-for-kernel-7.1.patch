From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Batocera Linux <batocera@batocera.org>
Date: Thu, 18 Jun 2026 11:00:00 +0300
Subject: [PATCH] fix pppoe tag access for kernel 7.1

Linux 7.1 hides the kernel-visible flexible arrays in struct pppoe_hdr
and struct pppoe_tag. The payload layout is unchanged, so derive the
addresses from the structure sizes instead of accessing hidden members.
---
 core/rtw_br_ext.c | 25 +++++++++++++++++--------
 1 file changed, 17 insertions(+), 8 deletions(-)

diff --git a/core/rtw_br_ext.c b/core/rtw_br_ext.c
--- a/core/rtw_br_ext.c
+++ b/core/rtw_br_ext.c
@@ -74,12 +74,22 @@
   PPPoE |type|   SID   |           AC MAC            |
 -----------------------------------------------------------------*/
 
+static __inline__ unsigned char *rtw_pppoe_tags(struct pppoe_hdr *ph)
+{
+	return (unsigned char *)ph + sizeof(*ph);
+}
+
+static __inline__ unsigned char *rtw_pppoe_tag_data(struct pppoe_tag *tag)
+{
+	return (unsigned char *)tag + sizeof(*tag);
+}
+
 
 //Find a tag in pppoe frame and return the pointer
 static __inline__ unsigned char *__nat25_find_pppoe_tag(struct pppoe_hdr *ph, unsigned short type)
 {
 	unsigned char *cur_ptr, *start_ptr;
 	unsigned short tagLen, tagType;
 
-	start_ptr = cur_ptr = (unsigned char *)ph->tag;
+	start_ptr = cur_ptr = rtw_pppoe_tags(ph);
 	while((cur_ptr - start_ptr) < ntohs(ph->length)) {
 		// prevent un-alignment access
 		tagType = (unsigned short)((cur_ptr[0] << 8) + cur_ptr[1]);
@@ -105,10 +115,10 @@ static __inline__ int __nat25_add_pppoe_tag(struct sk_buff *skb, struct pppoe_ta
 
 	skb_put(skb, data_len);
 	// have a room for new tag
-	memmove(((unsigned char *)ph->tag + data_len), (unsigned char *)ph->tag, ntohs(ph->length));
+	memmove(rtw_pppoe_tags(ph) + data_len, rtw_pppoe_tags(ph), ntohs(ph->length));
 	ph->length = htons(ntohs(ph->length) + data_len);
-	memcpy((unsigned char *)ph->tag, tag, data_len);
+	memcpy(rtw_pppoe_tags(ph), tag, data_len);
 	return data_len;
 }
 
@@ -1225,8 +1235,8 @@ int nat25_db_handle(_adapter *priv, struct sk_buff *skb, int method)
 									return -1;
 								}
 
-								memcpy(tag->tag_data+MAGIC_CODE_LEN+RTL_RELAY_TAG_LEN,
-									pOldTag->tag_data, old_tag_len);
+								memcpy(rtw_pppoe_tag_data(tag)+MAGIC_CODE_LEN+RTL_RELAY_TAG_LEN,
+									rtw_pppoe_tag_data(pOldTag), old_tag_len);
 
 								if (skb_pull_and_merge(skb, (unsigned char *)pOldTag, TAG_HDR_LEN+old_tag_len) < 0) {
 									DEBUG_ERR("call skb_pull_and_merge() failed in PADI/R packet!\n");
@@ -1239,9 +1249,9 @@ int nat25_db_handle(_adapter *priv, struct sk_buff *skb, int method)
 							tag->tag_len = htons(MAGIC_CODE_LEN+RTL_RELAY_TAG_LEN+old_tag_len);
 
 							// insert the magic_code+client mac in relay tag
-							pMagic = (__be16 *)tag->tag_data;
+							pMagic = (__be16 *)rtw_pppoe_tag_data(tag);
 							*pMagic = htons(MAGIC_CODE);
-							memcpy(tag->tag_data+MAGIC_CODE_LEN, skb->data+ETH_ALEN, ETH_ALEN);
+							memcpy(rtw_pppoe_tag_data(tag)+MAGIC_CODE_LEN, skb->data+ETH_ALEN, ETH_ALEN);
 
 							//Add relay tag
 							if(__nat25_add_pppoe_tag(skb, tag) < 0)
@@ -1306,14 +1316,14 @@ int nat25_db_handle(_adapter *priv, struct sk_buff *skb, int method)
 							return -1;
 						}
 
-						pMagic = (__be16 *)tag->tag_data;
+						pMagic = (__be16 *)rtw_pppoe_tag_data(tag);
 						if (ntohs(*pMagic) != MAGIC_CODE) {
 							DEBUG_ERR("Can't find MAGIC_CODE in %s packet!\n",
 								(ph->code == PADO_CODE ? "PADO" : "PADS"));
 							return -1;
 						}
 
-						memcpy(skb->data, tag->tag_data+MAGIC_CODE_LEN, ETH_ALEN);
+						memcpy(skb->data, rtw_pppoe_tag_data(tag)+MAGIC_CODE_LEN, ETH_ALEN);
 
 						if (tagLen > MAGIC_CODE_LEN+RTL_RELAY_TAG_LEN)
 							offset = TAG_HDR_LEN;
-- 
