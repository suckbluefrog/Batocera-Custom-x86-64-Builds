#!/bin/sh
BOOTCONF="/boot/batocera-boot.conf"

. /etc/profile.d/xdg.sh
. /etc/profile.d/dbus.sh

# Define the path for our communication pipe
FIFO_PATH="/tmp/es-resume.fifo"
SUSPEND_FLAG="/tmp/suspend.please"

frontend_running() {
	pgrep -f '/usr/bin/emulationstation-standalone' >/dev/null 2>&1 || \
	pidof /usr/bin/emulationstation >/dev/null 2>&1
}

compositor_running() {
	for COMPOSITOR in openbox sway labwc; do
		pidof "$COMPOSITOR" >/dev/null 2>&1 && return 0
	done
	return 1
}

compositor_pid() {
	local pids

	for COMPOSITOR in labwc sway openbox; do
		pids="$(pidof "$COMPOSITOR" 2>/dev/null || true)"
		if [ -n "${pids}" ]; then
			set -- ${pids}
			printf '%s\n' "$1"
			return 0
		fi
	done
	return 1
}

frontend_env_value() {
	local pid="$1"
	local key="$2"

	[ -r "/proc/${pid}/environ" ] || return 1
	tr '\0' '\n' < "/proc/${pid}/environ" | sed -n "s/^${key}=//p" | head -n 1
}

export_existing_compositor_env() {
	local pid
	local name
	local value
	local sock

	pid="$(compositor_pid)"
	[ -n "${pid}" ] || return 0

	for name in \
		WAYLAND_DISPLAY \
		XDG_RUNTIME_DIR \
		DISPLAY \
		XAUTHORITY \
		DBUS_SESSION_BUS_ADDRESS \
		SWAYSOCK \
		XDG_CURRENT_DESKTOP \
		XDG_SESSION_TYPE \
		XDG_SESSION_DESKTOP \
		WLR_XWAYLAND_NO_AUTH
	do
		value="$(frontend_env_value "${pid}" "${name}" 2>/dev/null || true)"
		[ -n "${value}" ] && export "${name}=${value}"
	done

	if [ -z "${WAYLAND_DISPLAY}" ]; then
		for sock in "${XDG_RUNTIME_DIR:-/var/run}"/wayland-* /var/run/wayland-* /run/wayland-*; do
			[ -S "${sock}" ] || continue
			export XDG_RUNTIME_DIR="$(dirname "${sock}")"
			export WAYLAND_DISPLAY="$(basename "${sock}")"
			break
		done
	fi
}

clear_runtime_launcher_env() {
	local name

	for name in $(env | sed -n 's/^\(BATOCERA_STEAM_[A-Za-z0-9_]*\)=.*/\1/p'); do
		unset "$name"
	done
	for name in $(env | sed -n 's/^\(GAMESCOPE_[A-Za-z0-9_]*\)=.*/\1/p'); do
		unset "$name"
	done

	unset STEAM_DECK
	unset STEAMOS
	unset STEAM_GAMEPADUI
	unset STEAM_FORCE_DESKTOPUI
	unset STEAM_GAME
	unset SteamGameId
	unset SteamAppId
	unset STEAM_USE_MANGOAPP
	unset STEAM_MANGOAPP_PRESETS_SUPPORTED
	unset GAMESCOPE_DISPLAY
	unset GAMESCOPE_WAYLAND_DISPLAY
	unset GAMESCOPE_SESSION
	unset WLR_DRM_DEVICES
	unset WLR_LIBINPUT_NO_DEVICES
	unset SDL_NOMOUSE
}

case "$1" in
	start)
		clear_runtime_launcher_env

		# Clean up any old pipe and create a new one for communication
		rm -f "${FIFO_PATH}"
		rm -f "${SUSPEND_FLAG}"
		mkfifo -m 666 "${FIFO_PATH}"

		enabled="$(/usr/bin/batocera-settings-get system.es.atstartup)"
		if [ "$enabled" != "0" ]; then
			if frontend_running; then
				exit 0
			fi

			if compositor_running; then
				export_existing_compositor_env
				emulationstation-standalone &
			else
				%BATOCERA_EMULATIONSTATION_CMD% %BATOCERA_EMULATIONSTATION_POSTFIX%
			fi
		fi
		;;

	stop)
		for COMPOSITOR in openbox sway labwc; do
			pidof $COMPOSITOR >/dev/null && break || COMPOSITOR=
		done

		emulationstation-standalone --stop-rebooting 2>/dev/null
		pkill -TERM -f '/usr/bin/emulationstation-standalone' 2>/dev/null || true
		pkill -TERM -f 'dbus-run-session -- emulationstation' 2>/dev/null || true

		if [ -n "$COMPOSITOR" ]; then
			case "$COMPOSITOR" in
				openbox) openbox --exit 2>/dev/null ;;
				sway)    swaymsg exit 2>/dev/null ;;
				labwc)   labwc --exit 2>/dev/null ;;
			esac
		fi

		# Send the standard terminate signal (SIGTERM) to other processes.
		killall touchegg         2>/dev/null
		killall emulationstation 2>/dev/null
		pkill -KILL -f '/usr/bin/emulationstation-standalone' 2>/dev/null || true
		pkill -KILL -f 'dbus-run-session -- emulationstation' 2>/dev/null || true

		# Forcefully kill the compositor if they're still running.
		if [ -n "$COMPOSITOR" ] && pidof "$COMPOSITOR" >/dev/null; then
			killall -9 "$COMPOSITOR" 2>/dev/null
		fi

		# Kill ES after 20 seconds if still active also
		if pidof emulationstation >/dev/null; then
		    timeout -k 5 20 tail -q --pid=$(pidof emulationstation) -f /dev/null 2>/dev/null
		fi
		
		# Clean up the communication pipe on a full system stop
		rm -f "${FIFO_PATH}"
		rm -f "${SUSPEND_FLAG}"
		;;

	suspend)
		echo "Suspending EmulationStation process only..."
		# Create the suspend flag file before telling ES to quit.
		touch "${SUSPEND_FLAG}"
		# Now, tell the running ES process to quit gracefully.
		curl -s --connect-timeout 2 "http://localhost:1234/quit" > /dev/null
		;;

	resume)
		echo "Resuming EmulationStation process..."
		# Write to the pipe to unblock the waiting 'read' command in the launcher script.
		if [ -p "${FIFO_PATH}" ]; then
			echo "resume" > "${FIFO_PATH}"
		else
			echo "Error: FIFO pipe not found. Cannot resume. Is the ES service running?" >&2
		fi
		;;

	restart|reload)
		"$0" stop
		"$0" start
		;;

	*)
		echo "Usage: $0 {start|stop|restart|suspend|resume}"
		exit 1
esac

exit $?
