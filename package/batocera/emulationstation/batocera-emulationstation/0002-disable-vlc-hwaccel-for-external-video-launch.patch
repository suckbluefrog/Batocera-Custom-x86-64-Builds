From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: suckbluefrog <suckbluefrog@proton.me>
Date: Mon, 01 Jun 2026 16:34:27 +0000
Subject: [PATCH] Disable VLC hardware decode for external video launches

Some VA-API paths can render short H.264 loading screen videos as a
solid green frame when launched through VLC. These one-shot external
video launches are small splash clips, so prefer software decode for
reliable playback.
---
 es-app/src/FileData.cpp | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

--- a/es-app/src/FileData.cpp
+++ b/es-app/src/FileData.cpp
@@ -717,11 +717,11 @@ static std::vector<std::pair<std::string, std::string>> getLaunchVideoCommands(c
 	auto duration = maxDuration > 0 ? std::to_string(maxDuration) : "";
 
 	if (Utils::FileSystem::exists("/usr/bin/cvlc"))
-		commands.push_back({ "cvlc", std::string("/usr/bin/cvlc --fullscreen --no-video-title-show --play-and-exit --no-loop --no-repeat ") +
+		commands.push_back({ "cvlc", std::string("/usr/bin/cvlc --fullscreen --no-video-title-show --play-and-exit --no-loop --no-repeat --avcodec-hw=none ") +
 			(duration.empty() ? "" : "--run-time " + duration + " ") + escapedVideo + (duration.empty() ? "" : " vlc://quit") });
 
 	if (Utils::FileSystem::exists("/usr/bin/vlc"))
-		commands.push_back({ "vlc", std::string("/usr/bin/vlc --fullscreen --no-video-title-show --play-and-exit --no-loop --no-repeat ") +
+		commands.push_back({ "vlc", std::string("/usr/bin/vlc --fullscreen --no-video-title-show --play-and-exit --no-loop --no-repeat --avcodec-hw=none ") +
 			(duration.empty() ? "" : "--run-time " + duration + " ") + escapedVideo + (duration.empty() ? "" : " vlc://quit") });
 
 	if (Utils::FileSystem::exists("/usr/bin/mpv"))
-- 
