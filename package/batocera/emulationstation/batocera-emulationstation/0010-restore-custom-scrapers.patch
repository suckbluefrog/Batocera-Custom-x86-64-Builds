+	std::string getCleanGameName(const ScraperSearchParams& params)
+	{
+		auto cleanName = params.nameOverride;
+		if (cleanName.empty())
+			cleanName = Utils::String::removeParenthesis(Utils::FileSystem::getStem(params.game->getPath()));
