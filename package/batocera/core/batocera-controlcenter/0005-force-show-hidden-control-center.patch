From 0fc4f7d5b9c3b42aa1af0a2dfb2cf12bf4a3f984 Mon Sep 17 00:00:00 2001
From: suckbluefrog <suckbluefrog@proton.me>
Date: Wed, 3 Jun 2026 00:00:00 +0000
Subject: [PATCH] force show hidden control center

---
 controlcenter.py | 6 ++++++
 ui_core.py       | 9 +++++++++
 2 files changed, 15 insertions(+)

diff --git a/controlcenter.py b/controlcenter.py
index 52bb78f..9859039 100755
--- a/controlcenter.py
+++ b/controlcenter.py
@@ -73,9 +73,15 @@ def main():
         if app_instance[0]:
             app_instance[0].core.toggle_visibility()
 
+    def signal_handler_usr2(*_):
+        if app_instance[0]:
+            app_instance[0].core.show()
+
     signal.signal(signal.SIGINT, signal_handler)
     signal.signal(signal.SIGTERM, signal_handler)
     signal.signal(signal.SIGUSR1, signal_handler_usr1)
+    if hasattr(signal, "SIGUSR2"):
+        signal.signal(signal.SIGUSR2, signal_handler_usr2)
 
     if not ensure_display():
         sys.stderr.write("ERROR: No GUI display detected. Set DISPLAY or WAYLAND_DISPLAY.\n")
diff --git a/ui_core.py b/ui_core.py
index 086f0ba..5fde9ee 100755
--- a/ui_core.py
+++ b/ui_core.py
@@ -1420,7 +1420,16 @@ class UICore:
         self._handle_gamepad_action = self._handle_gamepad_action_main
         self.start_gamepad()
         self._recompute_conditionals()
+        self.window.show_all()
+        if not getattr(self, "_is_wayland", False):
+            try:
+                self.window.set_keep_above(True)
+            except Exception:
+                pass
         self.window.present()
+        gdk_window = self.window.get_window()
+        if gdk_window:
+            gdk_window.raise_()
         self._run_show_animation()
         self.reset_inactivity_timer()  # Reset timer on button click
         self.start_refresh()
-- 
