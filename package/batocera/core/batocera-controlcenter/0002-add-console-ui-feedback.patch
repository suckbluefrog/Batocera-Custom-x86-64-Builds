+    # ---- Navigation sounds ----
+    def _nav_sound_path(self, name: str) -> str:
+        return os.path.join(self._sound_dir, f"{name}.wav")
+
+    def _generate_nav_sound(self, name: str):
+        os.makedirs(self._sound_dir, exist_ok=True)
+        path = self._nav_sound_path(name)
+        sample_rate = 24000
+        specs = {
+            "move": (0.055, 760.0, 990.0, 0.30),
+            "accept": (0.090, 840.0, 1260.0, 0.34),
+            "back": (0.075, 680.0, 420.0, 0.28),
+        }
+        duration, start_freq, end_freq, volume = specs.get(name, specs["move"])
+        frames = max(1, int(sample_rate * duration))
+
+        with wave.open(path, "wb") as wav:
+            wav.setnchannels(1)
+            wav.setsampwidth(2)
+            wav.setframerate(sample_rate)
+            for index in range(frames):
+                t = index / sample_rate
+                mix = index / max(1, frames - 1)
+                freq = start_freq + ((end_freq - start_freq) * mix)
+                attack = min(1.0, t / 0.006)
+                release = min(1.0, max(0.0, (duration - t) / 0.018))
+                envelope = attack * release * math.exp(-7.0 * t)
+                tone = math.sin(2.0 * math.pi * freq * t)
+                if name == "accept":
+                    tone = 0.65 * tone + 0.35 * math.sin(2.0 * math.pi * (freq * 1.5) * t)
+                value = int(max(-1.0, min(1.0, tone * envelope * volume)) * 32767)
+                wav.writeframesraw(struct.pack("<h", value))
+
+    def _ensure_nav_sound(self, name: str) -> str:
+        path = self._nav_sound_path(name)
+        if not os.path.exists(path):
+            self._generate_nav_sound(name)
+        return path
+
+    def play_nav_sound(self, name: str):
+        if not self._sound_enabled:
+            return
+        now = time.time()
+        if now - self._last_sound_time.get(name, 0) < 0.035:
+            return
+        self._last_sound_time[name] = now
+
+        def worker():
+            try:
+                path = self._ensure_nav_sound(name)
+                player = os.environ.get("BCC_NAV_SOUND_PLAYER", "").strip()
+                if not player:
+                    player = shutil.which("aplay") or shutil.which("paplay") or ""
+                if not player:
+                    return
+                if os.path.basename(player) == "aplay":
+                    cmd = [player, "-q", path]
+                else:
+                    cmd = [player, path]
+                subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, start_new_session=True)
+            except Exception as e:
+                debug_print(f"[SOUND] navigation sound failed: {e}")
+
+        threading.Thread(target=worker, daemon=True).start()
+
+    # ---- Show animation ----
+    def _run_show_animation(self):
+        if not self._show_animation_enabled or not self.window:
+            return
+        outer = getattr(self, "_outer_box", None)
+        if outer is None:
+            return
+
+        try:
+            self.window.set_opacity(0.72)
+        except Exception:
+            pass
+
+        margins = [22, 14, 8, 3, 0]
+        if self._scale_class == "small":
+            margins = [10, 6, 3, 0]
+        elif self._scale_class == "large":
+            margins = [34, 22, 12, 5, 0]
+        step = [0]
+
+        def animate():
+            idx = step[0]
+            margin = margins[min(idx, len(margins) - 1)]
+            try:
+                outer.set_margin_top(margin)
+                outer.set_margin_bottom(margin)
+                outer.set_margin_start(margin)
+                outer.set_margin_end(margin)
+                if len(margins) > 1:
+                    opacity = 0.72 + (0.28 * min(1.0, idx / (len(margins) - 1)))
+                    self.window.set_opacity(opacity)
+            except Exception:
+                return False
+
+            step[0] += 1
+            if step[0] >= len(margins):
+                try:
+                    self.window.set_opacity(1.0)
+                except Exception:
+                    pass
+                return False
+            return True
+
+        GLib.timeout_add(18, animate)
+
