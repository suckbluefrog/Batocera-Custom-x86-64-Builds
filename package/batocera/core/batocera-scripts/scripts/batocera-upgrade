#!/bin/bash

UPDATE_DIR="/userdata/update"
UPDATE_TAR="${UPDATE_DIR}/update.tar"
UPDATE_MD5="${UPDATE_DIR}/update.tar.md5"
LOCAL_UPDATE_TAR="./update.tar"
LOCAL_UPDATE_MD5="./update.tar.md5"

print_usage() {
    cat <<EOF
Usage:
  batocera-upgrade
  batocera-upgrade --check
  batocera-upgrade /path/to/update.tar [/path/to/update.tar.md5]

Updates are local-only. Place update.tar and update.tar.md5 in /userdata/update
or pass a local update.tar path to stage it there. The update is applied on the
next boot after the initramfs validates the MD5 checksum again.
EOF
}

first_md5_field() {
    awk '{print $1; exit}' "${1}"
}

verify_update() {
    local expected_md5
    local actual_md5

    if ! test -f "${UPDATE_TAR}"
    then
	echo "No local update found at ${UPDATE_TAR}."
	return 12
    fi

    if ! test -f "${UPDATE_MD5}"
    then
	echo "Missing checksum file: ${UPDATE_MD5}."
	return 2
    fi

    expected_md5="$(first_md5_field "${UPDATE_MD5}")"
    actual_md5="$(md5sum "${UPDATE_TAR}" | awk '{print $1}')"

    if test -z "${expected_md5}" || test "${expected_md5}" != "${actual_md5}"
    then
	echo "MD5 mismatch for ${UPDATE_TAR}."
	echo "Expected: ${expected_md5:-<empty>}"
	echo "Actual:   ${actual_md5}"
	return 2
    fi

    echo "Local update is staged and MD5 verified:"
    echo "  ${UPDATE_TAR}"
    echo "  ${UPDATE_MD5}"
    return 0
}

stage_update() {
    local source_tar="${1}"
    local source_md5="${2}"
    local stage_action="${3:-copy}"

    if ! test -f "${source_tar}"
    then
	echo "Update tar not found: ${source_tar}" >&2
	return 2
    fi

    if test -z "${source_md5}"
    then
	if test -f "${source_tar}.md5"
	then
	    source_md5="${source_tar}.md5"
	elif test -f "$(dirname "${source_tar}")/update.tar.md5"
	then
	    source_md5="$(dirname "${source_tar}")/update.tar.md5"
	fi
    fi

    if ! test -f "${source_md5}"
    then
	echo "Update checksum not found. Expected ${source_tar}.md5 or provide it as the second argument." >&2
	return 2
    fi

    mkdir -p "${UPDATE_DIR}" || return 1
    if test "${stage_action}" = "move"
    then
	mv "${source_tar}" "${UPDATE_TAR}" || return 1
	mv "${source_md5}" "${UPDATE_MD5}" || return 1
    else
	cp "${source_tar}" "${UPDATE_TAR}" || return 1
	cp "${source_md5}" "${UPDATE_MD5}" || return 1
    fi
}

stage_current_directory_update() {
    if test -f "${LOCAL_UPDATE_TAR}" && test -f "${LOCAL_UPDATE_MD5}"
    then
	if test "$(pwd -P)" = "${UPDATE_DIR}"
	then
	    verify_update || return $?
	    echo "Update is already staged in ${UPDATE_DIR}. Reboot to apply it."
	    return 0
	fi

	echo "Found update.tar and update.tar.md5 in the current directory."
	stage_update "${LOCAL_UPDATE_TAR}" "${LOCAL_UPDATE_MD5}" move || return $?
	verify_update || return $?
	echo "Update staged from the current directory. Reboot to apply it."
	return 0
    fi

    if test -f "${LOCAL_UPDATE_TAR}" || test -f "${LOCAL_UPDATE_MD5}"
    then
	echo "Found only one local update file in the current directory."
	echo "Expected both ./update.tar and ./update.tar.md5."
	return 2
    fi

    return 12
}

case "${1:-}" in
    -h|--help)
	print_usage
	exit 0
	;;
    --check)
	verify_update
	exit $?
	;;
    "")
	stage_current_directory_update
	status=$?
	if test "${status}" -eq 0
	then
	    exit 0
	fi
	if test "${status}" -ne 12
	then
	    exit "${status}"
	fi

	if test -f "${UPDATE_TAR}" || test -f "${UPDATE_MD5}"
	then
	    verify_update
	    status=$?
	    if test "${status}" -eq 0
	    then
		echo "Reboot to apply this update."
		exit 0
	    fi
	    exit "${status}"
	fi
	print_usage
	echo
	echo "No ./update.tar and ./update.tar.md5 found in the current directory."
	echo "Pass explicit paths, or place both files in ${UPDATE_DIR} and reboot."
	exit "${status}"
	;;
    *)
	stage_update "${1}" "${2:-}" || exit $?
	verify_update || exit $?
	echo "Update staged. Reboot to apply it."
	exit 0
	;;
esac
