config BR2_PACKAGE_NANOBOYADVANCE
    bool "nanoboyadvance"
    depends on BR2_INSTALL_LIBSTDCPP
    depends on BR2_PACKAGE_HAS_LIBGL
    select BR2_HOST_CMAKE_AT_LEAST_3_24
    select BR2_PACKAGE_SDL2
    select BR2_PACKAGE_BATOCERA_QT6
    select BR2_PACKAGE_QT6WAYLAND if BR2_PACKAGE_BATOCERA_WAYLAND
    select BR2_PACKAGE_LIBGLU if BR2_PACKAGE_XORG7
    help
      NanoBoyAdvance - Accurate Game Boy Advance emulator.
      Requires OpenGL 3.3 Core Profile.

      https://github.com/nba-emu/NanoBoyAdvance

comment "nanoboyadvance needs OpenGL and a toolchain w/ C++"
    depends on !BR2_INSTALL_LIBSTDCPP || !BR2_PACKAGE_HAS_LIBGL
