+void App::MapConfiguredGamepads() {
+    int numGamepads = 0;
+    SDL_JoystickID *joysticks = SDL_GetJoysticks(&numGamepads);
+    if (joysticks == nullptr) {
+        return;
+    }
+
+    auto mapConfiguredPort = [&](uint32 portIndex, int playerIndex) {
+        const auto configuredPath = m_settings.input.ports[portIndex].devicePath.string();
+        if (configuredPath.empty()) {
+            return;
+        }
+
+        for (int i = 0; i < numGamepads; ++i) {
+            SDL_JoystickID instanceID = joysticks[i];
+            if (m_gamepadPlayerIndices.Contains(instanceID)) {
+                continue;
+            }
+
+            const char *currentPath = SDL_GetJoystickPathForID(instanceID);
+            if (currentPath != nullptr && configuredPath == currentPath) {
+                SDL_Gamepad *gamepad = SDL_OpenGamepad(instanceID);
+                if (gamepad != nullptr) {
+                    m_gamepadPlayerIndices.AssignPlayerIndex(instanceID, playerIndex);
+                    m_gamepads[instanceID] = gamepad;
+                    m_context.inputContext.ConnectGamepad(playerIndex);
+                    devlog::debug<grp::base>("Device {} mapped to Port {} (player index {})", currentPath,
+                                             portIndex + 1, playerIndex);
+                }
+                break;
+            }
+        }
+    };
+
+    mapConfiguredPort(0, 0);
+    mapConfiguredPort(1, 1);
+
+    SDL_free(joysticks);
+}
