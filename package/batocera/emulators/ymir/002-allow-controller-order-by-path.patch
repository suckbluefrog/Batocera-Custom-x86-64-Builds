     int Run(const CommandLineOptions &options);

 private:
+    struct PlayerIndexMap {
+        int GetPlayerIndex(SDL_JoystickID id) const {
+            if (m_playerIndices.contains(id)) {
+                return m_playerIndices.at(id);
+            } else {
+                return -1;
+            }
+        }
+
+        int AssignPlayerIndex(SDL_JoystickID id) {
+            if (m_playerIndices.contains(id)) {
+                return m_playerIndices.at(id);
+            }
+
+            int index = -1;
+            if (m_freePlayerIndices.empty()) {
+                index = 0;
+                while (PlayerIndexAssigned(index)) {
+                    ++index;
+                }
+            } else {
+                auto first = m_freePlayerIndices.begin();
+                index = *first;
+                m_freePlayerIndices.erase(first);
+            }
+            m_playerIndices[id] = index;
+            return index;
+        }
+
+        int AssignPlayerIndex(SDL_JoystickID id, int index) {
+            m_playerIndices[id] = index;
+            m_freePlayerIndices.erase(index);
+            return index;
+        }
+
+        int ReleasePlayerIndex(SDL_JoystickID id) {
+            int index = GetPlayerIndex(id);
+            m_playerIndices.erase(id);
+            if (index >= 0) {
+                m_freePlayerIndices.insert(index);
+            }
+            return index;
+        }
+
+        bool Contains(SDL_JoystickID id) const {
+            return m_playerIndices.contains(id);
+        }
+
+    private:
+        bool PlayerIndexAssigned(int index) const {
+            for (const auto &entry : m_playerIndices) {
+                if (entry.second == index) {
+                    return true;
+                }
+            }
+            return false;
+        }
+
+        std::unordered_map<SDL_JoystickID, int> m_playerIndices{};
+        std::set<int> m_freePlayerIndices{};
+    };
