+bool UseBatoceraThorDualScreen3dsLayout() {
+    const char* value = std::getenv("BATOCERA_THOR_DUAL_SCREEN_3DS");
+    return value != nullptr && value[0] != '\0' && value[0] != '0';
+}
+
+Layout::FramebufferLayout BatoceraThorDualScreen3dsLayout() {
+    return {
+        BATOCERA_THOR_DUAL_SCREEN_WIDTH,
+        BATOCERA_THOR_DUAL_SCREEN_HEIGHT,
+        true,
+        true,
+        {0, 0, BATOCERA_THOR_DUAL_SCREEN_WIDTH, BATOCERA_THOR_TOP_SCREEN_HEIGHT},
+        {BATOCERA_THOR_BOTTOM_SCREEN_LEFT, BATOCERA_THOR_BOTTOM_SCREEN_TOP,
+         BATOCERA_THOR_BOTTOM_SCREEN_LEFT + BATOCERA_THOR_BOTTOM_SCREEN_WIDTH,
+         BATOCERA_THOR_BOTTOM_SCREEN_TOP + BATOCERA_THOR_BOTTOM_SCREEN_HEIGHT},
+        true,
+    };
+}
+
