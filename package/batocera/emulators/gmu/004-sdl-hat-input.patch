 #define JOYSTICK_THRESHOLD 3200
 
+#define JOYHAT_BUTTON_BASE 200
+
+static int joy_hat_button(Uint8 hat, Uint8 value)
+{
+	int base = JOYHAT_BUTTON_BASE + (hat * 4);
+
+	if (value & SDL_HAT_UP)    return base;
+	if (value & SDL_HAT_DOWN)  return base + 1;
+	if (value & SDL_HAT_LEFT)  return base + 2;
+	if (value & SDL_HAT_RIGHT) return base + 3;
+
+	return 0;
+}
