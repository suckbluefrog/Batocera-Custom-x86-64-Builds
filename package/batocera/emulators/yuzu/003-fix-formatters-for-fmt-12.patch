From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: suckbluefrog <suckbluefrog@proton.me>
Date: Sun, 7 Jun 2026 00:00:00 +0000
Subject: [PATCH] yuzu: make fmt format methods const for fmt 12

fmt 12 calls formatter::format through a const formatter object. Match the
newer formatter API by marking yuzu's stateless custom format methods const.
---
diff --git a/src/common/logging/formatter.h b/src/common/logging/formatter.h
--- a/src/common/logging/formatter.h
+++ b/src/common/logging/formatter.h
@@ -17 +17 @@
-    auto format(const T& value, FormatContext& ctx) -> decltype(ctx.out()) {
+    auto format(const T& value, FormatContext& ctx) const -> decltype(ctx.out()) {
diff --git a/src/common/typed_address.h b/src/common/typed_address.h
--- a/src/common/typed_address.h
+++ b/src/common/typed_address.h
