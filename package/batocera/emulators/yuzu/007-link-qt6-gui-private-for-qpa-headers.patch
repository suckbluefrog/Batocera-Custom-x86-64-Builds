From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: suckbluefrog <suckbluefrog@proton.me>
Date: Sun, 7 Jun 2026 00:00:00 +0000
Subject: [PATCH] yuzu: link Qt6 GuiPrivate for QPA headers

qt_common.cpp includes qpa/qplatformnativeinterface.h. With Qt 6, Buildroot
exports that QPA include path through the GuiPrivate CMake target.
---
diff --git a/CMakeLists.txt b/CMakeLists.txt
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -379,6 +379,9 @@ function(set_yuzu_qt_components)
     if (${CMAKE_SYSTEM_NAME} STREQUAL "Linux")
         list(APPEND YUZU_QT_COMPONENTS2 DBus)
     endif()
+    if (${CMAKE_SYSTEM_NAME} STREQUAL "Linux" AND ENABLE_QT6)
+        list(APPEND YUZU_QT_COMPONENTS2 GuiPrivate)
+    endif()
     if (YUZU_USE_QT_MULTIMEDIA)
         list(APPEND YUZU_QT_COMPONENTS2 Multimedia)
     endif()
diff --git a/src/yuzu/CMakeLists.txt b/src/yuzu/CMakeLists.txt
--- a/src/yuzu/CMakeLists.txt
+++ b/src/yuzu/CMakeLists.txt
@@ -393,6 +393,9 @@ if (NOT WIN32)
 endif()
 if (UNIX AND NOT APPLE)
     target_link_libraries(yuzu PRIVATE Qt${QT_MAJOR_VERSION}::DBus)
+    if (QT_MAJOR_VERSION EQUAL 6)
+        target_link_libraries(yuzu PRIVATE Qt6::GuiPrivate)
+    endif()
 endif()
 
 target_compile_definitions(yuzu PRIVATE
-- 
