config BR2_PACKAGE_YUZU
	bool "Yuzu (Nintendo Switch)"
	depends on BR2_x86_64 || BR2_aarch64
	select BR2_PACKAGE_BOOST
	select BR2_PACKAGE_BOOST_CONTEXT
	select BR2_PACKAGE_BOOST_FILESYSTEM
	select BR2_PACKAGE_BOOST_SYSTEM
	select BR2_PACKAGE_ENET
	select BR2_PACKAGE_FFMPEG
	select BR2_PACKAGE_FMT
	select BR2_PACKAGE_JSON_FOR_MODERN_CPP
	select BR2_PACKAGE_LIBOPENSSL
	select BR2_PACKAGE_LZ4
	select BR2_PACKAGE_OPUS
	select BR2_PACKAGE_QT6BASE
	select BR2_PACKAGE_SDL2
	select BR2_PACKAGE_VULKAN_HEADERS
	select BR2_PACKAGE_VULKAN_LOADER
	select BR2_PACKAGE_ZLIB
	select BR2_PACKAGE_ZSTD
	help
	  Yuzu Nintendo Switch emulator.

	  This package builds Yuzu from source and installs the native Qt
	  frontend behind the wrapper script in /usr/bin/yuzu.
