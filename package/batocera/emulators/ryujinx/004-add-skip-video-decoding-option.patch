From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: suckbluefrog <suckbluefrog@proton.me>
Date: Sun, 28 Jun 2026 00:00:00 +0000
Subject: [PATCH] add option to skip NVDEC video decoding

Some games can hang or crash on video playback while the rest of the title is
playable. Add a persistent skip_videos configuration option that routes through
HLE into the GPU/NVDEC path and skips video frame decoding when enabled.

Signed-off-by: suckbluefrog <suckbluefrog@proton.me>
---
 src/Ryujinx.Graphics.Gpu/GpuContext.cs                       |  8 +++++++-
 src/Ryujinx.Graphics.Nvdec/NvdecDevice.cs                    | 13 ++++++++++++-
 src/Ryujinx.HLE/HOS/Services/Nv/Host1xContext.cs             |  2 +-
 src/Ryujinx.HLE/HleConfiguration.cs                          |  8 ++++++++
 src/Ryujinx.HLE/Switch.cs                                    |  2 +-
 src/Ryujinx/Headless/HeadlessRyujinx.Init.cs                 |  1 +
 src/Ryujinx/Systems/Configuration/ConfigurationFileFormat.cs |  5 +++++
 src/Ryujinx/Systems/Configuration/ConfigurationState.Model.cs | 10 ++++++++++
 src/Ryujinx/Systems/Configuration/ConfigurationState.Migration.cs |  3 ++-
 src/Ryujinx/Systems/Configuration/ConfigurationState.cs      |  3 +++
 10 files changed, 50 insertions(+), 5 deletions(-)

diff --git a/src/Ryujinx.Graphics.Gpu/GpuContext.cs b/src/Ryujinx.Graphics.Gpu/GpuContext.cs
--- a/src/Ryujinx.Graphics.Gpu/GpuContext.cs
+++ b/src/Ryujinx.Graphics.Gpu/GpuContext.cs
@@ -101,6 +101,11 @@ namespace Ryujinx.Graphics.Gpu
         /// </summary>
         internal DirtyHacks DirtyHacks { get; }

+        /// <summary>
+        /// Skip NVDEC video frame decoding.
+        /// </summary>
+        public bool SkipVideoDecoding { get; }
+

         /// <summary>
         /// Host hardware capabilities.
@@ -121,8 +126,9 @@ namespace Ryujinx.Graphics.Gpu
         /// Creates a new instance of the GPU emulation context.
         /// </summary>
         /// <param name="renderer">Host renderer</param>
-        public GpuContext(IRenderer renderer, DirtyHacks hacks)
+        public GpuContext(IRenderer renderer, DirtyHacks hacks, bool skipVideoDecoding)
         {
             Renderer = renderer;
+            SkipVideoDecoding = skipVideoDecoding;

             GPFifo = new GPFifoDevice(this);

diff --git a/src/Ryujinx.Graphics.Nvdec/NvdecDevice.cs b/src/Ryujinx.Graphics.Nvdec/NvdecDevice.cs
--- a/src/Ryujinx.Graphics.Nvdec/NvdecDevice.cs
+++ b/src/Ryujinx.Graphics.Nvdec/NvdecDevice.cs
@@ -11,14 +11,17 @@ namespace Ryujinx.Graphics.Nvdec
     {
         private readonly ResourceManager _rm;
         private readonly DeviceState<NvdecRegisters> _state;
+        private readonly bool _skipVideoDecoding;

         private long _currentId;
         private readonly ConcurrentDictionary<long, NvdecDecoderContext> _contexts;
         private NvdecDecoderContext _currentContext;
+        private bool _reportedVideoSkip;

-        public NvdecDevice(DeviceMemoryManager mm)
+        public NvdecDevice(DeviceMemoryManager mm, bool skipVideoDecoding)
         {
             _rm = new ResourceManager(mm, new SurfaceCache(mm));
+            _skipVideoDecoding = skipVideoDecoding;
             _state = new DeviceState<NvdecRegisters>(new Dictionary<string, RwCallback>
             {
                 { nameof(NvdecRegisters.Execute), new RwCallback(Execute, null) },
@@ -62,6 +66,13 @@ namespace Ryujinx.Graphics.Nvdec

         private void Decode(ApplicationId applicationId)
         {
+            if (_skipVideoDecoding)
+            {
+                LogVideoSkipOnce();
+
+                return;
+            }
+
             switch (applicationId)
             {
                 case ApplicationId.H264:
@@ -79,5 +90,14 @@ namespace Ryujinx.Graphics.Nvdec
                     break;
             }
         }
+
+        private void LogVideoSkipOnce()
+        {
+            if (!_reportedVideoSkip)
+            {
+                Logger.Info?.Print(LogClass.Nvdec, "NVDEC video decoding is disabled. Skipping video frames.");
+                _reportedVideoSkip = true;
+            }
+        }
     }
 }
diff --git a/src/Ryujinx.HLE/HOS/Services/Nv/Host1xContext.cs b/src/Ryujinx.HLE/HOS/Services/Nv/Host1xContext.cs
--- a/src/Ryujinx.HLE/HOS/Services/Nv/Host1xContext.cs
+++ b/src/Ryujinx.HLE/HOS/Services/Nv/Host1xContext.cs
@@ -18,7 +18,7 @@ namespace Ryujinx.HLE.HOS.Services.Nv
             MemoryAllocator = new NvMemoryAllocator();
             Host1x = new Host1xDevice(gpu.Synchronization);
             Smmu = gpu.CreateDeviceMemoryManager(pid);
-            NvdecDevice nvdec = new(Smmu);
+            NvdecDevice nvdec = new(Smmu, gpu.SkipVideoDecoding);
             VicDevice vic = new(Smmu);
             Host1x.RegisterDevice(ClassId.Nvdec, nvdec);
             Host1x.RegisterDevice(ClassId.Vic, vic);
diff --git a/src/Ryujinx.HLE/HleConfiguration.cs b/src/Ryujinx.HLE/HleConfiguration.cs
