+        internal readonly bool SkipVideoDecoding;
+
         /// <summary>
         /// Use Hypervisor over JIT if available.
         /// </summary>
@@ -235,6 +240,7 @@ namespace Ryujinx.HLE
                                 bool ignoreMissingServices,
                                 AspectRatio aspectRatio,
                                 float audioVolume,
+                                bool skipVideoDecoding,
                                 bool useHypervisor,
                                 string multiplayerLanInterfaceId,
                                 MultiplayerMode multiplayerMode,
@@ -262,6 +268,7 @@ namespace Ryujinx.HLE
             IgnoreMissingServices = ignoreMissingServices;
             AspectRatio = aspectRatio;
             AudioVolume = audioVolume;
+            SkipVideoDecoding = skipVideoDecoding;
             UseHypervisor = useHypervisor;
             MultiplayerLanInterfaceId = multiplayerLanInterfaceId;
             MultiplayerMode = multiplayerMode;
diff --git a/src/Ryujinx.HLE/Switch.cs b/src/Ryujinx.HLE/Switch.cs
--- a/src/Ryujinx.HLE/Switch.cs
+++ b/src/Ryujinx.HLE/Switch.cs
@@ -85,7 +85,7 @@ namespace Ryujinx.HLE
             DirtyHacks        = new DirtyHacks(Configuration.Hacks);
             AudioDeviceDriver = new CompatLayerHardwareDeviceDriver(Configuration.AudioDeviceDriver);
             Memory            = new MemoryBlock(Configuration.MemoryConfiguration.ToDramSize(), memoryAllocationFlags);
