config BR2_PACKAGE_XENIA_CANARY
	bool "xenia-canary"
	depends on BR2_x86_64
	select BR2_PACKAGE_ALSA_LIB
	select BR2_PACKAGE_FONTCONFIG
	select BR2_PACKAGE_LIBGTK3
	select BR2_PACKAGE_LIBGTK3_X11
	select BR2_PACKAGE_LZ4
	select BR2_PACKAGE_SDL2
	select BR2_PACKAGE_VULKAN_HEADERS
	select BR2_PACKAGE_VULKAN_LOADER
	select BR2_PACKAGE_WINE_PROTON
	select BR2_PACKAGE_XLIB_LIBX11
	select BR2_PACKAGE_LIBXCB
	select BR2_PACKAGE_PYTHON_TOML
	help
	  Xenia is an open source research project for emulating Xbox 360
	  games on modern PCs. This is the bleeding edge canary release,
	  built natively for Vulkan while keeping the Windows build for D3D12/Wine.

	  https://xenia.jp/
