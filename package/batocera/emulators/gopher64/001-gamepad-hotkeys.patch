+else if (event->type == SDL_EVENT_GAMEPAD_BUTTON_DOWN)
+{
+    switch (event->gbutton.button)
+    {
+    case SDL_GAMEPAD_BUTTON_GUIDE:
+        guide_held = true;
+        break;
+
+    case SDL_GAMEPAD_BUTTON_RIGHT_SHOULDER: // R1
+        if (guide_held)
+        {
+            callback.save_state = true;
+            return 1;
+        }
+        break;
+
+    case SDL_GAMEPAD_BUTTON_LEFT_SHOULDER: // L1
+        if (guide_held)
+        {
+            callback.load_state = true;
+            return 1;
+        }
+        break;
+
+    case SDL_GAMEPAD_BUTTON_WEST: // West
+        if (guide_held)
+        {
+            display_fps = !display_fps;
+            rdp_onscreen_message(
+                display_fps ? "FPS display ON" : "FPS display OFF",
+                MESSAGE_SHORT
+            );
+            return 1;
+        }
+        break;
+
+    case SDL_GAMEPAD_BUTTON_SOUTH: // South
+        if (guide_held)
+        {
+            callback.reset_game = true;
+            rdp_onscreen_message("Reset game", MESSAGE_SHORT);
+            return 1;
+        }
+        break;
+
+    case SDL_GAMEPAD_BUTTON_START: //Start
+        if (guide_held)
+        {
+            if (gfx_info.fullscreen)
+                callback.emu_running = false;
+            return 1;
+        }
+        break;
+
+    case SDL_GAMEPAD_BUTTON_MISC1: // Share
+        if (guide_held)
+        {
+          SDL_RunOnMainThread(ra_display_inprogress_achievements, nullptr, true);
+        }
+        break;
 
+    default:
+        if (guide_held)
+            return 1; // block other inputs while guide held
+        break;
+    }
+}
+else if (event->type == SDL_EVENT_GAMEPAD_AXIS_MOTION)
+{
+    switch (event->gaxis.axis)
+    {
+    case SDL_GAMEPAD_AXIS_RIGHT_TRIGGER: // R2
+    {
+        bool pressed = event->gaxis.value > 0;
+
+        if (pressed && !r2_held && guide_held)
+        {
+            fast_forward_toggled = !fast_forward_toggled;
+            callback.enable_speedlimiter = !fast_forward_toggled;
+
+            rdp_onscreen_message(
+                fast_forward_toggled ? "Fast forward on"
+                                     : "Fast forward off",
+                MESSAGE_SHORT
+            );
+
+            r2_held = true;
+            return 1;
+        }
+
+        if (!pressed)
+            r2_held = false;
+    }
+    break;
+
+    default:
+        break;
+    }
+}
+else if (event->type == SDL_EVENT_GAMEPAD_BUTTON_UP)
+{
+    switch (event->gbutton.button)
+    {
+    case SDL_GAMEPAD_BUTTON_GUIDE:
+        guide_held = false;
+        break;
+
+    default:
+        break;
+    }
+}
   return 0;
 }
 
