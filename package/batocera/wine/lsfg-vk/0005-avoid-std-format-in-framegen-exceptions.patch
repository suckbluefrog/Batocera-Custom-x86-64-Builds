From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: suckbluefrog <suckbluefrog@proton.me>
Date: Wed, 6 May 2026 19:05:00 +0000
Subject: [PATCH] Avoid std::format in framegen exceptions

The x86_64 Wine layer is built with the host C++ compiler during aarch64
Buildroot builds. Some supported build hosts provide a C++20 compiler without
libstdc++'s <format> header, which fails the x86 helper build even though the
formatting here is simple exception text.
---
 framegen/src/common/exception.cpp | 7 +++----
 1 file changed, 3 insertions(+), 4 deletions(-)

diff --git a/framegen/src/common/exception.cpp b/framegen/src/common/exception.cpp
index 44db95d..9d44833 100644
--- a/framegen/src/common/exception.cpp
+++ b/framegen/src/common/exception.cpp
@@ -5,20 +5,19 @@
 #include <exception>
 #include <stdexcept>
 #include <cstdint>
-#include <format>
 #include <string>
 
 using namespace LSFG;
 
 vulkan_error::vulkan_error(VkResult result, const std::string& message)
-    : std::runtime_error(std::format("{} (error {})", message, static_cast<int32_t>(result))),
+    : std::runtime_error(message + " (error " + std::to_string(static_cast<int32_t>(result)) + ")"),
       result(result) {}
 
 vulkan_error::~vulkan_error() noexcept = default;
 
 rethrowable_error::rethrowable_error(const std::string& message, const std::exception& exe)
         : std::runtime_error(message) {
-    this->message = std::format("{}\n- {}", message, exe.what());
+    this->message = message + "\n- " + exe.what();
 }
 
 rethrowable_error::~rethrowable_error() noexcept = default;
