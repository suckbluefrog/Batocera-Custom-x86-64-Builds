config BR2_PACKAGE_LSFG_VK
	bool "lsfg-vk"
	depends on BR2_x86_64 || BR2_aarch64
	help
	  Lossless Scaling Frame Generation Vulkan layer.
	  On aarch64 targets this builds the native layer for native Vulkan
	  AppImages and also installs the upstream x86_64 layer privately for
	  Wine/FEX. A user-provided Lossless.dll from a purchased Lossless
	  Scaling installation is still required at runtime.

	  https://github.com/PancakeTAS/lsfg-vk
