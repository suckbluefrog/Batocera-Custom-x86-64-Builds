From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: suckbluefrog <suckbluefrog@proton.me>
Date: Wed, 6 May 2026 16:25:00 +0000
Subject: [PATCH] Respect DISABLE_LSFG while returning layer hooks

The frame generation context sets DISABLE_LSFG before creating its own
internal Vulkan objects. With an explicit layer inside Wine, the loader may
still call the already-loaded layer entry points in the same process. That
lets lsfg-vk recursively hook its own internal Vulkan device, which does not
provide swapchain functions, and Wine can abort when the layer returns a
failed device creation.

Check DISABLE_LSFG at hook dispatch time so recursive/internal Vulkan work is
passed through instead of being wrapped again.
---
 src/layer.cpp | 16 +++++++++++-----
 1 file changed, 11 insertions(+), 5 deletions(-)

diff --git a/src/layer.cpp b/src/layer.cpp
index 171e47b..f0d9b50 100644
--- a/src/layer.cpp
+++ b/src/layer.cpp
@@ -8,6 +8,7 @@
 #include <unordered_map>
 #include <exception>
 #include <iostream>
+#include <cstdlib>
 #include <cstdint>
 #include <string>
 
@@ -74,6 +75,10 @@ namespace {
         }
         return true;
     }
+
+    bool layerDisabled() {
+        return std::getenv("DISABLE_LSFG") != nullptr;
+    }
 }
 
 namespace {
@@ -103,7 +108,7 @@ namespace {
                     "Failed to get instance function pointer for vkCreateInstance");
 
             // NOLINTEND | skip initialization if the layer is disabled
-            if (!Config::activeConf.enable) {
+            if (layerDisabled() || !Config::activeConf.enable) {
                 auto res = next_vkCreateInstance(pCreateInfo, pAllocator, pInstance);
                 initInstanceFunc(*pInstance, "vkCreateDevice", &next_vkCreateDevice);
                 return res;
@@ -182,7 +187,7 @@ namespace {
             next_vSetDeviceLoaderData = layerDesc2->u.pfnSetDeviceLoaderData;
 
             // NOLINTEND | skip initialization if the layer is disabled
-            if (!Config::activeConf.enable)
+            if (layerDisabled() || !Config::activeConf.enable)
                 return next_vkCreateDevice(physicalDevice, pCreateInfo, pAllocator, pDevice);
 
             // create device
@@ -262,7 +267,7 @@ extern "C" __attribute__((visibility("default"))) PFN_vkVoidFunction layer_vkGet
         return it->second;
 
     it = Hooks::hooks.find(name);
-    if (it != Hooks::hooks.end() && Config::activeConf.enable)
+    if (it != Hooks::hooks.end() && !layerDisabled() && Config::activeConf.enable)
         return it->second;
 
     return next_vkGetInstanceProcAddr(instance, pName);
@@ -275,7 +280,7 @@ extern "C" __attribute__((visibility("default"))) PFN_vkVoidFunction layer_vkGet
         return it->second;
 
     it = Hooks::hooks.find(name);
-    if (it != Hooks::hooks.end() && Config::activeConf.enable)
+    if (it != Hooks::hooks.end() && !layerDisabled() && Config::activeConf.enable)
         return it->second;
 
     return next_vkGetDeviceProcAddr(device, pName);
