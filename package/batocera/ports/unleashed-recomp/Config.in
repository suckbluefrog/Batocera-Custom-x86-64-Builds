config BR2_PACKAGE_UNLEASHED_RECOMP
	bool "unleashedrecomp"
	depends on BR2_x86_64
	depends on BR2_TOOLCHAIN_USES_GLIBC
	depends on BR2_INSTALL_LIBSTDCPP
	depends on BR2_TOOLCHAIN_HAS_THREADS
	depends on BR2_USE_WCHAR
	depends on BR2_PACKAGE_HOST_RUSTC_ARCH_SUPPORTS
	depends on BR2_USE_MMU
	depends on BR2_TOOLCHAIN_HAS_SYNC_4
	depends on BR2_TOOLCHAIN_GCC_AT_LEAST_4_9
	depends on BR2_PACKAGE_HAS_LIBEGL || BR2_PACKAGE_HAS_LIBGL
	select BR2_PACKAGE_LIBGTK3
	select BR2_PACKAGE_VULKAN_LOADER
	help
	  Unleashed Recompiled, a native Sonic Unleashed Xbox 360
	  recompilation port.

	  Requires user-supplied original Xbox 360 game/update/DLC files at
	  runtime.

	  https://github.com/hedge-dev/UnleashedRecomp

comment "unleashedrecomp needs an x86_64 glibc C++ toolchain with GTK3 and Vulkan support"
	depends on !BR2_x86_64 || !BR2_TOOLCHAIN_USES_GLIBC || \
		!BR2_INSTALL_LIBSTDCPP || !BR2_TOOLCHAIN_HAS_THREADS || \
		!BR2_USE_WCHAR || !BR2_PACKAGE_HOST_RUSTC_ARCH_SUPPORTS || \
		!BR2_USE_MMU || !BR2_TOOLCHAIN_HAS_SYNC_4 || \
		!BR2_TOOLCHAIN_GCC_AT_LEAST_4_9 || \
		(!BR2_PACKAGE_HAS_LIBEGL && !BR2_PACKAGE_HAS_LIBGL)
