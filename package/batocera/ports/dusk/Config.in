config BR2_PACKAGE_DUSK
	bool "dusk"
	depends on BR2_aarch64 || BR2_x86_64
	depends on BR2_PACKAGE_HOST_RUSTC_TARGET_ARCH_SUPPORTS
	depends on BR2_TOOLCHAIN_HAS_THREADS
	depends on BR2_INSTALL_LIBSTDCPP
	depends on !BR2_STATIC_LIBS
	select BR2_PACKAGE_HOST_RUSTC
	select BR2_PACKAGE_BATOCERA_SDL3
	select BR2_PACKAGE_VULKAN_HEADERS
	select BR2_PACKAGE_VULKAN_LOADER
	select BR2_PACKAGE_LIBCURL
	select BR2_PACKAGE_FREETYPE
	select BR2_PACKAGE_ZLIB
	select BR2_PACKAGE_LIBPNG
	select BR2_PACKAGE_ALSA_LIB
	select BR2_PACKAGE_PULSEAUDIO
	select BR2_PACKAGE_DBUS
	select BR2_PACKAGE_UDEV
	help
	  Native Twilight Princess engine reimplementation.

	  Requires a user-supplied original game dump at runtime.

	  https://github.com/TwilitRealm/dusk

comment "dusk needs a dynamic C++ toolchain with threads and Rust target support"
	depends on !(BR2_aarch64 || BR2_x86_64) || BR2_STATIC_LIBS || \
		!BR2_TOOLCHAIN_HAS_THREADS || !BR2_INSTALL_LIBSTDCPP || \
		!BR2_PACKAGE_HOST_RUSTC_TARGET_ARCH_SUPPORTS
