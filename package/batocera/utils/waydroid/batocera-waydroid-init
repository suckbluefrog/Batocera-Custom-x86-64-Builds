#!/bin/bash
set -euo pipefail

LOG_FILE="/userdata/system/logs/waydroid-init.log"
STATE_ROOT="/userdata/system/waydroid"
STATE_VARLIB="${STATE_ROOT}/var-lib"
PROFILE_FILE="/userdata/system/configs/waydroid/image-profile"
WAYDROID_CFG="/var/lib/waydroid/waydroid.cfg"
WAYDROID_BASE_PROP="/var/lib/waydroid/waydroid_base.prop"
EXPECTED_IMAGES_DIR="/var/lib/waydroid/images"

PROFILE="standard-gapps"
PROFILE_LABEL="Standard Android with Google apps"
SYSTEM_TYPE="GAPPS"
SYSTEM_CHANNEL="https://ota.waydro.id/system"
VENDOR_CHANNEL="https://ota.waydro.id/vendor"
ROM_TYPE="lineage"

mkdir -p /userdata/system/logs "${STATE_VARLIB}" "$(dirname "${PROFILE_FILE}")"

read_profile() {
    local requested="standard-gapps"

    if [ -f "${PROFILE_FILE}" ]; then
        requested="$(tr -d '\r\n' < "${PROFILE_FILE}")"
    fi

    case "${requested}" in
        standard-gapps)
            PROFILE="standard-gapps"
            PROFILE_LABEL="Standard Android with Google apps"
            SYSTEM_TYPE="GAPPS"
            SYSTEM_CHANNEL="https://ota.waydro.id/system"
            VENDOR_CHANNEL="https://ota.waydro.id/vendor"
            ;;
        standard-vanilla)
            PROFILE="standard-vanilla"
            PROFILE_LABEL="Standard Android without Google apps"
            SYSTEM_TYPE="VANILLA"
            SYSTEM_CHANNEL="https://ota.waydro.id/system"
            VENDOR_CHANNEL="https://ota.waydro.id/vendor"
            ;;
        android-tv-gapps)
            PROFILE="android-tv-gapps"
            PROFILE_LABEL="Android TV with Google apps"
            SYSTEM_TYPE="GAPPS"
            SYSTEM_CHANNEL="https://waydroid-atv.github.io/ota/a16-tv/system"
            VENDOR_CHANNEL="https://waydroid-atv.github.io/ota/a16-tv/vendor"
            ;;
        android-tv-vanilla)
            PROFILE="android-tv-vanilla"
            PROFILE_LABEL="Android TV without Google apps"
            SYSTEM_TYPE="VANILLA"
            SYSTEM_CHANNEL="https://waydroid-atv.github.io/ota/a16-tv/system"
            VENDOR_CHANNEL="https://waydroid-atv.github.io/ota/a16-tv/vendor"
            ;;
        *)
            echo "[$(date '+%F %T')] Invalid Waydroid image profile '${requested}', using standard-gapps" |
                tee -a "${LOG_FILE}"
            ;;
    esac
}

profile_matches_config() {
    local expected_system_ota="${SYSTEM_CHANNEL}/${ROM_TYPE}/waydroid_x86_64/${SYSTEM_TYPE}.json"
    local expected_vendor_prefix="${VENDOR_CHANNEL}/waydroid_x86_64/"

    python3 - "${WAYDROID_CFG}" "${expected_system_ota}" "${expected_vendor_prefix}" <<'PY'
import configparser
import sys

cfg_path, expected_system, expected_vendor_prefix = sys.argv[1:]
cfg = configparser.RawConfigParser()
cfg.read(cfg_path)
if not cfg.has_section("waydroid"):
    raise SystemExit(1)
system_ota = cfg.get("waydroid", "system_ota", fallback="")
vendor_ota = cfg.get("waydroid", "vendor_ota", fallback="")
if system_ota != expected_system or not vendor_ota.startswith(expected_vendor_prefix):
    raise SystemExit(1)
PY
}

# Keep waydroid state in userdata (persistent), even though /var is tmpfs.
if [ -L /var/lib/waydroid ]; then
    :
elif [ -d /var/lib/waydroid ]; then
    rm -rf /var/lib/waydroid
    ln -snf "${STATE_VARLIB}" /var/lib/waydroid
else
    mkdir -p /var/lib
    ln -snf "${STATE_VARLIB}" /var/lib/waydroid
fi

if [ ! -x /usr/bin/waydroid ]; then
    echo "waydroid binary is not installed" | tee -a "${LOG_FILE}"
    exit 1
fi

read_profile

has_network() {
    if command -v ip >/dev/null 2>&1; then
        if ! ip route get 1.1.1.1 >/dev/null 2>&1; then
            return 1
        fi
    fi
    if command -v ping >/dev/null 2>&1; then
        timeout 2 ping -c 1 -W 1 1.1.1.1 >/dev/null 2>&1
        return $?
    fi
    return 0
}

ensure_waydroid_property() {
    local key="$1"
    local value="$2"

    [ -f "${WAYDROID_CFG}" ] || return 0

    python3 - "${WAYDROID_CFG}" "${key}" "${value}" <<'PY'
import configparser
import os
import sys
import tempfile

cfg_path, key, value = sys.argv[1:]
cfg = configparser.RawConfigParser()
cfg.read(cfg_path)
if not cfg.has_section("properties"):
    cfg.add_section("properties")
cfg.set("properties", key, value)
directory = os.path.dirname(cfg_path)
fd, temporary = tempfile.mkstemp(prefix=".waydroid.cfg.", dir=directory, text=True)
try:
    with os.fdopen(fd, "w", encoding="utf-8") as handle:
        cfg.write(handle)
    os.chmod(temporary, 0o600)
    os.replace(temporary, cfg_path)
finally:
    if os.path.exists(temporary):
        os.unlink(temporary)
PY
}

ensure_waydroid_base_property() {
    local key="$1"
    local value="$2"

    if [ ! -f "${WAYDROID_BASE_PROP}" ]; then
        echo "[$(date '+%F %T')] Missing ${WAYDROID_BASE_PROP}; cannot configure Android TV setup" |
            tee -a "${LOG_FILE}"
        return 1
    fi

    python3 - "${WAYDROID_BASE_PROP}" "${key}" "${value}" <<'PY'
import os
import sys
import tempfile

prop_path, key, value = sys.argv[1:]
prefix = f"{key}="
with open(prop_path, encoding="utf-8") as handle:
    lines = handle.read().splitlines()

updated = []
replaced = False
for line in lines:
    if line.startswith(prefix):
        if not replaced:
            updated.append(f"{key}={value}")
            replaced = True
    else:
        updated.append(line)
if not replaced:
    updated.append(f"{key}={value}")

directory = os.path.dirname(prop_path)
fd, temporary = tempfile.mkstemp(prefix=".waydroid_base.prop.", dir=directory, text=True)
try:
    with os.fdopen(fd, "w", encoding="utf-8") as handle:
        handle.write("\n".join(updated) + "\n")
    os.chmod(temporary, os.stat(prop_path).st_mode & 0o777)
    os.replace(temporary, prop_path)
finally:
    if os.path.exists(temporary):
        os.unlink(temporary)
PY
}

need_waydroid_init=0
need_waydroid_download=0

if [ ! -f "${WAYDROID_CFG}" ]; then
    need_waydroid_init=1
    need_waydroid_download=1
elif [ ! -f "${EXPECTED_IMAGES_DIR}/system.img" ] || [ ! -f "${EXPECTED_IMAGES_DIR}/vendor.img" ]; then
    need_waydroid_init=1
    need_waydroid_download=1
elif ! profile_matches_config; then
    echo "[$(date '+%F %T')] Existing Waydroid images do not match selected profile ${PROFILE}" |
        tee -a "${LOG_FILE}"
    echo "Use Emulator -> Waydroid Tools -> Select image profile. Profile changes require a clean container reset." |
        tee -a "${LOG_FILE}"
    if command -v batocera-flash-screen >/dev/null 2>&1; then
        /usr/bin/batocera-flash-screen 7 "#ffffff" "Waydroid profile mismatch." 23 >/dev/null 2>&1 || true
        /usr/bin/batocera-flash-screen 8 "#ffffff" "Use Waydroid Tools to switch profiles safely." 18 >/dev/null 2>&1 || true
    fi
    exit 1
fi

if [ "${need_waydroid_init}" -eq 1 ]; then
    mkdir -p "${EXPECTED_IMAGES_DIR}"

    # Upstream Waydroid skips downloads when cached datetimes are current,
    # even if the image files were deleted. Force a re-download in that case.
    if [ "${need_waydroid_download}" -eq 1 ] && [ -f "${WAYDROID_CFG}" ]; then
        sed -i \
            -e 's/^system_datetime = .*/system_datetime = 0/' \
            -e 's/^vendor_datetime = .*/vendor_datetime = 0/' \
            "${WAYDROID_CFG}"
    fi

    if ! has_network; then
        echo "[$(date '+%F %T')] ${PROFILE_LABEL} initialization requires internet" |
            tee -a "${LOG_FILE}"
        if command -v batocera-flash-screen >/dev/null 2>&1; then
            /usr/bin/batocera-flash-screen 6 "#ffffff" "Waydroid image download needs Wi-Fi." 22 >/dev/null 2>&1 || true
            /usr/bin/batocera-flash-screen 6 "#ffffff" "Please connect to the internet and launch again." 20 >/dev/null 2>&1 || true
        fi
        exit 1
    fi

    if command -v batocera-flash-screen >/dev/null 2>&1; then
        /usr/bin/batocera-flash-screen 12 "#ffffff" "Downloading ${PROFILE_LABEL}. Please wait." 18 >/dev/null 2>&1 || true
    fi

    echo "[$(date '+%F %T')] Initializing profile ${PROFILE}: ${PROFILE_LABEL}" |
        tee -a "${LOG_FILE}"
    /usr/bin/waydroid init -f "$@" \
        -c "${SYSTEM_CHANNEL}" \
        -v "${VENDOR_CHANNEL}" \
        -r "${ROM_TYPE}" \
        -s "${SYSTEM_TYPE}" >>"${LOG_FILE}" 2>&1

    if [ ! -f "${EXPECTED_IMAGES_DIR}/system.img" ] || [ ! -f "${EXPECTED_IMAGES_DIR}/vendor.img" ]; then
        echo "[$(date '+%F %T')] Waydroid init finished but expected images are still missing from ${EXPECTED_IMAGES_DIR}" |
            tee -a "${LOG_FILE}"
        exit 1
    fi
    if ! profile_matches_config; then
        echo "[$(date '+%F %T')] Waydroid init returned images from an unexpected OTA profile" |
            tee -a "${LOG_FILE}"
        exit 1
    fi
fi

# Allow Android to react to hotplugged controllers and other input devices.
ensure_waydroid_property "persist.waydroid.udev" "true"
ensure_waydroid_property "persist.waydroid.uevent" "true"

# WayDroid-ATV 16's Bluetooth remote-pairing page is currently broken and can
# render as a corrupted, non-interactive screen. Upstream documents this
# property as the supported way to skip that page.
case "${PROFILE}" in
    android-tv-*)
        ensure_waydroid_base_property "atv.setup.bt_remote_pairing" "false"
        ;;
esac

# Re-apply native-bridge support only when the user explicitly installed it.
# With no marker, reconcile also removes the legacy image-vendored auto-seed.
if [ -x /usr/bin/batocera-waydroid-arm ]; then
    /usr/bin/batocera-waydroid-arm reconcile >>"${LOG_FILE}" 2>&1
fi
