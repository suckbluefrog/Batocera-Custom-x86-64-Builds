config BR2_PACKAGE_WAYDROID
	bool "waydroid"
	depends on BR2_PACKAGE_BATOCERA_WAYLAND
	depends on BR2_PACKAGE_PYTHON3
	depends on BR2_USE_MMU
	depends on BR2_TOOLCHAIN_HAS_THREADS
	select BR2_PACKAGE_DBUS
	select BR2_PACKAGE_DBUS_PYTHON
	select BR2_PACKAGE_PYTHON_GOBJECT
	select BR2_PACKAGE_PYTHON_GBINDER
	select BR2_PACKAGE_LXC
	select BR2_PACKAGE_IPTABLES
	select BR2_PACKAGE_DNSMASQ
	select BR2_PACKAGE_DIALOG if BR2_x86_64
	select BR2_PACKAGE_EROFS_UTILS if BR2_x86_64
	select BR2_PACKAGE_EROFS_UTILS_LZ4 if BR2_x86_64
	select BR2_PACKAGE_P7ZIP if BR2_x86_64
	select BR2_PACKAGE_SQLITE if BR2_x86_64
	select BR2_PACKAGE_XTERM if BR2_x86_64
	select BR2_PACKAGE_LIBCURL if BR2_x86_64
	select BR2_PACKAGE_LIBCURL_CURL if BR2_x86_64
	select BR2_PACKAGE_LIBCURL_FORCE_TLS if BR2_x86_64
	select BR2_PACKAGE_OPENSSL if BR2_x86_64
	select BR2_PACKAGE_LIBCURL_OPENSSL if BR2_x86_64
	help
	  Waydroid Android container userspace.

	  https://github.com/waydroid/waydroid

comment "waydroid needs Batocera Wayland, python3, MMU and threads"
	depends on !BR2_PACKAGE_BATOCERA_WAYLAND || !BR2_PACKAGE_PYTHON3 || !BR2_USE_MMU || !BR2_TOOLCHAIN_HAS_THREADS
