#!/bin/bash
set -u -o pipefail

TOOLS_LOG="/userdata/system/logs/batocera-waydroid-tools.log"
PROFILE_FILE="/userdata/system/configs/waydroid/image-profile"
WAYDROID_CFG="/var/lib/waydroid/waydroid.cfg"
WAYDROID_IMAGES="/var/lib/waydroid/images"
ARM_TOOL="/usr/bin/batocera-waydroid-arm"
BIOS_ROOT="/userdata/bios/waydroid"
DROP_ROOT="${BIOS_ROOT}/dump_here"
STAGED_ROOT="${BIOS_ROOT}/overlay"
OFFICIAL_FILENAME="chromeos_16238.47.0_zork_recovery_stable-channel_ZorkMPKeys-v12.bin.zip"
OFFICIAL_URL="https://dl.google.com/dl/edgedl/chromeos/recovery/${OFFICIAL_FILENAME}"

mkdir -p /userdata/system/logs "${DROP_ROOT}" "$(dirname "${PROFILE_FILE}")"

clear_screen() {
    clear >/dev/null 2>&1 || true
}

msg_box() {
    dialog --clear --backtitle "Batocera Waydroid Tools" \
        --msgbox "$1" 18 92 2>&1 >/dev/tty
    clear_screen
}

yes_no() {
    dialog --clear --backtitle "Batocera Waydroid Tools" \
        --yesno "$1" 18 92 2>&1 >/dev/tty
    local rc=$?
    clear_screen
    return "${rc}"
}

show_text_file() {
    local title="$1" file="$2"
    dialog --clear --backtitle "Batocera Waydroid Tools" \
        --title "${title}" --textbox "${file}" 24 104 2>&1 >/dev/tty
    clear_screen
}

require_tools() {
    local missing=() command_name

    [ "$(id -u)" -eq 0 ] || {
        echo "batocera-waydroid-tools must run as root." >&2
        exit 1
    }
    for command_name in dialog xterm waydroid "${ARM_TOOL}"; do
        if [[ "${command_name}" = /* ]]; then
            [ -x "${command_name}" ] || missing+=("${command_name}")
        else
            command -v "${command_name}" >/dev/null 2>&1 || missing+=("${command_name}")
        fi
    done
    if [ "${#missing[@]}" -gt 0 ]; then
        echo "Missing required commands: ${missing[*]}" >&2
        exit 1
    fi
    if ! [ -t 0 ] && ! [ -t 1 ] && ! [ -t 2 ]; then
        echo "batocera-waydroid-tools requires an interactive terminal." >&2
        exit 1
    fi
}

read_profile() {
    local profile="standard-gapps"

    if [ -f "${PROFILE_FILE}" ]; then
        profile="$(tr -d '\r\n' < "${PROFILE_FILE}")"
    fi
    case "${profile}" in
        standard-gapps|standard-vanilla|android-tv-gapps|android-tv-vanilla)
            printf '%s\n' "${profile}"
            ;;
        *)
            printf 'standard-gapps\n'
            ;;
    esac
}

profile_label() {
    case "$1" in
        standard-gapps) printf 'Standard Android with Google apps (default)\n' ;;
        standard-vanilla) printf 'Standard Android without Google apps\n' ;;
        android-tv-gapps) printf 'Android TV with Google apps\n' ;;
        android-tv-vanilla) printf 'Android TV without Google apps\n' ;;
    esac
}

write_profile() {
    local profile="$1" temporary="${PROFILE_FILE}.tmp.$$"

    printf '%s\n' "${profile}" > "${temporary}"
    chmod 0644 "${temporary}"
    mv "${temporary}" "${PROFILE_FILE}"
}

run_action() {
    local title="$1"
    shift
    local output rc

    output="$(mktemp)"
    clear_screen
    printf '\n%s\n\n' "${title}"
    "$@" 2>&1 | tee -a "${TOOLS_LOG}" "${output}"
    rc="${PIPESTATUS[0]}"
    printf '\nExit status: %s\n' "${rc}" | tee -a "${TOOLS_LOG}" "${output}"
    show_text_file "${title}" "${output}"
    rm -f "${output}"
    return "${rc}"
}

show_status() {
    local output
    output="$(mktemp)"
    "${ARM_TOOL}" status >"${output}" 2>&1 || true
    show_text_file "Waydroid status" "${output}"
    rm -f "${output}"
}

show_google_id() {
    local output rc
    output="$(mktemp)"
    /usr/bin/waydroid-get-android-id >"${output}" 2>&1
    rc=$?
    show_text_file "Google Play registration ID" "${output}"
    rm -f "${output}"
    return "${rc}"
}

archive_is_available() {
    [ -f "${DROP_ROOT}/${OFFICIAL_FILENAME}" ] ||
        find "${DROP_ROOT}" -maxdepth 1 -type f \
            \( -iname '*.zip' -o -iname '*.bin' \) -print -quit 2>/dev/null |
            grep -q .
}

ensure_waydroid_initialized() {
    if [ -f "${WAYDROID_CFG}" ] &&
       [ -f "${WAYDROID_IMAGES}/system.img" ] &&
       [ -f "${WAYDROID_IMAGES}/vendor.img" ]; then
        return 0
    fi

    yes_no "Waydroid is not initialized yet.\n\nInitialize the selected profile now? This downloads the Android system and vendor images. You can also cancel, launch Waydroid normally once, and return here afterward." ||
        return 1

    run_action "Initialize Waydroid image" /usr/bin/batocera-waydroid-init || {
        msg_box "Waydroid initialization failed. Check:\n\n/userdata/system/logs/waydroid-init.log"
        return 1
    }
}

install_arm_bridge() {
    local profile
    profile="$(read_profile)"

    case "${profile}" in
        android-tv-*)
            msg_box "The selected WayDroid-ATV image is x86_64, but it already supplies ARM-app translation inside the Android system image.\n\nThis applies to both the Google-apps and no-GApps Android TV variants. The exact bridge can change with the image release; Waydroid Tools reports what running Android uses. Do not add the separate Chromebook zork libndk payload because two bridge installations would conflict."
            return 0
            ;;
    esac

    ensure_waydroid_initialized || return 0

    yes_no "Install ARM app translation into this existing Waydroid container?\n\nThe source is the pinned official Google zork recovery image. The extracted libndk payload is proprietary, AMD-only, and is not shipped by Batocera. Waydroid will be stopped, existing overlay files/properties will be backed up, and the result will be validated before activation." ||
        return 0

    if ! archive_is_available && [ ! -f "${STAGED_ROOT}/system/lib64/libndk_translation.so" ]; then
        yes_no "No recovery image is present in:\n\n${DROP_ROOT}\n\nDownload the pinned official Google recovery directly now? The file is about 1.9 GB and extraction temporarily needs about 14 GiB free under /userdata.\n\n${OFFICIAL_URL}" ||
            {
                msg_box "Manual setup:\n\nDownload:\n${OFFICIAL_FILENAME}\n\nfrom Google's URL shown in README.txt, place it in:\n${DROP_ROOT}\n\nthen retry this action."
                return 0
            }
        run_action "Download official Google recovery" "${ARM_TOOL}" download || return 0
    fi

    run_action "Extract, install, and validate ARM translation" "${ARM_TOOL}" install || {
        msg_box "ARM translation was not enabled. The installer either made no live change or rolled back its first-install transaction.\n\nSee:\n/userdata/system/logs/waydroid-arm.log"
        return 0
    }

    if yes_no "ARM translation is installed and validated offline.\n\nTemporary BIN, ROOT-A, and EROFS extraction images were already deleted automatically.\n\nRemove the downloaded recovery archive and redundant BIOS staging copy now? The protected installed payload will remain available for normal Waydroid reconciliation. Reinstalling after a later bridge removal or container reset will require downloading the recovery again."; then
        run_action "Remove downloaded ARM installer files" \
            "${ARM_TOOL}" cleanup-source || {
            msg_box "The installer files were kept because cleanup validation failed.\n\nSee:\n/userdata/system/logs/waydroid-arm.log"
        }
    fi
}

remove_arm_bridge() {
    yes_no "Remove the separately installed ARM translation bridge?\n\nThis restores the saved pre-install Waydroid properties and overlay files. Android apps and their data are not deleted, but installed ARM-only apps will stop launching. Google Play will return to x86/x86_64-compatible apps only." ||
        return 0
    run_action "Remove ARM translation" "${ARM_TOOL}" remove || return 0
}

cleanup_arm_source_files() {
    yes_no "Remove downloaded ARM installer files?\n\nThis deletes recovery ZIP/BIN files in:\n${DROP_ROOT}\n\nand the redundant verified staging copy in:\n${STAGED_ROOT}\n\nIt is allowed only after the installed bridge and protected reconciliation payload validate successfully. Removing the bridge or factory-resetting Waydroid later will require downloading the recovery again." ||
        return 0

    run_action "Remove downloaded ARM installer files" \
        "${ARM_TOOL}" cleanup-source || {
        msg_box "Installer cleanup did not complete. Review the cleanup output and:\n\n/userdata/system/logs/waydroid-arm.log"
    }
}

waydroid_running() {
    local status
    status="$(waydroid status 2>/dev/null || true)"
    printf '%s\n' "${status}" | grep -Eq '^(Session|Container):[[:space:]]*RUNNING'
}

stop_waydroid() {
    local attempt

    timeout 20 waydroid session stop >>"${TOOLS_LOG}" 2>&1 || true
    timeout 20 waydroid container stop >>"${TOOLS_LOG}" 2>&1 || true
    for attempt in $(seq 1 15); do
        waydroid_running || return 0
        sleep 1
    done
    return 1
}

waydroid_mounts_remain() {
    awk '
        $5 ~ "^/var/lib/waydroid(/|$)" ||
        $5 ~ "^/userdata/system/waydroid/var-lib(/|$)" ||
        $5 ~ "^/userdata/system/.local/share/waydroid(/|$)" {
            print
            found = 1
        }
        END { exit !found }
    ' /proc/self/mountinfo
}

reset_container_data() {
    local mounts

    stop_waydroid || {
        msg_box "Waydroid is still running. No data was deleted.\n\nClose Waydroid or reboot, then retry."
        return 1
    }

    mounts="$(waydroid_mounts_remain 2>/dev/null || true)"
    if [ -n "${mounts}" ]; then
        printf '%s\n' "${mounts}" >>"${TOOLS_LOG}"
        msg_box "Waydroid still has mounted filesystems. No data was deleted.\n\nReboot Batocera, do not launch Waydroid, and retry the reset."
        return 1
    fi

    # These are the complete, explicit Batocera-owned Waydroid state roots.
    # The BIOS source/staging area, selected image profile, and logs survive.
    rm -rf -- \
        /userdata/system/waydroid/var-lib \
        /userdata/system/waydroid/etc \
        /userdata/system/waydroid/arm-translation \
        /userdata/system/.local/share/waydroid
    rm -f -- /userdata/system/waydroid/libndk-auto-seed-migrated

    if [ -d /userdata/system/.local/share/applications ]; then
        find /userdata/system/.local/share/applications -maxdepth 1 -type f \
            -name 'waydroid.*.desktop' -delete
    fi

    mkdir -p /userdata/system/waydroid/var-lib /userdata/system/waydroid/etc
    /etc/init.d/S22waydroid-host start >>"${TOOLS_LOG}" 2>&1 || true
    /usr/bin/batocera-waydroid-update >>"${TOOLS_LOG}" 2>&1 || true
    return 0
}

confirm_factory_reset() {
    yes_no "Factory-reset the Waydroid container?\n\nThis permanently deletes every Android app, account, login, setting, and all Android app data. The selected image profile and any recovery file staged under /userdata/bios/waydroid are preserved." ||
        return 1
    yes_no "Final confirmation:\n\nDELETE ALL WAYDROID ANDROID DATA?\n\nThis cannot be undone unless you have a separate backup." ||
        return 1
}

delete_container_menu() {
    confirm_factory_reset || return 0
    if reset_container_data; then
        msg_box "The Waydroid container and Android user data were deleted.\n\nThe next Waydroid launch will download/initialize the currently selected profile:\n\n$(profile_label "$(read_profile)")"
    fi
}

select_image_profile() {
    local current selected initialized=0
    local standard_gapps=off standard_vanilla=off atv_gapps=off atv_vanilla=off

    current="$(read_profile)"
    case "${current}" in
        standard-gapps) standard_gapps=on ;;
        standard-vanilla) standard_vanilla=on ;;
        android-tv-gapps) atv_gapps=on ;;
        android-tv-vanilla) atv_vanilla=on ;;
    esac

    selected="$(
        dialog --stdout --clear --backtitle "Batocera Waydroid Tools" \
            --title "Waydroid image profile" \
            --radiolist "Choose the image used on the next initialization. Both FOSS WayDroid-ATV variants are x86_64 images that supply their own ARM-app translation layer." \
            22 104 10 \
            standard-gapps "Standard Android + Google apps (default)" "${standard_gapps}" \
            standard-vanilla "Standard Android, no Google apps" "${standard_vanilla}" \
            android-tv-gapps "Android TV + Google apps" "${atv_gapps}" \
            android-tv-vanilla "Android TV, no Google apps" "${atv_vanilla}" \
            </dev/tty 2>/dev/tty
    )" || {
        clear_screen
        return 0
    }
    clear_screen

    [ "${selected}" != "${current}" ] || {
        msg_box "That profile is already selected:\n\n$(profile_label "${current}")"
        return 0
    }

    if [ -f "${WAYDROID_CFG}" ] ||
       [ -f "${WAYDROID_IMAGES}/system.img" ] ||
       [ -d /userdata/system/.local/share/waydroid/data ]; then
        initialized=1
    fi

    if [ "${initialized}" -eq 1 ]; then
        yes_no "Changing from:\n\n$(profile_label "${current}")\n\nto:\n\n$(profile_label "${selected}")\n\nrequires a clean container. Every Android app, account, and all Android data will be deleted." ||
            return 0
        yes_no "Final confirmation:\n\nDELETE THE CURRENT WAYDROID CONTAINER AND SWITCH IMAGE PROFILE?" ||
            return 0
        reset_container_data || return 0
    fi

    write_profile "${selected}"
    msg_box "Selected:\n\n$(profile_label "${selected}")\n\nLaunch Waydroid to initialize it. Vanilla profiles have no Google Play registration ID. Both Android TV variants supply their own ARM-app translation layer, so the separate zork libndk installer remains disabled."
}

main_menu() {
    local choice

    while true; do
        choice="$(
            dialog --stdout --clear --backtitle "Batocera Waydroid Tools" \
                --title "Waydroid Tools" \
                --menu "Current profile: $(profile_label "$(read_profile)")\nChoose an action:" \
                23 100 12 \
                1 "Show Google Play registration ID" \
                2 "Install and validate ARM translation" \
                3 "Remove ARM translation" \
                4 "Remove downloaded ARM installer files" \
                5 "Select Standard / Android TV / no-GApps image" \
                6 "Delete Waydroid container (factory reset)" \
                7 "Show provisioning status and instructions" \
                99 "Exit" \
                </dev/tty 2>/dev/tty
        )" || {
            clear_screen
            break
        }
        clear_screen

        case "${choice}" in
            1) show_google_id || true ;;
            2) install_arm_bridge ;;
            3) remove_arm_bridge ;;
            4) cleanup_arm_source_files ;;
            5) select_image_profile ;;
            6) delete_container_menu ;;
            7) show_status ;;
            99) break ;;
        esac
    done
}

require_tools
main_menu
