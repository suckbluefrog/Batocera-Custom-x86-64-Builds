#!/bin/bash
set -euo pipefail

log="/userdata/system/logs/steam-desktop-switch.log"
mkdir -p "$(dirname "${log}")"
steam_session_pattern='(^|/)batocera-steam-session([[:space:]]|$)'
es_service="/etc/init.d/S31emulationstation"
ALLY_HOTKEY_DIR="/userdata/system/configs/hotkeygen"
ALLY_ACTIVE_MAP="${ALLY_HOTKEY_DIR}/ASUS_ROG_Ally_Config-b05-1abe.mapping"
ALLY_COMMON_CONTEXT="${ALLY_HOTKEY_DIR}/common_context.ally.conf"
ALLY_SYSTEM_DIR="/usr/share/batocera/services/allyhotkeys.d"
ALLY_ES_MAP="${ALLY_SYSTEM_DIR}/ASUS_ROG_Ally_Config-b05-1abe.mapping.es"
ALLY_DEFAULT_MAP="${ALLY_SYSTEM_DIR}/ASUS_ROG_Ally_Config-b05-1abe.mapping"

echo "[$(date +%F\ %T)] desktop-launcher: process start" >> "${log}"

close_inherited_frontend_lock() {
    { exec 9>&-; } 2>/dev/null || true
}

close_inherited_frontend_lock

steam_stack_alive() {
    pgrep -x batocera-steam >/dev/null 2>&1 || \
    pgrep -f "${steam_session_pattern}" >/dev/null 2>&1 || \
    pgrep -x steam >/dev/null 2>&1 || \
    pgrep -x steamwebhelper >/dev/null 2>&1 || \
    pgrep -x gamescope >/dev/null 2>&1 || \
    pgrep -x gamescopereaper >/dev/null 2>&1 || \
    pgrep -x gamescopestream >/dev/null 2>&1 || \
    pgrep -x gamescopectl >/dev/null 2>&1 || \
    pgrep -f '/userdata/system/homebrew/services/PluginLoader' >/dev/null 2>&1 || \
    pgrep -f '/userdata/system/steam/steam.sh|/usr/share/steam/bin_steam.sh|emulatorlauncher.*-system steam|SteamOS Mode\.steam|Steam GamepadUI\.steam|Steam Desktop\.steam' >/dev/null 2>&1
}

hotkeygen_permanent_running() {
    pgrep -f '(^|[[:space:]])(/usr/bin/)?hotkeygen([[:space:]].*)?--permanent([[:space:]]|$)' >/dev/null 2>&1
}

allyhotkeys_enabled() {
    [ -f "${ALLY_COMMON_CONTEXT}" ]
}

recover_hotkeys_force() {
    local src

    if allyhotkeys_enabled; then
        mkdir -p "${ALLY_HOTKEY_DIR}" 2>/dev/null || true
        for src in "${ALLY_ES_MAP}" "${ALLY_DEFAULT_MAP}"; do
            if [ -f "${src}" ]; then
                cp -f "${src}" "${ALLY_ACTIVE_MAP}" 2>/dev/null || true
                break
            fi
        done
    fi

    if command -v hotkeygen >/dev/null 2>&1; then
        if ! hotkeygen_permanent_running && [ -x /etc/init.d/S90hotkeygen ]; then
            /etc/init.d/S90hotkeygen start >/dev/null 2>&1 || true
        fi
        /usr/bin/hotkeygen --default-context >/dev/null 2>&1 || true
        /usr/bin/hotkeygen --reload >/dev/null 2>&1 || true
    fi
}

wait_for_stack_exit() {
    local max_tries="${1:-100}"
    local i
    for i in $(seq 1 "${max_tries}"); do
        if ! steam_stack_alive; then
            return 0
        fi
        sleep 0.2
    done
    return 1
}

wait_for_desktop_steam() {
    local max_tries="${1:-30}"
    local i
    for i in $(seq 1 "${max_tries}"); do
        if pgrep -x steam >/dev/null 2>&1 || pgrep -x steamwebhelper >/dev/null 2>&1; then
            return 0
        fi
        sleep 0.2
    done
    return 1
}

frontend_ready() {
    pgrep -x emulationstation >/dev/null 2>&1 || \
    pgrep -f '(^|/)emulationstation-standalone([[:space:]]|$)' >/dev/null 2>&1 || \
    pgrep -x labwc >/dev/null 2>&1 || \
    pgrep -x sway >/dev/null 2>&1 || \
    pgrep -x openbox >/dev/null 2>&1
}

emulationstation_ready() {
    pgrep -x emulationstation >/dev/null 2>&1 || \
    pgrep -f '(^|/)emulationstation-standalone([[:space:]]|$)' >/dev/null 2>&1 || \
    pgrep -x labwc >/dev/null 2>&1 || \
    pgrep -x sway >/dev/null 2>&1
}

xorg_frontend_running() {
    pgrep -x X >/dev/null 2>&1 || \
    pgrep -x Xorg >/dev/null 2>&1 || \
    pgrep -x xinit >/dev/null 2>&1 || \
    pgrep -x startx >/dev/null 2>&1
}

clear_stale_xorg_locks() {
    if xorg_frontend_running; then
        return 0
    fi

    rm -f /tmp/.X[0-9]*-lock /tmp/.X11-unix/X[0-9]* 2>/dev/null || true
}

clear_stale_frontend_locks() {
    if frontend_ready || xorg_frontend_running; then
        return 0
    fi

    rm -f /run/emulationstation-standalone.lock /var/run/emulationstation-standalone.lock 2>/dev/null || true
}

stop_stale_xorg_frontend() {
    local i

    echo "[$(date +%F\ %T)] desktop-launcher: stopping stale Xorg frontend before desktop handoff" >> "${log}"
    pkill -TERM -x openbox >/dev/null 2>&1 || true
    pkill -TERM -x xinit >/dev/null 2>&1 || true
    pkill -TERM -x startx >/dev/null 2>&1 || true
    pkill -TERM -x X >/dev/null 2>&1 || true
    pkill -TERM -x Xorg >/dev/null 2>&1 || true

    for i in $(seq 1 30); do
        if ! xorg_frontend_running; then
            clear_stale_xorg_locks
            return 0
        fi
        sleep 0.1
    done

    pkill -KILL -x openbox >/dev/null 2>&1 || true
    pkill -KILL -x xinit >/dev/null 2>&1 || true
    pkill -KILL -x startx >/dev/null 2>&1 || true
    pkill -KILL -x X >/dev/null 2>&1 || true
    pkill -KILL -x Xorg >/dev/null 2>&1 || true
    clear_stale_xorg_locks
    clear_stale_frontend_locks
}

wait_for_frontend_ready() {
    local max_tries="${1:-80}"
    local i

    for i in $(seq 1 "${max_tries}"); do
        if frontend_ready; then
            return 0
        fi
        sleep 0.25
    done

    return 1
}

ensure_frontend_ready_for_desktop() {
    if wait_for_frontend_ready 80; then
        echo "[$(date +%F\ %T)] desktop-launcher: frontend ready for desktop steam" >> "${log}"
        return 0
    fi

    if xorg_frontend_running; then
        stop_stale_xorg_frontend
    fi
    clear_stale_frontend_locks

    if [[ -x "${es_service}" ]]; then
        echo "[$(date +%F\ %T)] desktop-launcher: starting frontend before desktop steam" >> "${log}"
        "${es_service}" start >/dev/null 2>&1 || "${es_service}" restart >/dev/null 2>&1 || true
        if wait_for_frontend_ready 80; then
            echo "[$(date +%F\ %T)] desktop-launcher: frontend ready after start" >> "${log}"
            return 0
        fi
    fi

    echo "[$(date +%F\ %T)] desktop-launcher: frontend not ready before desktop steam" >> "${log}"
    return 1
}

restore_frontend() {
    local i

    if emulationstation_ready; then
        echo "[$(date +%F\ %T)] desktop-launcher: frontend already running after desktop steam exit" >> "${log}"
        return 0
    fi

    if [[ -x "${es_service}" ]]; then
        echo "[$(date +%F\ %T)] desktop-launcher: starting EmulationStation after desktop steam exit" >> "${log}"
        "${es_service}" restart >/dev/null 2>&1 || "${es_service}" start >/dev/null 2>&1 || true
        for i in $(seq 1 30); do
            if emulationstation_ready; then
                return 0
            fi
            sleep 0.2
        done

        echo "[$(date +%F\ %T)] desktop-launcher: frontend did not return after restart/start" >> "${log}"
    fi
}

launch_desktop_steam_supervised() {
    BATOCERA_STEAM_MODE=desktop \
    BATOCERA_STEAM_GAMEPADUI=0 \
    BATOCERA_STEAM_USE_GAMESCOPE=0 \
    /usr/bin/batocera-steam >> "${log}" 2>&1 &

    if ! wait_for_desktop_steam 30; then
        echo "[$(date +%F\ %T)] desktop-launcher: desktop steam launch did not come up" >> "${log}"
        return 1
    fi

    echo "[$(date +%F\ %T)] desktop-launcher: desktop steam is running" >> "${log}"
    if ! wait_for_stack_exit 432000; then
        echo "[$(date +%F\ %T)] desktop-launcher: timed out waiting for desktop steam to exit" >> "${log}"
        return 1
    fi

    echo "[$(date +%F\ %T)] desktop-launcher: desktop steam exited" >> "${log}"
    return 0
}

if ! wait_for_stack_exit 100; then
    echo "[$(date +%F\ %T)] desktop-launcher: timed out waiting for steam stack to exit" >> "${log}"
fi

sleep 0.5
if ! ensure_frontend_ready_for_desktop; then
    recover_hotkeys_force
    exit 1
fi

echo "[$(date +%F\ %T)] desktop-launcher: launching desktop steam" >> "${log}"

if ! launch_desktop_steam_supervised; then
    echo "[$(date +%F\ %T)] desktop-launcher: failed to launch desktop steam after retries" >> "${log}"
    recover_hotkeys_force
    exit 1
fi

recover_hotkeys_force
sleep 0.6
recover_hotkeys_force
sleep 2
restore_frontend
echo "[$(date +%F\ %T)] desktop-launcher: done" >> "${log}"
