config BR2_PACKAGE_BATOCERA_UBUNTU_PLASMA_LXC
	bool "batocera-ubuntu-plasma-lxc"
	depends on BR2_x86_64
	depends on BR2_USE_MMU
	depends on BR2_TOOLCHAIN_HAS_THREADS
	depends on !BR2_STATIC_LIBS
	depends on BR2_TOOLCHAIN_GCC_AT_LEAST_4_7
	depends on BR2_TOOLCHAIN_HEADERS_AT_LEAST_3_0
	depends on !BR2_TOOLCHAIN_USES_UCLIBC
	select BR2_PACKAGE_BASH
	select BR2_PACKAGE_DIALOG
	select BR2_PACKAGE_DNSMASQ
	select BR2_PACKAGE_IPTABLES
	select BR2_PACKAGE_LIBCURL
	select BR2_PACKAGE_LIBCURL_CURL
	select BR2_PACKAGE_LXC
	select BR2_PACKAGE_SQUASHFS
	select BR2_PACKAGE_XTERM
	help
	  Ubuntu 26.04 LTS KDE Plasma desktop launcher using LXC with direct
	  KWin DRM rendering. The amd64 rootfs is downloaded and extracted
	  under /userdata on first launch and is not packaged into the image.
