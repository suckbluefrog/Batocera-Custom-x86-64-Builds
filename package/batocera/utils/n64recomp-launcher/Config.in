config BR2_PACKAGE_N64RECOMP_LAUNCHER
	bool "n64recomp-launcher"
	depends on BR2_x86_64
	depends on BR2_TOOLCHAIN_USES_GLIBC
	depends on BR2_INSTALL_LIBSTDCPP
	depends on !BR2_STATIC_LIBS
	select BR2_PACKAGE_SDL2
	help
	  N64 Recomp Launcher packaged as a writable Batocera app.

	  The upstream launcher manages the dynamic recomp catalog, downloads,
	  ROM selection, settings, mods, and game updates. Batocera provides a
	  stable launcher entry and imports the launcher's generated desktop
	  shortcuts into EmulationStation.

comment "n64recomp-launcher needs an x86_64 glibc toolchain with libstdc++"
	depends on !BR2_x86_64 || !BR2_TOOLCHAIN_USES_GLIBC || !BR2_INSTALL_LIBSTDCPP || BR2_STATIC_LIBS
