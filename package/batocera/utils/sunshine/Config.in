config BR2_PACKAGE_SUNSHINE
	bool "sunshine"
	depends on BR2_x86_64
	depends on BR2_INSTALL_LIBSTDCPP
	depends on BR2_TOOLCHAIN_HAS_THREADS_NPTL
	depends on BR2_USE_MMU
	depends on BR2_PACKAGE_HAS_LIBGBM
	select BR2_PACKAGE_BOOST
	select BR2_PACKAGE_BOOST_FILESYSTEM
	select BR2_PACKAGE_BOOST_LOCALE
	select BR2_PACKAGE_BOOST_LOG
	select BR2_PACKAGE_BOOST_PROGRAM_OPTIONS
	select BR2_PACKAGE_BOOST_SYSTEM
	select BR2_PACKAGE_FFMPEG
	select BR2_PACKAGE_FFMPEG_GPL
	select BR2_PACKAGE_FFMPEG_SWSCALE
	select BR2_PACKAGE_GLSLANG
	select BR2_PACKAGE_HOST_GLSLANG
	select BR2_PACKAGE_HOST_NODEJS
	select BR2_PACKAGE_JSON_FOR_MODERN_CPP
	select BR2_PACKAGE_LIBCAP
	select BR2_PACKAGE_LIBCURL
	select BR2_PACKAGE_LIBDRM
	select BR2_PACKAGE_LIBEVDEV
	select BR2_PACKAGE_LIBVA
	select BR2_PACKAGE_LIBMINIUPNPC
	select BR2_PACKAGE_NUMACTL
	select BR2_PACKAGE_OPENSSL
	select BR2_PACKAGE_OPUS
	select BR2_PACKAGE_PIPEWIRE
	select BR2_PACKAGE_PULSEAUDIO
	select BR2_PACKAGE_VULKAN_HEADERS
	select BR2_PACKAGE_VULKAN_LOADER
	select BR2_PACKAGE_WAYLAND
	select BR2_PACKAGE_WAYLAND_PROTOCOLS
	select BR2_PACKAGE_XDG_DESKTOP_PORTAL
	select BR2_PACKAGE_XDG_DESKTOP_PORTAL_WLR
	help
	  Sunshine game-streaming host built from source.

comment "sunshine needs an x86_64 target with C++, NPTL, MMU, and libgbm"
	depends on !BR2_x86_64 || !BR2_INSTALL_LIBSTDCPP || !BR2_TOOLCHAIN_HAS_THREADS_NPTL || !BR2_USE_MMU || !BR2_PACKAGE_HAS_LIBGBM
