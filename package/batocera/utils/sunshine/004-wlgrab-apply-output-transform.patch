+  static bool transform_rotates_90(std::int32_t transform) {
+    switch (transform) {
+      case WL_OUTPUT_TRANSFORM_90:
+      case WL_OUTPUT_TRANSFORM_270:
+      case WL_OUTPUT_TRANSFORM_FLIPPED_90:
+      case WL_OUTPUT_TRANSFORM_FLIPPED_270:
+        return true;
+      default:
+        return false;
+    }
+  }
+
+  static void rotate_bgra_from_output_transform(const std::uint8_t *src, std::uint8_t *dst, int src_width, int src_height, int dst_pitch, std::int32_t transform) {
+    constexpr int pixel_pitch = 4;
+
+    for (int y = 0; y < src_height; ++y) {
+      for (int x = 0; x < src_width; ++x) {
+        int dst_x = src_height - 1 - y;
+        int dst_y = x;
+
+        if (transform == WL_OUTPUT_TRANSFORM_270 || transform == WL_OUTPUT_TRANSFORM_FLIPPED_270) {
+          dst_x = y;
+          dst_y = src_width - 1 - x;
+        }
+
+        std::memcpy(dst + dst_y * dst_pitch + dst_x * pixel_pitch, src + (y * src_width + x) * pixel_pitch, pixel_pitch);
+      }
+    }
+  }
