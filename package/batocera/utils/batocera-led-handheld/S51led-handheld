#!/bin/bash
#
# Starts LED driver for handheld devices
#

# Exit if not in the list of supported devices
SUPPBOARD=$(python3 /usr/lib/python*/batoled.py)
[[ "$SUPPBOARD" == "Unsupported" ]] && exit
# Exit if system.led-handheld=0 in batocera.conf
OPT=$(batocera-settings-get system.led-handheld)
[[ "$OPT" == 0 ]] && exit
PROCESS="/usr/bin/batocera-led-handheld"
PID="/var/run/led-handheld.pid"
HOOK_DIR="/var/run/emulationstation/scripts/achievements"
HOOK_TARGET="/usr/share/batocera-led-handheld/scripts/achievements.sh"
HOOK_LINK="${HOOK_DIR}/batocera-led-handheld.sh"

register_hook() {
	mkdir -p "${HOOK_DIR}"
	ln -sf "${HOOK_TARGET}" "${HOOK_LINK}"
}

unregister_hook() {
	rm -f "${HOOK_LINK}"
}

kill_daemons() {
	if [ -f "$PID" ]; then
		start-stop-daemon -K -q -p "$PID" --retry 3 >/dev/null 2>&1 || true
		rm -f "$PID"
	fi
	# start-stop-daemon can leave stale Python instances behind if the script
	# changed while running. Always make start idempotent.
	pkill -f "[p]ython3 /usr/bin/batocera-led-handheld start" >/dev/null 2>&1 || true
	pkill -f "[/]usr/bin/batocera-led-handheld start" >/dev/null 2>&1 || true
	pkill -f "batocera-led-handheld[.]py start" >/dev/null 2>&1 || true
}

start() {
	printf "Starting LED handheld daemon: "
	register_hook
	kill_daemons
	start-stop-daemon -S -q -b -m -p "$PID" --exec "$PROCESS" -- start
	[ $? = 0 ] && echo "OK" || echo "FAIL"
}

stop() {
	printf "Stopping LED handheld daemon: "
	kill_daemons
	unregister_hook
	echo "OK"
	/usr/bin/batocera-led-handheld stop
}
restart() {
	stop
	start
}

case "$1" in
  start)
  	start
	;;
  stop)
  	stop
	;;
  restart|reload)
  	restart
	;;
  *)
	echo "Usage: $0 {start|stop|restart}"
	exit 1
esac

exit $?
