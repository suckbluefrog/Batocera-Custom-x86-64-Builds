flash_msg() {
    local seconds="$1"
    local message="$2"
    local size="${3:-22}"

    if command -v batocera-flash-screen >/dev/null 2>&1; then
        /usr/bin/batocera-flash-screen "${seconds}" "#ffffff" "${message}" "${size}" >/dev/null 2>&1 || true
    fi
}

is_uint() {
    [[ "${1}" =~ ^[0-9]+$ ]]
}

is_resolution() {
    [[ "${1}" =~ ^[0-9]+x[0-9]+$ ]]
}

append_wine_dll_override() {
    local override="$1"

    [[ -z "${override}" ]] && return 0
    if [[ -n "${WINEDLLOVERRIDES:-}" ]]; then
        export WINEDLLOVERRIDES="${WINEDLLOVERRIDES};${override}"
    else
        export WINEDLLOVERRIDES="${override}"
    fi
}


append_colon_env() {
    local name="$1"
    local value="$2"
    local current="${!name:-}"
    local -a items
    local existing

    [[ -z "${value}" ]] && return 0
    IFS=":" read -ra items <<< "${current}"
    for existing in "${items[@]}"; do
        [[ "${existing}" == "${value}" ]] && return 0
    done

    if [[ -n "${current}" ]]; then
        export "${name}=${value}:${current}"
    else
        export "${name}=${value}"
    fi
}

resolve_lsfg_vk_dll() {
    local configured="$1"
    local candidate
    local -a candidates=()

    if [[ -n "${configured}" ]]; then
        if [[ "${configured}" == "~/"* ]]; then
            candidates+=("/userdata/system/${configured#~/}")
        else
            candidates+=("${configured}")
        fi
    fi

    candidates+=(
        "/userdata/system/wine/lossless-scaling/Lossless.dll"
        "/userdata/system/wine/.local/share/Steam/steamapps/common/Lossless Scaling/Lossless.dll"
        "/userdata/system/.local/share/Steam/steamapps/common/Lossless Scaling/Lossless.dll"
        "/userdata/roms/windows/Lossless Scaling/Lossless.dll"
    )

    for candidate in "${candidates[@]}"; do
        [[ -f "${candidate}" ]] && { echo "${candidate}"; return 0; }
    done

    return 1
}

enable_lsfg_vk() {
    local lsfg_root="/usr/wine/lsfg-vk/x64"
    local lsfg_layer_dir="${lsfg_root}/share/vulkan/explicit_layer.d"
    local lsfg_library="${lsfg_root}/lib/liblsfg-vk.so"
    local dll_path

    [[ "${LSFG_VK}" =~ ^(1|true|on|enabled)$ ]] || return 0

    if [[ ! -f "${lsfg_library}" || ! -d "${lsfg_layer_dir}" ]]; then
        flash_msg 4 "LSFG-VK is enabled but the Vulkan layer is not installed"
        echo "LSFG-VK requested but ${lsfg_library} is missing"
        return 0
    fi

    if ! dll_path="$(resolve_lsfg_vk_dll "${LSFG_VK_DLL}")"; then
        flash_msg 5 "LSFG-VK needs Lossless.dll in /userdata/system/wine/lossless-scaling"
        echo "LSFG-VK requested but Lossless.dll was not found"
        return 0
    fi

    [[ -z "${LSFG_VK_MULTIPLIER}" ]] && LSFG_VK_MULTIPLIER=2
    [[ -z "${LSFG_VK_FLOW_SCALE}" ]] && LSFG_VK_FLOW_SCALE=1.0

    export ENABLE_LSFG=1
    export LSFG_LEGACY=1
    export LSFG_DLL_PATH="${dll_path}"
    export LSFG_MULTIPLIER="${LSFG_VK_MULTIPLIER}"
    export LSFG_FLOW_SCALE="${LSFG_VK_FLOW_SCALE}"
    export LSFG_PERFORMANCE_MODE=0
    export LSFG_HDR_MODE=0
    [[ "${LSFG_VK_PERFORMANCE}" =~ ^(1|true|on|enabled)$ ]] && LSFG_PERFORMANCE_MODE=1
    [[ "${LSFG_VK_HDR}" =~ ^(1|true|on|enabled)$ ]] && LSFG_HDR_MODE=1

    case "${LSFG_VK_PRESENT_MODE}" in
        fifo|vsync|mailbox|immediate)
            export LSFG_EXPERIMENTAL_PRESENT_MODE="${LSFG_VK_PRESENT_MODE}"
            ;;
    esac

    append_colon_env VK_LAYER_PATH "${lsfg_layer_dir}"
    append_colon_env LD_LIBRARY_PATH "${lsfg_root}/lib"
    append_colon_env VK_INSTANCE_LAYERS "VK_LAYER_LS_frame_generation"
    echo "LSFG-VK enabled using ${dll_path}"
}

ensure_winetricks() {
    if [[ -e "${WINETRICKS}" ]]; then
        echo "Winetricks is installed"
        return 0
    fi

    echo "Winetricks is downloading"
    mkdir -p "$(dirname "${WINETRICKS}")" || return 1
    wget -O "${WINETRICKS}" "https://raw.githubusercontent.com/Winetricks/winetricks/master/src/winetricks" &>/dev/null || return 1
    chmod +x "${WINETRICKS}" || return 1
    echo "Winetricks is now installed"
}

stopWineServer() {
    [[ -z "${WINESERVER}" || -z "${WINEPOINT}" ]] && exit 0

    #try to cleanly exit wineserver
    WINEPREFIX=${WINEPOINT} "${WINESERVER}" -k &
    #wait 10s for clean exit
    echo "${FUNCNAME[0]}: waiting wineserver shutdown" >&2
    if waitWineServer 10; then
        echo "${FUNCNAME[0]}: wineserver has cleanly exited" >&2
        return 0
    fi

    #kill all process with wineprefix as envvar if wineserver is still not stopped
    declare -a PIDS

    # find all process with wineprefix environement
    for PID in $(ps -e -o pid=); do
        if grep -z "WINEPREFIX=${WINEPOINT}" "/proc/$PID/environ" 2>/dev/null; then
            PIDS+=("$PID")
        fi
    done

    # kill all pids
    if [ ${#PIDS[@]} -gt 0 ]; then
        echo "${FUNCNAME[0]}: Killing stuck wine processes: ${PIDS[*]}"
        kill -9 "${PIDS[@]}"
    fi
    return 1
}

# Arguments: key, system, game
get_setting() {
    /usr/bin/batocera-settings-get "$2[\"$3\"].$1" "$2.$1" "global.$1"
}

find_wine_dir() {
    local WINE_VERSION="$1"
    # check if we're using a custom wine runner
    if [[ ! "$WINE_VERSION" =~ ^(wine-(tkg|proton)|proton-ge)$ ]]; then
        # now check if the folder exists
        if [[ -e "/userdata/system/wine/custom/${WINE_VERSION}" ]]; then
            echo "/userdata/system/wine/custom"
        else
            WINE_VERSION="wine-tkg"
            if [[ -e "/usr/wine/${WINE_VERSION}" ]]; then
                echo "/usr/wine"
            else
                return 1
            fi
        fi
    elif [[ -e "/usr/wine/${WINE_VERSION}" ]]; then
        echo "/usr/wine"
    else
        return 1
    fi
}

update_wine_version() {
    local WINE_VERSION="$1"
    if [[ ! "$WINE_VERSION" =~ ^(wine-(tkg|proton)|proton-ge)$ ]]; then
        if [[ -e "/userdata/system/wine/custom/${WINE_VERSION}" ]]; then
            echo "$WINE_VERSION"
        else
            WINE_VERSION="wine-tkg"
            echo "$WINE_VERSION"
        fi
    else
        echo "$WINE_VERSION"
    fi
}

sanitize_umu_gameid() {
    local raw="$1"
    raw="${raw%.*}"
    raw="${raw##*/}"
    raw=$(printf '%s' "$raw" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9._-]/-/g;s/--*/-/g;s/^-//;s/-$//')
    [[ -z "${raw}" ]] && raw="batocera-default"
    printf 'batocera-%s\n' "${raw}"
}

prepare_umu_proton() {
    local source_dir="/usr/wine/proton-ge"
    local compat_root="/userdata/system/wine/.local/share/umu/compatibilitytools"
    local target_dir="${compat_root}/proton-ge"

    [[ -d "${source_dir}" ]] || return 1

    mkdir -p "${compat_root}" "${target_dir}"

    if ! mountpoint -q "${target_dir}" 2>/dev/null; then
        mount --bind "${source_dir}" "${target_dir}" 2>/dev/null || return 1
    fi

    printf '%s\n' "${target_dir}"
}

play_with_umu() {
    local workdir="$1"
    local cmd="$2"
    local lang="$3"
    local extra_env="$4"
    local prefix="$5"
    local gameid

    gameid="$(sanitize_umu_gameid "${ROMGAMENAME}")"

    mkdir -p /userdata/system/wine/.local/share /userdata/system/cache

    if [[ -n "${lang}" ]]; then
        (
            cd "${workdir}" && \
            LC_ALL="${lang}" \
            HOME=/userdata/system/wine \
            XDG_DATA_HOME=/userdata/system/wine/.local/share \
            XDG_CACHE_HOME=/userdata/system/cache \
            XDG_CONFIG_HOME=/userdata/system/configs \
            WINEPREFIX="${prefix}" \
            STEAM_COMPAT_DATA_PATH="${prefix}" \
            PROTONPATH="${UMU_PROTONPATH}" \
            GAMEID="${gameid}" \
            STORE=none \
            UMU_RUNTIME_UPDATE="${UMU_RUNTIME_UPDATE_VALUE}" \
            eval "${extra_env}" ${CMD_PREFIX} umu-run ${cmd}
        )
    else
        (
            cd "${workdir}" && \
            HOME=/userdata/system/wine \
            XDG_DATA_HOME=/userdata/system/wine/.local/share \
            XDG_CACHE_HOME=/userdata/system/cache \
            XDG_CONFIG_HOME=/userdata/system/configs \
            WINEPREFIX="${prefix}" \
            STEAM_COMPAT_DATA_PATH="${prefix}" \
            PROTONPATH="${UMU_PROTONPATH}" \
            GAMEID="${gameid}" \
            STORE=none \
            UMU_RUNTIME_UPDATE="${UMU_RUNTIME_UPDATE_VALUE}" \
            eval "${extra_env}" ${CMD_PREFIX} umu-run ${cmd}
        )
    fi
}

is_box86_compatible_runner() {
    # Parameter 1 = runner name
    local runner="$1"
    local dir
    local wine_bin
    local wineserver_bin

    dir="$(find_wine_dir "${runner}")" || return 1

    # Strict box86 compatibility:
    # require ELF32 wine + wineserver pair (not just wrapper scripts or wow64 stubs).
    for wine_bin in \
        "${dir}/${runner}/lib/wine/i386-unix/wine" \
        "${dir}/${runner}/lib32/wine/wine" \
        "${dir}/${runner}/bin/wine32" \
        "${dir}/${runner}/bin/wine"; do
        [[ -e "${wine_bin}" ]] || continue
        if file -Lb "$(readlink -f "${wine_bin}" 2>/dev/null || echo "${wine_bin}")" 2>/dev/null | grep -q "ELF 32-bit"; then
            break
        fi
        wine_bin=""
    done

    [[ -n "${wine_bin}" ]] || return 1

    for wineserver_bin in \
        "${dir}/${runner}/lib/wine/i386-unix/wineserver" \
        "${dir}/${runner}/lib32/wine/wineserver" \
        "${dir}/${runner}/bin/wineserver" \
        "${dir}/${runner}/lib/wine/wineserver"; do
        [[ -e "${wineserver_bin}" ]] || continue
        if file -Lb "$(readlink -f "${wineserver_bin}" 2>/dev/null || echo "${wineserver_bin}")" 2>/dev/null | grep -q "ELF 32-bit"; then
            return 0
        fi
    done

    return 1
}

is_wow64_compatible_runner() {
    # Parameter 1 = runner name
    local runner="$1"
    local dir

    dir="$(find_wine_dir "${runner}")" || return 1

    ([[ -e "${dir}/${runner}/lib/wine/x86_64-unix/wine64" ]] || [[ -e "${dir}/${runner}/bin/wine64" ]]) && \
    ([[ -e "${dir}/${runner}/bin/wineserver" ]] || [[ -e "${dir}/${runner}/lib/wine/x86_64-unix/wineserver" ]] || [[ -e "${dir}/${runner}/lib/wine/wineserver" ]])
}

setPrefixArch(){
    # Parameter 1 = current Winepoint
    # Parameter 2 = current WineRunner
    # Parameter 3 = action

    # Set WINEARCH to win32 if term win32 is found in used runner or if it setted as option in ES and if prefix is not already build!
    # Check usedaArch in userdef.reg, and delete syswow64 symlink from prefix if ACTION=tricks - winetricks checks sys dir and will deny to work!

    # get ES-OPTION
    ENABLE_WIN32="$(get_setting enable_win32 "${SYSTEM}" "${ROMGAMENAME}")"
    AARCH64_WINE_MODE="$(get_setting aarch64_wine_mode "${SYSTEM}" "${ROMGAMENAME}")"
    # On aarch64, only force win32 when box86 mode is effectively active.
    # If box86 prerequisites are missing and we fell back to WoW64, never force win32.
    if [[ "$(uname -m)" == "aarch64" ]]; then
        if [[ "${FORCE_BOX86_MODE:-0}" == "1" ]]; then
            [[ "${AARCH64_WINE_MODE}" == "box86" ]] && ENABLE_WIN32=1
        else
            if [[ "${AARCH64_WINE_MODE}" == "box86" ]]; then
                echo "${FUNCNAME[0]}: box86 mode requested but not active; keeping prefix in WoW64/win64 mode"
            fi
            ENABLE_WIN32=0
        fi
    fi

    # check registry settings in PREFIX for current WINE-RUNNER
    local val
    if [[ -e "${1}/userdef.reg" ]]; then
        if val=$(grep -Po '^#arch=\K.*' "${1}/userdef.reg"); then
            echo "${FUNCNAME[0]}: Found arch '${val}' in Prefix-registry-file"
            if [[ $val == win32 && $3 == tricks ]]; then 
                test -d "${1}/drive_c/windows/syswow64" && { rm -r -- "$_"; echo "${FUNCNAME[0]}: removed $_"; }
            elif [[ $val != win32 && ${ENABLE_WIN32} -eq 1 ]]; then
                echo "${FUNCNAME[0]}: Did found '$val' in registry - Prefix can't be set to 32bit!"
            elif [[ $val == win32 ]]; then
                if [[ "$(uname -m)" == "aarch64" && "${FORCE_BOX86_MODE:-0}" != "1" ]]; then
                    echo "${FUNCNAME[0]}: Found win32 prefix but running WoW64 mode; not exporting WINEARCH=win32"
                else
                    export WINEARCH=win32
                fi
            fi
        fi
    else
        # Missing key, perform further checks and perform a fresh install with createWineDirectory()
        if [[ ${ENABLE_WIN32} == 1 && ! -d "${1}" ]]; then
            export WINEARCH=win32; val="ENEABLE WIN32 in ES setted 'win32'"
        elif [[ "${2,,}" =~ ^win32[-_.].*$ && ! -d "${1}" ]]; then 
            export WINEARCH=win32; val="RUNNER carries 'win32' value"
        else
            val=win64
        fi
    fi
    # Safety net: WoW64 on aarch64 must never run with WINEARCH=win32.
    if [[ "$(uname -m)" == "aarch64" && "${FORCE_BOX86_MODE:-0}" != "1" && "${WINEARCH:-}" == "win32" ]]; then
        unset WINEARCH
        val=win64
        echo "${FUNCNAME[0]}: cleared invalid WINEARCH=win32 for WoW64 fallback"
    fi
    echo "${FUNCNAME[0]}: Environment Prefix setted -> $val"
}

waitWineServer() {
    local ret=0
    local ws_match="${WINESERVER_REAL:-${WINESERVER}}"
    local pid

    pid=$(pgrep -o -f "${ws_match}")

    # Wrapper mode fallback: process cmdline may only show wineserver/box64.
    if [[ -z "${pid}" ]]; then
        pid=$(pgrep -o -x "wineserver")
    fi

    # Final fallback: process bound to current WINEPREFIX with wineserver in cmdline.
    if [[ -z "${pid}" ]] && [[ -n "${WINEPOINT}" ]]; then
        local p cmdline
        for p in /proc/[0-9]*; do
            [[ -r "${p}/environ" ]] || continue
            if tr '\0' '\n' < "${p}/environ" 2>/dev/null | grep -qx "WINEPREFIX=${WINEPOINT}"; then
                cmdline="$(tr '\0' ' ' < "${p}/cmdline" 2>/dev/null || true)"
                if [[ "${cmdline}" == *wineserver* ]]; then
                    pid="${p##*/}"
                    break
                fi
            fi
        done
    fi

    [[ -z "${pid}" ]] && { echo "${FUNCNAME[0]}: Called by ${FUNCNAME[1]} no process '${WINESERVER}' found - finished with hotkey?" >&2; return 0; }
    #from: https://unix.stackexchange.com/a/427133
    #timeout will report not 0 if setted value is reached
    echo "${FUNCNAME[0]}: Called by ${FUNCNAME[1]} wait WineServer: [$pid] ${WINESERVER}"
    timeout "$1" tail -q --pid=$pid -f /dev/null
    ret=$?
    echo "${FUNCNAME[0]}: Finished waiting for WineServer [$pid] with errorcode($ret)"
    return $ret
}

cleanupWinePrefixProcesses() {
    local prefix="$1"
    local p pid cmdline
    local -a pids=()

    [[ -z "${prefix}" ]] && return 0

    for p in /proc/[0-9]*; do
        pid="${p##*/}"
        [[ -r "${p}/environ" ]] || continue
        if tr '\0' '\n' < "${p}/environ" 2>/dev/null | grep -qx "WINEPREFIX=${prefix}"; then
            cmdline="$(tr '\0' ' ' < "${p}/cmdline" 2>/dev/null || true)"
            if [[ "${cmdline}" == *wine* || "${cmdline}" == *wineserver* || "${cmdline}" == *box64* || "${cmdline}" == *box86* ]]; then
                pids+=("${pid}")
            fi
        fi
    done

    if [[ ${#pids[@]} -gt 0 ]]; then
        echo "${FUNCNAME[0]}: killing stale wine pids for prefix '${prefix}': ${pids[*]}"
        kill -9 "${pids[@]}" 2>/dev/null || true
    fi
}

wine_options() {
    WINEPOINT=$1
    NTSYNC="$(get_setting ntsync "${SYSTEM}" "${ROMGAMENAME}")"
    WINE_SYNC="$(get_setting wine_sync "${SYSTEM}" "${ROMGAMENAME}")"
    PBA="$(get_setting pba "${SYSTEM}" "${ROMGAMENAME}")"
    FSR="$(get_setting fsr "${SYSTEM}" "${ROMGAMENAME}")"
    FPS_LIMIT="$(get_setting fps_limit "${SYSTEM}" "${ROMGAMENAME}")"
    FPS_LIMIT_CUSTOM="$(get_setting fps_limit_custom "${SYSTEM}" "${ROMGAMENAME}")"
    ALLOW_XIM="$(get_setting allow_xim "${SYSTEM}" "${ROMGAMENAME}")"
    NO_WRITE_WATCH="$(get_setting no_write_watch "${SYSTEM}" "${ROMGAMENAME}")"
    FORCE_LARGE_ADRESS="$(get_setting force_large_adress "${SYSTEM}" "${ROMGAMENAME}")"
    HEAP_DELAY_FREE="$(get_setting heap_delay_free "${SYSTEM}" "${ROMGAMENAME}")"
    HIDE_NVIDIA_GPU="$(get_setting hide_nvidia_gpu "${SYSTEM}" "${ROMGAMENAME}")"
    ENABLE_NVAPI="$(get_setting enable_nvapi "${SYSTEM}" "${ROMGAMENAME}")"
    ENABLE_HIDRAW="$(get_setting enable_hidraw "${SYSTEM}" "${ROMGAMENAME}")"
    DXVK_ASYNC_SETTING="$(get_setting dxvk_async "${SYSTEM}" "${ROMGAMENAME}")"
    WINE_D3D12_BACKEND="$(get_setting wine_d3d12_backend "${SYSTEM}" "${ROMGAMENAME}")"
    DXVK_RESET_CACHE="$(get_setting dxvk_reset_cache "${SYSTEM}" "${ROMGAMENAME}")"
    WINE_NTFS="$(get_setting wine_ntfs "${SYSTEM}" "${ROMGAMENAME}")"
    WINE_DEBUG="$(get_setting wine_debug "${SYSTEM}" "${ROMGAMENAME}")"
    WINE_DLL_OVERRIDES="$(get_setting wine_dll_overrides "${SYSTEM}" "${ROMGAMENAME}")"
    WINE_RUNTIME_INJECTORS="$(get_setting wine_runtime_injectors "${SYSTEM}" "${ROMGAMENAME}")"
    WINE_RUNTIME_INJECTORS_CUSTOM="$(get_setting wine_runtime_injectors_custom "${SYSTEM}" "${ROMGAMENAME}")"
    LSFG_VK="$(get_setting lsfg_vk "${SYSTEM}" "${ROMGAMENAME}")"
    LSFG_VK_DLL="$(get_setting lsfg_vk_dll "${SYSTEM}" "${ROMGAMENAME}")"
    LSFG_VK_MULTIPLIER="$(get_setting lsfg_vk_multiplier "${SYSTEM}" "${ROMGAMENAME}")"
    LSFG_VK_FLOW_SCALE="$(get_setting lsfg_vk_flow_scale "${SYSTEM}" "${ROMGAMENAME}")"
    LSFG_VK_PERFORMANCE="$(get_setting lsfg_vk_performance "${SYSTEM}" "${ROMGAMENAME}")"
    LSFG_VK_HDR="$(get_setting lsfg_vk_hdr "${SYSTEM}" "${ROMGAMENAME}")"
    LSFG_VK_PRESENT_MODE="$(get_setting lsfg_vk_present_mode "${SYSTEM}" "${ROMGAMENAME}")"
    KEYBOARD="$(/usr/bin/batocera-settings-get system.kblayout)"
    VIRTUAL_DESKTOP="$(get_setting virtual_desktop "${SYSTEM}" "${ROMGAMENAME}")"
    VIRTUAL_DESKTOP_SIZE="$(get_setting virtual_desktop_size "${SYSTEM}" "${ROMGAMENAME}")"
    VIRTUAL_DESKTOP_SIZE_CUSTOM="$(get_setting virtual_desktop_size_custom "${SYSTEM}" "${ROMGAMENAME}")"
    WAYLAND_DRIVER="$(get_setting wayland_driver "${SYSTEM}" "${ROMGAMENAME}")"

    [[ -z "${WINE_SYNC}" ]] && { [[ "${NTSYNC}" = "0" ]] && WINE_SYNC="disabled" || WINE_SYNC="auto"; }
    [[ -z "${DXVK_ASYNC_SETTING}" ]] && DXVK_ASYNC_SETTING=1
    [[ -z "${WINE_D3D12_BACKEND}" ]] && WINE_D3D12_BACKEND=auto
    [[ -z "${WINE_DLL_OVERRIDES}" ]] && WINE_DLL_OVERRIDES=none
    [[ -z "${WINE_RUNTIME_INJECTORS}" ]] && WINE_RUNTIME_INJECTORS=none

    safe_setxkbmap() {
        if command -v setxkbmap >/dev/null 2>&1; then
            setxkbmap "${KEYBOARD}"
        else
            echo "*** setxkbmap not found; skipping keyboard layout setup for Wine launcher ***"
        fi
    }

    if [[ "${VIRTUAL_DESKTOP}" = 1 ]]; then
        case "${VIRTUAL_DESKTOP_SIZE}" in
            custom)
                VIRTUAL_DESKTOP_SIZE="${VIRTUAL_DESKTOP_SIZE_CUSTOM}"
                ;;
            "")
                VIRTUAL_DESKTOP_SIZE="$(get_setting videomode "${SYSTEM}" "${ROMGAMENAME}")"
                ;;
        esac
        if ! is_resolution "${VIRTUAL_DESKTOP_SIZE}"; then
            VIRTUAL_DESKTOP_SIZE="$(batocera-resolution currentResolution)"
        fi
        VDESKTOP="explorer /desktop=Wine,${VIRTUAL_DESKTOP_SIZE}"
    else
        VDESKTOP=""
    fi

    # Handle Wayland driver option only if the system is running Wayland
    if [[ "${SYSTEM_DISPLAY_MODE}" == "wayland" ]]; then
        if [[ "${WAYLAND_DRIVER}" != "native" ]]; then
            echo "*** System is Wayland, using XWayland by default or as requested. ***"
            safe_setxkbmap
        else
            CMD_PREFIX="DISPLAY="
            echo "*** System is Wayland and 'native' driver requested. Forcing Wine native Wayland mode. ***"
        fi
    else
        # System is X.org, run as normal
        echo "*** System is X.org. Running in standard X11 mode. ***"
        safe_setxkbmap
    fi

    export WINEFSYNC=0
    export WINEESYNC=0
    case "${WINE_SYNC}" in
        disabled|off|0)
            export WINEDISABLEFASTSYNC=1
            echo "Wine sync disabled"
            ;;
        fsync)
            export WINEDISABLEFASTSYNC=1
            export WINEFSYNC=1
            echo "FSYNC enabled for Wine"
            ;;
        esync)
            export WINEDISABLEFASTSYNC=1
            export WINEESYNC=1
            echo "ESYNC enabled for Wine"
            ;;
        auto|ntsync|1|*)
            if lsmod | grep -q ^ntsync; then
                echo "Ntsync module already loaded"
            else
                echo "Loading ntsync module..."
                modprobe ntsync 2>/dev/null || true
            fi

            if [ -e /dev/ntsync ] && [ -r /dev/ntsync ]; then
                export WINEDISABLEFASTSYNC=0
                echo "NTSYNC enabled for Wine"
            else
                echo "Warning: /dev/ntsync not accessible after module load, disabling ntsync in Wine"
                export WINEDISABLEFASTSYNC=1
            fi
            ;;
    esac

    export PBA_ENABLE=0
    [[ "${PBA}" = 1 ]] && PBA_ENABLE=1

    export DXVK_FRAME_RATE=0
    case "${FPS_LIMIT}" in
        1)
            DXVK_FRAME_RATE=60
            ;;
        custom)
            is_uint "${FPS_LIMIT_CUSTOM}" && DXVK_FRAME_RATE="${FPS_LIMIT_CUSTOM}"
            ;;
        ""|0|off)
            DXVK_FRAME_RATE=0
            ;;
        *)
            is_uint "${FPS_LIMIT}" && DXVK_FRAME_RATE="${FPS_LIMIT}"
            ;;
    esac

    export WINEDEBUG="-all"
    case "${WINE_DEBUG}" in
        err|errors)
            WINEDEBUG="err+all"
            ;;
        fixme)
            WINEDEBUG="err+all,fixme+all"
            ;;
        1|all|verbose)
            WINEDEBUG="err+all,fixme+all"
            ;;
        relay)
            WINEDEBUG="+relay,+seh,+tid"
            ;;
    esac

    export DXVK_LOG_LEVEL=none
    [[ "${WINE_DEBUG}" != "" && "${WINE_DEBUG}" != 0 ]] && unset DXVK_LOG_LEVEL

    export VKD3D_DEBUG=none
    [[ "${WINE_DEBUG}" != "" && "${WINE_DEBUG}" != 0 ]] && unset VKD3D_DEBUG

    export VKD3D_SHADER_CACHE_PATH="/userdata/system/cache"

    export WINE_ENABLE_HIDRAW=0
    [[ "${ENABLE_HIDRAW}" = 1 ]] && WINE_ENABLE_HIDRAW=1

    export WINE_FULLSCREEN_FSR=0
    [[ "${FSR}" = 1 ]] && unset WINE_FULLSCREEN_FSR

    # Wine-mono override for FNA games
    export WINE_MONO_OVERRIDES="Microsoft.Xna.Framework.*,Gac=n"

    # Disable XIM support until libx11 >= 1.7 is widespread
    export WINE_ALLOW_XIM=0
    [[ "${ALLOW_XIM}" = 1 ]] && WINE_ALLOW_XIM=1

    # Advanced options from proton
    export WINE_DISABLE_WRITE_WATCH=0
    [[ "${NO_WRITE_WATCH}" = 1 ]] && WINE_DISABLE_WRITE_WATCH=1

    export WINE_LARGE_ADDRESS_AWARE=0
    [[ "${FORCE_LARGE_ADRESS}" = 1 ]] && WINE_LARGE_ADDRESS_AWARE=1

    export WINE_HEAP_DELAY_FREE=0
    [[ "${HEAP_DELAY_FREE}" = 1 ]] && WINE_HEAP_DELAY_FREE=1

    export WINE_HIDE_NVIDIA_GPU=0
    [[ "${HIDE_NVIDIA_GPU}" = 1 ]] && WINE_HIDE_NVIDIA_GPU=1

    export NVAPI=0
    [[ "${ENABLE_NVAPI}" = 1 ]] && NVAPI=1

    export DXVK_STATE_CACHE=1
    [[ "${DXVK_RESET_CACHE}" = 1 ]] && DXVK_STATE_CACHE=reset

    export NTFS_MODE=0
    [[ "${WINE_NTFS}" = 1 ]] && NTFS_MODE=1

    export STAGING_SHARED_MEMORY=1
    export ULIMIT_SIZE=1048576
    export USE_BUILTIN_VKD3D=0
    [[ "${WINE_D3D12_BACKEND}" == "builtin" ]] && export USE_BUILTIN_VKD3D=1

    # Nvidia variables
    [[ -e "/userdata/system/cache/nvidia" ]] || mkdir -p "/userdata/system/cache/nvidia"
    export XDG_CACHE_HOME="/userdata/system/cache"
    export __GL_SHADER_DISK_CACHE_SIZE=2147483648
    export __GL_SHADER_DISK_CACHE_SKIP_CLEANUP=1
    export __GL_SHADER_DISK_CACHE_PATH="${XDG_CACHE_HOME}"/nvidia

    # While esync is deprecated, the ulimit is still important for Wine performance.
    if ! ulimit -n "${ULIMIT_SIZE}" 2>/dev/null; then
        echo "Warning: could not set file limit, which may impact performance." >&2
    fi

    enable_lsfg_vk
}

redist_install() {
    WINEPREFIX=$1
    local i; local ii
    if [[ -d "${USER_DIR}/exe" ]]; then
        readarray -t i < <(find "${USER_DIR}/exe" -maxdepth 1 -type f -iname "*.exe" -printf "%p\n")
        [[ "${#i[@]}" -eq 0 ]] && { rmdir "${USER_DIR}/exe"; echo "${FUNCNAME[0]}: Place only exe-files to ${USER_DIR}/exe" >&2; return 0; }
        mkdir -p "${USER_DIR}/installed.exe"

        for file in "${i[@]}"; do
            #We compare base-filename in lowercase only and execute the file stored in array
            ii="$(basename "$file")"; ii="${ii,,}"
            echo "Executing file $file"
            case "${ii}" in

            "dxsetup.exe")
                WINEPREFIX=${WINEPOINT} ${CMD_PREFIX} "${WINE}" "${file}" /silent &>/dev/null || return 1
                "${WINESERVER}" -w
            ;;

            "vcredist_x64_2005.exe" | "vcredist_x86_2005.exe" | \
            "vcredist_x64_2008.exe" | "vcredist_x86_2008.exe")
                WINEPREFIX=${WINEPOINT} ${CMD_PREFIX} "${WINE}" "${file}" /q &>/dev/null || return 1
                "${WINESERVER}" -w
            ;;

            "vcredist_x64_2010.exe" | "vcredist_x86_2010.exe" | \
            "vcredist_x64_2012.exe" | "vcredist_x86_2012.exe" | \
            "vcredist_x64_2013.exe" | "vcredist_x86_2013.exe" | \
            "vcredist_x64_2015.exe" | "vcredist_x86_2015.exe" | \
            "vcredist_x64_2017.exe" | "vcredist_x86_2017.exe" | \
            "vcredist_x64_2019.exe" | "vcredist_x86_2019.exe")
                WINEPREFIX=${WINEPOINT} ${CMD_PREFIX} "${WINE}" "${file}" /quiet /qn /norestart &>/dev/null || return 1
                "${WINESERVER}" -w
            ;;

            "vcredist_x64_2015_2019.exe" | "vcredist_x86_2015_2019.exe" | \
            "vcredist_x64_2015_2022.exe" | "vcredist_x86_2015_2022.exe" )
                WINEPREFIX=${WINEPOINT} ${CMD_PREFIX} "${WINE}" "${file}" /quiet /qn /norestart &>/dev/null || return 1
                "${WINESERVER}" -w
            ;;

            "oalinst.exe")
                WINEPREFIX=${WINEPOINT} ${CMD_PREFIX} "${WINE}" "${file}" /s &>/dev/null
                "${WINESERVER}" -w
            ;;

            *)
                WINEPREFIX=${WINEPOINT} ${CMD_PREFIX} "${WINE}" "${file}" &>/dev/null
                "${WINESERVER}" -w
            ;;
            esac
            echo "$(date '+%D %T') - Installed: '$file' --> ${WINEPREFIX}" | tee -a "${USER_DIR}/imports.log"
            mv --backup=t "$file" "${USER_DIR}/installed.exe"
        done
        rmdir "${USER_DIR}/exe" || { echo "${FUNCNAME[0]}: Place only exe-files to ${USER_DIR}/exe" >&2; }
    fi
    return 0
}

