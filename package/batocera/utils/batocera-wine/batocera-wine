runtime_injectors_install() {
    WINEPREFIX=$1
    local runtime="${WINE_RUNTIME_INJECTORS:-none}"
    local verbs_string verb stamp safe_verb
    local -a verbs=()

    [[ "${runtime}" == "none" || "${runtime}" == "0" || -z "${runtime}" ]] && return 0

    if [[ "${runtime}" == "custom" ]]; then
        verbs_string="${WINE_RUNTIME_INJECTORS_CUSTOM}"
    else
        verbs_string="${runtime}"
    fi
    [[ -z "${verbs_string}" ]] && return 0

    verbs_string="${verbs_string//,/ }"
    read -r -a verbs <<< "${verbs_string}"
    [[ "${#verbs[@]}" -eq 0 ]] && return 0

    ensure_winetricks || {
        flash_msg 5 "Could not prepare winetricks. Launching game." 18
        return 0
    }

    mkdir -p "${WINEPREFIX}/.batocera-runtime-stamps" || return 0
    for verb in "${verbs[@]}"; do
        [[ -z "${verb}" ]] && continue
        safe_verb="${verb//[^A-Za-z0-9_.-]/_}"
        stamp="${WINEPREFIX}/.batocera-runtime-stamps/${safe_verb}"
        [[ -e "${stamp}" ]] && { echo "Runtime '${verb}' already injected for ${WINEPREFIX}"; continue; }

        flash_msg 5 "Installing Windows runtime: ${verb}" 18
        echo "Installing winetricks runtime '${verb}' into ${WINEPREFIX}"
        if WINEPREFIX=${WINEPREFIX} ${CMD_PREFIX} "${WINETRICKS}" -q "${verb}"; then
            "${WINESERVER}" -w
            date '+%F %T' > "${stamp}"
            flash_msg 4 "Installed runtime: ${verb}" 18
            echo "Installed winetricks runtime '${verb}' into ${WINEPREFIX}"
        else
            flash_msg 5 "Runtime install failed: ${verb}" 18
            echo "Warning: winetricks runtime '${verb}' failed; launching game anyway." >&2
        fi
    done
}

