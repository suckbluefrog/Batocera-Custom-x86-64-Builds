    for i in "$@"; do
        [ ! -e "$i" ] && echo "${FUNCNAME[1]}: $i does not exists" && continue
        ii=$(df -PTh "$i" | awk 'END{print $2}')
        [ -d "$i" ] && printf "%s: Directory %s uses filesystem %s" "${FUNCNAME[1]}" "$i" "$ii"
        [ -f "$i" ] && printf "%s: File      %s uses filesystem %s" "${FUNCNAME[1]}" "$i" "$ii"
        [ -L "$i" ] && printf "\n\t \\----> Symlinked to: " && readlink "$i" || echo
    done
}

cleanAndExit() {
    RESNEW=$(batocera-resolution currentMode)
    if [[ "${RESNEW}" != "${G_RESCUR}" ]]; then
        batocera-resolution setMode "${G_RESCUR}"
    fi

    if [[ -e "${GST_REGISTRY_1_0}" ]]; then
        rm -f "${GST_REGISTRY_1_0}"
    fi
    
    # Clean up box64 wrapper directory if it exists
    if [[ -n "${BOX64_WRAPPER_DIR}" ]] && [[ -d "${BOX64_WRAPPER_DIR}" ]]; then
        rm -rf "${BOX64_WRAPPER_DIR}"
    fi

    case "${GAMEEXT,,}" in
        "iso")
            # try to clean the cdrom
            [[ -n "${GAMEISOMOUNT}" ]] && [[ -d "${GAMEISOMOUNT}" ]] && safe_umount "${GAMEISOMOUNT}" || return 1
            [[ -n "${GAMEISOMOUNT}" ]] && [[ -d "${GAMEISOMOUNT}" ]] && rm -rf "${GAMEISOMOUNT}"
            ;;
        "wsquashfs")
            # Safely unmount and clean up
            [[ -n "${WINEPOINT}" ]] && [[ -d "${WINEPOINT}" ]] && safe_umount "${WINEPOINT}" || return 1
            [[ -n "${SQUASHFSPOINT}" ]] && [[ -d "${SQUASHFSPOINT}" ]] && safe_umount "${SQUASHFSPOINT}" || return 1

            # Remove directories if they exist
            [[ -n "${SQUASHFSPOINT}" ]] && [[ -d "${SQUASHFSPOINT}" ]] && rm -rf "${SQUASHFSPOINT}"
            [[ -n "${WORKPOINT}" ]] && [[ -d "${WORKPOINT}" ]] && rm -rf "${WORKPOINT}"
            [[ -n "${WINEPOINT}" ]] && [[ -d "${WINEPOINT}" ]] && rm -rf "${WINEPOINT}"
            ;;
    esac
    echo "WineServer was ${SECONDS}s active"
    return $?
}

init_wine() {
    # Check the system's display mode once at the start
    SYSTEM_DISPLAY_MODE=$(batocera-resolution getDisplayMode)
    HOST_ARCH="$(uname -m)"

    HAS_ARMHF_RUNTIME=0
    if [[ -d "/lib32" ]] && \
       ([[ -e "/lib/ld-linux-armhf.so.3" ]] || [[ -e "/lib32/ld-linux-armhf.so.3" ]] || [[ -e "/lib32/ld-linux.so.3" ]]); then
        HAS_ARMHF_RUNTIME=1
    fi

    ## Wine detection
    WINE_RUNNER="$(/usr/bin/batocera-settings-get windows.wine-runner)"
    [[ -z "$WINE_RUNNER" ]] && WINE_RUNNER="wine-tkg"
    WINE_LAUNCHER="$(get_setting wine-launcher "${SYSTEM}" "${ROMGAMENAME}")"
    [[ -z "${WINE_LAUNCHER}" ]] && WINE_LAUNCHER="direct"

    WINE_VERSION="$(get_setting wine-runner "${SYSTEM}" "${ROMGAMENAME}")"
    # to help with the transition from previous runners.
    [[ -z "$WINE_VERSION" ]] && WINE_VERSION="$(get_setting core "${SYSTEM}" "${ROMGAMENAME}" || echo "${WINE_RUNNER}")"

    if [[ "${WINE_VERSION}" == "lutris" ]]; then
        WINE_VERSION="wine-tkg"
    elif [[ "${WINE_VERSION}" == "proton" ]]; then
        WINE_VERSION="wine-proton"
    fi

    WINE_BOTTLE_VERSION="${WINE_VERSION}"

    if [[ "${WINE_VERSION}" == "proton-ge" ]]; then
        if [[ "${WINE_LAUNCHER}" != "umu" ]]; then
            echo "*** proton-ge selected; forcing UMU launcher mode ***"
        fi
        WINE_LAUNCHER="umu"
        WINE_BOTTLE_VERSION="proton-ge"
        UMU_PROTONPATH="$(prepare_umu_proton)" || {
            echo "*** Failed to prepare Proton GE for UMU launcher ***"
            return 1
        }
        if [[ -e "/userdata/system/wine/.local/share/umu/steamrt3/run" ]]; then
            UMU_RUNTIME_UPDATE_VALUE="0"
        fi
        echo "*** UMU launcher enabled with Proton GE at ${UMU_PROTONPATH} ***"
        WINE_VERSION="wine-tkg"
    fi

    if [[ "${WINE_LAUNCHER}" == "umu" && -z "${UMU_PROTONPATH}" ]]; then
        echo "*** UMU launcher requested without proton-ge runner; falling back to direct runner mode ***"
        WINE_LAUNCHER="direct"
    fi

    AARCH64_WINE_MODE="$(get_setting aarch64_wine_mode "${SYSTEM}" "${ROMGAMENAME}")"
    AARCH64_WINE_MODE_IS_SET=1
    if [[ -z "${AARCH64_WINE_MODE}" ]]; then
        AARCH64_WINE_MODE="wow64"
        AARCH64_WINE_MODE_IS_SET=0
    fi
    FORCE_BOX86_MODE=0

    # Custom runners are usually pure 32-bit builds. Default them to box86 mode on aarch64
    # when WoW64 support is missing and user did not explicitly set the mode.
    if [[ "${HOST_ARCH}" == "aarch64" ]] && [[ "${AARCH64_WINE_MODE_IS_SET}" -eq 0 ]] && \
       [[ ! "${WINE_VERSION}" =~ ^(wine-(tkg|proton)|proton-ge)$ ]] && \
       command -v box86 &>/dev/null && [[ "${HAS_ARMHF_RUNTIME}" -eq 1 ]] && \
       is_box86_compatible_runner "${WINE_VERSION}" && ! is_wow64_compatible_runner "${WINE_VERSION}"; then
        AARCH64_WINE_MODE="box86"
        echo "*** aarch64: custom runner '${WINE_VERSION}' has no WoW64 support, defaulting to pure box86 mode ***"
    fi

    if [[ "${HOST_ARCH}" == "aarch64" ]] && [[ "${AARCH64_WINE_MODE}" == "box86" ]]; then
        if command -v box86 &>/dev/null && [[ "${HAS_ARMHF_RUNTIME}" -eq 1 ]]; then
            if is_box86_compatible_runner "${WINE_VERSION}"; then
                FORCE_BOX86_MODE=1
                echo "*** aarch64: forcing pure box86 + wine mode with runner '${WINE_VERSION}' ***"
            else
                echo "*** aarch64: box86 mode requested but runner '${WINE_VERSION}' has no compatible 32-bit wine/wineserver pair ***"
                echo "*** aarch64: falling back to WoW64 (box64 + wine64) ***"
                AARCH64_WINE_MODE="wow64"
                FORCE_BOX86_MODE=0
            fi
        else
            echo "*** aarch64: box86 mode requested but requirements are missing (box86 + armhf runtime) ***"
            echo "*** aarch64: falling back to WoW64 (box64 + wine64) ***"
            AARCH64_WINE_MODE="wow64"
            FORCE_BOX86_MODE=0
        fi
    fi

    # If we are still in WoW64 mode on aarch64, verify runner support and fall back to pure box86 when needed.
    if [[ "${HOST_ARCH}" == "aarch64" ]] && [[ "${FORCE_BOX86_MODE}" -ne 1 ]]; then
        if is_wow64_compatible_runner "${WINE_VERSION}"; then
            echo "*** aarch64: runner '${WINE_VERSION}' supports WoW64 (box64 + wine64) ***"
        else
            echo "*** aarch64: runner '${WINE_VERSION}' does not provide WoW64 support ***"
            if command -v box86 &>/dev/null && [[ "${HAS_ARMHF_RUNTIME}" -eq 1 ]] && is_box86_compatible_runner "${WINE_VERSION}"; then
                AARCH64_WINE_MODE="box86"
                FORCE_BOX86_MODE=1
                echo "*** aarch64: falling back to pure box86 + wine mode with runner '${WINE_VERSION}' ***"
            else
                echo "*** aarch64: no valid fallback mode for runner '${WINE_VERSION}' (needs WoW64 or box86-compatible runtime) ***"
            fi
        fi
    fi

    echo "*** Chosen WINE runner is ${WINE_VERSION} ***"

    ## Wine executables
    DIR="$(find_wine_dir "$WINE_VERSION")"
    if [[ $? -eq 0 ]]; then
        WINE_VERSION="$(update_wine_version "$WINE_VERSION")"
    else
        echo "can't find WINE version ${WINE_VERSION} directory, you should change the runner"
        exit 1
    fi

    echo "*** Directory checks complete, WINE runner is ${WINE_VERSION} ***"
    USER_DIR="/userdata/system/wine"
    WOW64_WRAPPERS="$(get_setting wow64_wrappers "${SYSTEM}" "${ROMGAMENAME}")"
    [[ -z "${WOW64_WRAPPERS}" ]] && WOW64_WRAPPERS=1
    
    ## Runtime emulation detection by host architecture.
    BOX64=""
    BOX86=""
    if [[ "${HOST_ARCH}" == "aarch64" ]]; then
        if [[ "${FORCE_BOX86_MODE}" -eq 1 ]]; then
            BOX86="box86"
            export BOX86_LOG=0
            export BOX86_DYNAREC=1
            echo "*** Running on aarch64 - box86 emulation enabled (32-bit mode) ***"
        else
            if command -v box64 &>/dev/null; then
                BOX64="box64"
                # Box64 environment configuration
                export BOX64_LOG=0
                export BOX64_DYNAREC=1
                export BOX64_DYNAREC_BIGBLOCK=1
                export BOX64_DYNAREC_STRONGMEM=2
                export BOX64_DYNAREC_FASTROUND=1
                export BOX64_DYNAREC_FASTNAN=1
                export BOX64_DYNAREC_SAFEFLAGS=1
                echo "*** Running on aarch64 - box64 emulation enabled (WoW64 mode) ***"
            else
                echo "ERROR: Running on aarch64 but box64 is not installed!" >&2
                echo "Please install box64 to run Wine on this architecture." >&2
                exit 1
            fi
        fi
    elif [[ "${HOST_ARCH}" == arm* ]]; then
        if command -v box86 &>/dev/null && [[ "${HAS_ARMHF_RUNTIME}" -eq 1 ]]; then
            BOX86="box86"
            export BOX86_LOG=0
            export BOX86_DYNAREC=1
            echo "*** Running on ${HOST_ARCH} - box86 emulation enabled ***"
        elif command -v box86 &>/dev/null; then
            echo "*** Running on ${HOST_ARCH} - box86 found but armhf runtime is incomplete (/lib32 + ld-linux-armhf.so.3 missing) ***"
            echo "*** Falling back to native/binfmt execution path ***"
        else
            echo "*** Running on ${HOST_ARCH} - box86 not found, relying on native/binfmt execution ***"
        fi
    else
        echo "*** Running on ${HOST_ARCH} - native execution ***"
    fi
    
    # Pure modes:
    # - aarch64 + FORCE_BOX86_MODE=1 => 32-bit wine + box86
    # - aarch64 + FORCE_BOX86_MODE=0 => wine64 + box64 (WoW64)
    if [[ "${HOST_ARCH}" == "aarch64" && "${FORCE_BOX86_MODE}" -ne 1 ]]; then
        # WoW64 mode
        if [[ -e "${DIR}/${WINE_VERSION}/lib/wine/x86_64-unix/wine64" ]]; then
            WINE="${DIR}/${WINE_VERSION}/lib/wine/x86_64-unix/wine64"
        else
            WINE="${DIR}/${WINE_VERSION}/bin/wine64"
        fi
        WINE64="${WINE}"
        echo "*** aarch64: Using wine64 for WoW64 mode: ${WINE} ***"
    else
        # Non-aarch64: prefer 32-bit wine path.
        # check 32-bit wine path
        if [[ -e "${DIR}/${WINE_VERSION}/lib/wine/i386-unix/wine" ]]; then
            WINE="${DIR}/${WINE_VERSION}/lib/wine/i386-unix/wine"
        else
            WINE="${DIR}/${WINE_VERSION}/bin/wine"
        fi
        # check 64-bit wine64 path
        if [[ -e "${DIR}/${WINE_VERSION}/lib/wine/x86_64-unix/wine64" ]]; then
            WINE64="${DIR}/${WINE_VERSION}/lib/wine/x86_64-unix/wine64"
        elif [[ -e "${DIR}/${WINE_VERSION}/bin/wine64" ]]; then
            WINE64="${DIR}/${WINE_VERSION}/bin/wine64"
        else
            # 32-bit-only runners do not ship wine64; keep reg_install and helpers working.
            WINE64="${WINE}"
        fi
    fi
    
    if [[ "${HOST_ARCH}" == "aarch64" && "${FORCE_BOX86_MODE}" -eq 1 ]]; then
        # Pure box86 mode: prefer 32-bit wineserver paths.
        if [[ -e "${DIR}/${WINE_VERSION}/lib/wine/i386-unix/wineserver" ]]; then
            WINESERVER="${DIR}/${WINE_VERSION}/lib/wine/i386-unix/wineserver"
        elif [[ -e "${DIR}/${WINE_VERSION}/bin/wineserver" ]]; then
            WINESERVER="${DIR}/${WINE_VERSION}/bin/wineserver"
        elif [[ -e "${DIR}/${WINE_VERSION}/lib/wine/wineserver" ]]; then
            WINESERVER="${DIR}/${WINE_VERSION}/lib/wine/wineserver"
        else
            echo "ERROR: 32-bit wineserver not found for runner '${WINE_VERSION}' under ${DIR}/${WINE_VERSION}" >&2
            exit 1
        fi
    elif [[ "${HOST_ARCH}" == "aarch64" ]]; then
        # Pure WoW64 mode: prefer native wineserver paths.
        if [[ -e "${DIR}/${WINE_VERSION}/bin/wineserver" ]]; then
            WINESERVER="${DIR}/${WINE_VERSION}/bin/wineserver"
        elif [[ -e "${DIR}/${WINE_VERSION}/lib/wine/x86_64-unix/wineserver" ]]; then
            WINESERVER="${DIR}/${WINE_VERSION}/lib/wine/x86_64-unix/wineserver"
        elif [[ -e "${DIR}/${WINE_VERSION}/lib/wine/wineserver" ]]; then
            WINESERVER="${DIR}/${WINE_VERSION}/lib/wine/wineserver"
        else
            echo "ERROR: WoW64 wineserver not found for runner '${WINE_VERSION}' under ${DIR}/${WINE_VERSION}" >&2
            exit 1
        fi
    elif [[ -e "${DIR}/${WINE_VERSION}/bin/wineserver" ]]; then
        WINESERVER="${DIR}/${WINE_VERSION}/bin/wineserver"
    elif [[ -e "${DIR}/${WINE_VERSION}/lib/wine/i386-unix/wineserver" ]]; then
        WINESERVER="${DIR}/${WINE_VERSION}/lib/wine/i386-unix/wineserver"
    elif [[ -e "${DIR}/${WINE_VERSION}/lib/wine/wineserver" ]]; then
        WINESERVER="${DIR}/${WINE_VERSION}/lib/wine/wineserver"
    else
        echo "ERROR: wineserver not found for runner '${WINE_VERSION}' under ${DIR}/${WINE_VERSION}" >&2
        exit 1
    fi
    WINESERVER_REAL="${WINESERVER}"
    MSIEXEC="${DIR}/${WINE_VERSION}/bin/msiexec"
    WINETRICKS="${DIR}/winetricks"
    
    # Create box64 wrapper scripts for Wine binaries on aarch64.
    if [[ -n "${BOX64}" && "${WOW64_WRAPPERS}" != "0" ]]; then
        BOX64_WRAPPER_DIR="/var/run/box64-wine-$$"
        mkdir -p "${BOX64_WRAPPER_DIR}"
        
        # Store the real binary paths before we override them
        REAL_WINE="${WINE}"
        REAL_WINESERVER="${WINESERVER}"
        REAL_MSIEXEC="${MSIEXEC}"
        
        # Create wrapper for wine/wine64
        cat > "${BOX64_WRAPPER_DIR}/wine" << EOF
#!/bin/bash
exec box64 "${REAL_WINE}" "\$@"
EOF
        chmod +x "${BOX64_WRAPPER_DIR}/wine"
        
        cat > "${BOX64_WRAPPER_DIR}/wine64" << EOF
#!/bin/bash
exec box64 "${REAL_WINE}" "\$@"
EOF
        chmod +x "${BOX64_WRAPPER_DIR}/wine64"
        
        # Create wrapper for wineserver
        cat > "${BOX64_WRAPPER_DIR}/wineserver" << EOF
#!/bin/bash
exec box64 "${REAL_WINESERVER}" "\$@"
EOF
        chmod +x "${BOX64_WRAPPER_DIR}/wineserver"
        
        # Create wrapper for msiexec (it's a Unix binary wrapper in Wine's bin/)
        cat > "${BOX64_WRAPPER_DIR}/msiexec" << EOF
#!/bin/bash
exec box64 "${REAL_MSIEXEC}" "\$@"
EOF
        chmod +x "${BOX64_WRAPPER_DIR}/msiexec"
        
        # Update variables to use wrappers
        WINE="${BOX64_WRAPPER_DIR}/wine"
        WINE64="${BOX64_WRAPPER_DIR}/wine64"
        WINESERVER="${BOX64_WRAPPER_DIR}/wineserver"
        MSIEXEC="${BOX64_WRAPPER_DIR}/msiexec"
        
        echo "*** Box64 wrappers created in ${BOX64_WRAPPER_DIR} ***"
        echo "*** WINE=${WINE} -> ${REAL_WINE} ***"
        echo "*** WINESERVER=${WINESERVER} -> ${REAL_WINESERVER} ***"
    elif [[ -n "${BOX86}" && "${WOW64_WRAPPERS}" != "0" ]]; then
        BOX64_WRAPPER_DIR="/var/run/box86-wine-$$"
        mkdir -p "${BOX64_WRAPPER_DIR}"

        REAL_WINE="${WINE}"
        REAL_WINE64="${WINE64}"
        REAL_WINESERVER="${WINESERVER}"
        REAL_MSIEXEC="${MSIEXEC}"

        cat > "${BOX64_WRAPPER_DIR}/wine" << EOF
#!/bin/bash
exec box86 "${REAL_WINE}" "\$@"
EOF
        chmod +x "${BOX64_WRAPPER_DIR}/wine"

        cat > "${BOX64_WRAPPER_DIR}/wine64" << EOF
#!/bin/bash
exec box86 "${REAL_WINE64}" "\$@"
EOF
        chmod +x "${BOX64_WRAPPER_DIR}/wine64"

        cat > "${BOX64_WRAPPER_DIR}/wineserver" << EOF
#!/bin/bash
exec box86 "${REAL_WINESERVER}" "\$@"
EOF
        chmod +x "${BOX64_WRAPPER_DIR}/wineserver"

        cat > "${BOX64_WRAPPER_DIR}/msiexec" << EOF
#!/bin/bash
exec box86 "${REAL_MSIEXEC}" "\$@"
EOF
        chmod +x "${BOX64_WRAPPER_DIR}/msiexec"

        WINE="${BOX64_WRAPPER_DIR}/wine"
        WINE64="${BOX64_WRAPPER_DIR}/wine64"
        WINESERVER="${BOX64_WRAPPER_DIR}/wineserver"
        MSIEXEC="${BOX64_WRAPPER_DIR}/msiexec"

        echo "*** Box86 wrappers created in ${BOX64_WRAPPER_DIR} ***"
        echo "*** WINE=${WINE} -> ${REAL_WINE} ***"
        echo "*** WINESERVER=${WINESERVER} -> ${REAL_WINESERVER} ***"
    elif [[ "${WOW64_WRAPPERS}" == "0" ]]; then
        echo "*** Wrapper layer disabled by setting (wow64_wrappers=0); using direct Wine binaries ***"
    fi

    # Check lib64 directory
    if [[ -e "${DIR}/${WINE_VERSION}/lib64/wine" ]]; then
        WINE_LIB64_DIR="${DIR}/${WINE_VERSION}/lib64/wine"
    else
        WINE_LIB64_DIR="${DIR}/${WINE_VERSION}/lib/wine"
    fi
    # Check lib32 directory
    if [[ -e "${DIR}/${WINE_VERSION}/lib32/wine" ]]; then
        WINE_LIB32_DIR="${DIR}/${WINE_VERSION}/lib32/wine"
    else
        WINE_LIB32_DIR="${DIR}/${WINE_VERSION}/lib/wine"
    fi

    ## Export Wine libs
    # Prepend wrapper dir so emulation wrappers are found first.
    if [[ -n "${BOX64_WRAPPER_DIR}" ]]; then
        PATH="${BOX64_WRAPPER_DIR}:${PATH}:${DIR}/${WINE_VERSION}/bin"
    else
        PATH="${PATH}:${DIR}/${WINE_VERSION}/bin"
    fi
    # Box86 uses BOX86_PATH to resolve x86 child executables (e.g. wineserver).
    # Without this, prefix initialization can fail with:
    # "Error: file is not found (check BOX86_PATH)".
    if [[ -n "${BOX86}" ]]; then
        export BOX86_PATH="${BOX64_WRAPPER_DIR}:${DIR}/${WINE_VERSION}/bin:${WINE_LIB32_DIR}/i386-unix:/usr/bin"
        export BOX86_LD_LIBRARY_PATH="/lib32:/usr/lib32:${WINE_LIB32_DIR}/i386-unix:/usr/lib/box86-i386-linux-gnu"
    fi
    export LD_LIBRARY_PATH="/lib32:/usr/lib32:${WINE_LIB32_DIR}/i386-unix:/lib:/usr/lib:${WINE_LIB64_DIR}/x86_64-unix"
    export GST_PLUGIN_SYSTEM_PATH_1_0="/usr/lib/gstreamer-1.0:/usr/lib32/gstreamer-1.0:/lib32/gstreamer-1.0"
    export GST_REGISTRY_1_0="/userdata/system/.cache/gstreamer-1.0/registry.x86_64.bin:/userdata/system/.cache/gstreamer-1.0/registry..bin"
    export LIBGL_DRIVERS_PATH="/lib32/dri:/usr/lib32/dri:/usr/lib/dri"
    export WINEDLLPATH="${WINE_LIB32_DIR}/i386-windows:${WINE_LIB64_DIR}/x86_64-windows"
    # hum pw 0.2 and 0.3 are hardcoded, not nice
    export SPA_PLUGIN_DIR="/usr/lib/spa-0.2:/usr/lib32/spa-0.2:/lib32/spa-0.2"
    export PIPEWIRE_MODULE_DIR="/usr/lib/pipewire-0.3:/usr/lib32/pipewire-0.3:/lib32/pipewire-0.3"

    # safe old resolution, for bringing it back properly after WINE closes, cleanAndExit()
    G_RESCUR=$(batocera-resolution currentMode)
}

###### MAIN #######
trap stopWineServer SIGHUP SIGINT SIGTERM

#Init WINE Folders and Extension only if parameters are correct and a system is setted
[[ -z "${SYSTEM}" ]] && SYSTEM="~NO SYSTEM~"
[[ -z "${ACTION}" ]] && ACTION="~NO ACTION~"

case "${ACTION}" in
   "stop")
        echo "Stop called from Sunbeam: Outside World"
        PID=$(pgrep -f -o $0)
        kill -1 $(pgrep -P $PID)
        kill -1 $PID
        exit 0
   ;;

# case selections will provide 2 variables here, GAMENAME and WINEPOINT
   "play")
   init_wine
	case "${GAMEEXT,,}" in
	    "wine")
		requestFileSystem "${GAMENAME}"
		play_wine "${GAMENAME}" "${GAMENAME}"
		;;
		    "pc")
			requestFileSystem "${GAMENAME}" "${WINE_BOTTLE_DIR}/${WINE_BOTTLE_VERSION}/${ROMGAMENAME}.wine"
			play_pc "${GAMENAME}" "${WINE_BOTTLE_DIR}/${WINE_BOTTLE_VERSION}/${ROMGAMENAME}.wine"
			;;
		    "exe")
			requestFileSystem "${GAMENAME}" "${WINE_BOTTLE_DIR}/${WINE_BOTTLE_VERSION}/${ROMGAMENAME}.wine"
			play_exe "${GAMENAME}" "${WINE_BOTTLE_DIR}/${WINE_BOTTLE_VERSION}/${ROMGAMENAME}.wine"
			;;
#	    "iso")
#		play_iso "${GAMENAME}"
#		;;
		    "wsquashfs")
			#Arguments, ROMNAME, WINEPREFIX as squashfs, SAVEDIR, WORKDIR
			requestFileSystem "${GAMENAME}" "${WINE_BOTTLE_DIR}/${WINE_BOTTLE_VERSION}/${ROMGAMENAME}.wine"
			play_squashfs "${GAMENAME}" "/var/run/wine/${ROMGAMENAME}" "${WINE_BOTTLE_DIR}/${WINE_BOTTLE_VERSION}/${ROMGAMENAME}.wine" "${WINE_BOTTLE_DIR}/${ROMGAMENAME}.work"
			;;
		    "wtgz")
			requestFileSystem "${GAMENAME}" "${WINE_BOTTLE_DIR}/${WINE_BOTTLE_VERSION}/${ROMGAMENAME}.wine"
			play_winetgz "${GAMENAME}" "${WINE_BOTTLE_DIR}/${WINE_BOTTLE_VERSION}/${ROMGAMENAME}.wine"
			;;
	    *)
		echo "unknown extension ${GAMEEXT}" >&2
	esac
	;;

    "install")
    init_wine && requestFileSystem "${GAMENAME}"
	case "${GAMEEXT,,}" in
	    "exe"|"msi")
		#Winepoint with stripped extension, add current date_time to avoid duplicates
		install_exe_msi "${GAMEEXT,,}" "${GAMENAME}" "${G_ROMS_DIR}/$(date +%y%m%d-%H%M%S)_${ROMGAMENAME%.*}.wine"
		;;
	    "iso")
		#Parsing Gamename, Winepoint with stripped extension, add current date_time to avoid duplicates
		install_iso "${GAMENAME}" "${G_ROMS_DIR}/$(date +%y%m%d-%H%M%S)_${ROMGAMENAME%.*}.wine"
		;;
	    *)
		echo "unknown extension ${GAMEEXT}" >&2
	esac
	;;

    "tricks"|"createprefix")
        init_wine && requestFileSystem "${GAMENAME}"
        case "${GAMEEXT,,}" in
            "wine")
                [[ "${ACTION}" == "createprefix" ]] && { echo "error: '${GAMENAME}' is already a prefix"; exit 1; }
                l_PREFIX="${GAMENAME}"
                setPrefixArch "${GAMENAME}" "${WINE_VERSION}" "${ACTION}"
                ;;
            "wtqz"|"pc"|"exe"|"wsquashfs")
                l_PREFIX="${WINE_BOTTLE_DIR}/${WINE_BOTTLE_VERSION}/${ROMGAMENAME}.wine"
                setPrefixArch "${l_PREFIX}" "${WINE_VERSION}" "${ACTION}"
                test -d "${l_PREFIX}" && echo "WINEPREFIX: '$_' already found!" || { createWineDirectory "$_" && echo "WINEPREFIX: '$_' created!"; }
                ;;
        esac

        if [[ -n "${TRICK}" && "${ACTION}" == "tricks" ]]; then
            shift 3 # heap additional arguments for daisychained tricks or cli commands
            echo "${FUNCNAME[0]}: Applying tricks: $@ to '${l_PREFIX}'"
            trick_wine "${l_PREFIX}" "$@"
        fi
        unset l_PREFIX
	;;

    "wine2squashfs")
	#Parsing Gamename, location and name of compressed file
	wine2squashfs "${GAMENAME}" "${G_ROMS_DIR}/${ROMGAMENAME%.*}.wsquashfs"
	exit $?
	;;

    "wine2winetgz")
	wine2winetgz "${GAMENAME}" "${G_ROMS_DIR}/${ROMGAMENAME%.*}.wtgz"
	exit $?
	;;

    "add-to-steam")
        add_wine_rom_to_steam "${GAMENAME}"
        exit $?
        ;;

    "autorun"|"autorun-list"|"autorun-count")
        # Create autorunfile, works only in SSH mode, recommended is arg1=gamepath, arg2=searchmask
        # It's held small: "batocera-wine windows autorun . bin" will search current directory in dir bin
        [[ -z "${GAMENAME}" ]] && GAMENAME="$PWD"
        [[ -z "${AUTORUN_FILEMASK}" ]] && AUTORUN_FILEMASK="."
        pushd "${GAMENAME}" &> /dev/null || { echo "Error: Can't enter dir '${GAMENAME}'" >&2; exit 1; }
        GAMENAME="$PWD"
        createAutorunCmd "${GAMENAME}" "${AUTORUN_FILEMASK}" || exit 1
        [[ ${#AUTORUN_FOUNDEXE[@]} -eq 0 ]] && { ! [[ "${ACTION}" == "autorun-count" ]] && echo "Error: No windows executable found in '${GAMENAME}/${AUTORUN_FILEMASK}'" >&2 || echo 0; exit 2; }
        #show only list of exes if autorun-list/count is set otherwise...
        [[ "${ACTION}" == "autorun-list" ]]  && { printf '%s\n' "${AUTORUN_FOUNDEXE[@]}"; exit 0; }
        [[ "${ACTION}" == "autorun-count" ]] && { echo ${#AUTORUN_FOUNDEXE[@]}; exit 0; }
        #...show list with entries numbers to select
        if [[ ${#AUTORUN_FOUNDEXE[@]} -gt 1 ]]; then
            echo "Found ${#AUTORUN_FOUNDEXE[@]} files in ${GAMENAME}"
            echo "0) Enter 0 or CTRL+C to abort creation of autorun.cmd"
            for i in "${AUTORUN_FOUNDEXE[@]}"; do
                let ii++
                echo -e "$ii) $(basename "$i") --> $(dirname "$i")"
            done
            echo; read -p "Select entry to write to autorun.cmd: " ii
        else
            ii=1
        fi
        [[ $ii -eq 0 ]] && exit 2 #0 selected, abort
        [[ -e autorun.cmd ]] && echo "File exists: Creating Backup!" && mv --backup=t autorun.cmd autorun.cmd.bak
        (
            echo "DIR=$(dirname "${AUTORUN_FOUNDEXE[$ii-1]}")"
            echo "CMD=\"$(basename "${AUTORUN_FOUNDEXE[$ii-1]}")\""
        ) > autorun.cmd
        echo "Written: ${GAMENAME}/autorun.cmd"
        popd > /dev/null
        exit 0
    ;;

    *)
        echo "For system <${SYSTEM}> action <${ACTION}> detected" >&2
        echo
        echo "${0} windows play          <game>.iso"             >&2
        echo "${0} windows play          <game>.exe"             >&2
        echo "${0} windows play          <game>.pc"              >&2
        echo "${0} windows play          <game>.wine"            >&2
        echo "${0} windows play          <game>.wsquashfs"       >&2
        echo "${0} windows play          <game>.wtgz"            >&2
        echo "${0} windows install       <game>.exe"             >&2
        echo "${0} windows install       <game>.iso"             >&2
        echo "${0} windows install       <game>.msi"             >&2
        echo "${0} windows tricks        <game>.wine directplay" >&2
        echo "${0} windows createprefix  <game>"                 >&2
        echo "${0} windows wine2squashfs <game.wine>"            >&2
        echo "${0} windows wine2winetgz  <game.wine>"            >&2
        echo "${0} windows add-to-steam  <game>"                 >&2
        echo "${0} windows autorun       <game>.*    drive_c/P*" >&2
        echo "${0} windows autorun-list  <game>"                 >&2
        echo "${0} windows autorun-count <game>"                 >&2
        echo "${0} windows stop"                                 >&2
        exit 1
esac

cleanAndExit $?
exit $?
