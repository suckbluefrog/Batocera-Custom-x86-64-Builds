    enable_gamepad="${BATOCERA_ARCH_PLASMA_THOR_GAMEPAD_MOUSE:-0}"
    [ "${enable_touch}" = "1" ] || [ "${enable_gamepad}" = "1" ] || return 0
    [ -e /dev/uinput ] || modprobe uinput >/dev/null 2>&1 || true
    [ -e /dev/uinput ] || return 0
    command -v python3 >/dev/null 2>&1 || return 0
    python3 - <<'PY' >/dev/null 2>&1 || return 0
from evdev import InputDevice, UInput, ecodes
PY

    event_path=""
    if [ "${enable_touch}" = "1" ]; then
        event_path="$(find_input_event_by_sysfs_pattern 'platform-a90000\.i2c|platform-a90000_i2c' 2>/dev/null || true)"
    fi
    gamepad_path=""
    if [ "${enable_gamepad}" = "1" ]; then
        gamepad_path="$(find_input_event_by_sysfs_pattern 'AYN Odin(2|3) Gamepad|rsinput-gamepad|2020/3001' 2>/dev/null || true)"
    fi
    [ -n "${event_path}${gamepad_path}" ] || {
