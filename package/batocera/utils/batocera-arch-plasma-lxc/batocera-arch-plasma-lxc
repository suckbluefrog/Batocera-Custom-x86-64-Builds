        THOR_TOUCH_MOUSE_GRAB="${BATOCERA_ARCH_PLASMA_THOR_TOUCH_MOUSE_GRAB:-0}" \
        THOR_GAMEPAD_MOUSE_SPEED="${BATOCERA_ARCH_PLASMA_THOR_GAMEPAD_MOUSE_SPEED:-24}" \
        THOR_GAMEPAD_MOUSE_STICK="${BATOCERA_ARCH_PLASMA_THOR_GAMEPAD_MOUSE_STICK:-left}" \
        THOR_GAMEPAD_MOUSE_GRAB="${BATOCERA_ARCH_PLASMA_THOR_GAMEPAD_MOUSE_GRAB:-1}" \
        THOR_GAMEPAD_MOUSE_TRIGGER_THRESHOLD="${BATOCERA_ARCH_PLASMA_THOR_GAMEPAD_MOUSE_TRIGGER_THRESHOLD:-0.50}" \
        nohup "${HOST_RUNTIME_DIR}/thor-touch-mouse.py" >"${log_path}" 2>&1 &
    printf '%s\n' "$!" > "${pidfile}"
