configure_network_manager() {
    local network_iface connection_name="Batocera LXC"
    local -a networkd_units=()

    command -v nmcli >/dev/null 2>&1 || return 0
    command -v systemctl >/dev/null 2>&1 || return 0

    network_iface="$(ip -o route show default 2>/dev/null | awk '{ print $5; exit }')"
    if [ -z "${network_iface}" ]; then
        network_iface="$(find /sys/class/net -mindepth 1 -maxdepth 1 -printf '%f\n' 2>/dev/null | grep -vx lo | head -n 1 || true)"
    fi
    [ -n "${network_iface}" ] || {
        printf '%s\n' 'warning: no LXC network interface found for NetworkManager'
        return 0
    }

    install -d -m 0755 /etc/NetworkManager/conf.d
    # Ubuntu's 10-globally-managed-devices.conf marks every non-Wi-Fi device
    # strictly unmanaged. A per-device managed=1 setting cannot override that
    # keyfile rule, so add a later exception for the container veth itself.
    cat > /etc/NetworkManager/conf.d/90-batocera-lxc.conf <<EOF_NM
[main]
dns=none
rc-manager=unmanaged

[keyfile]
unmanaged-devices=*,except:interface-name:${network_iface}

[device-batocera-lxc]
match-device=interface-name:${network_iface}
managed=1
EOF_NM

    systemctl enable NetworkManager.service >/dev/null 2>&1 || true
    # nmcli talks to the running daemon. Fresh distribution images have the
    # package installed but the service is still inactive at this point.
    if ! run_bounded 30 systemctl restart NetworkManager.service; then
        printf '%s\n' 'warning: NetworkManager failed to start; retaining the working LXC network configuration'
        systemctl status NetworkManager.service --no-pager -l 2>&1 || true
        return 0
    fi
    for _ in $(seq 1 15); do
        nmcli general status >/dev/null 2>&1 && break
        sleep 1
    done
    if ! nmcli general status >/dev/null 2>&1; then
        printf '%s\n' 'warning: NetworkManager did not become ready; retaining the working LXC network configuration'
        return 0
    fi

    if nmcli -t -f NAME connection show 2>/dev/null | grep -Fxq "${connection_name}"; then
        if ! nmcli connection modify "${connection_name}" \
            connection.interface-name "${network_iface}" \
            connection.autoconnect yes \
            ipv4.method auto ipv4.ignore-auto-dns yes \
            ipv6.method auto ipv6.ignore-auto-dns yes >/dev/null; then
            printf 'warning: NetworkManager could not update %s\n' "${connection_name}"
            return 0
        fi
    else
        if ! nmcli connection add type ethernet ifname "${network_iface}" \
            con-name "${connection_name}" \
            connection.autoconnect yes \
            ipv4.method auto ipv4.ignore-auto-dns yes \
            ipv6.method auto ipv6.ignore-auto-dns yes >/dev/null; then
            printf 'warning: NetworkManager could not create %s\n' "${connection_name}"
            return 0
        fi
    fi

    # Downloaded LXC images can initially use networkd. Once NetworkManager owns
    # the veth, leave only one DHCP client active so the two services cannot
    # race for the same interface and make Plasma report intermittent outages.
    # Recent systemd releases can reactivate networkd through several varlink
    # and resolver sockets. Mask every concrete networkd unit so it cannot
    # race NetworkManager for the same veth after provisioning or reboot.
    mapfile -t networkd_units < <(
        SYSTEMD_COLORS=0 systemctl list-unit-files 'systemd-networkd*' \
            --no-legend --no-pager 2>/dev/null | awk '$1 !~ /@/ { print $1 }'
    )
    if [ "${#networkd_units[@]}" -gt 0 ]; then
        systemctl disable "${networkd_units[@]}" >/dev/null 2>&1 || true
        systemctl mask "${networkd_units[@]}" >/dev/null 2>&1 || true
        systemctl stop "${networkd_units[@]}" >/dev/null 2>&1 || true
    fi
    nmcli device set "${network_iface}" managed yes >/dev/null 2>&1 || true

    for _ in $(seq 1 15); do
        if nmcli connection up "${connection_name}" >/dev/null 2>&1; then
            nmcli general status || true
            return 0
        fi
        sleep 1
    done

    printf 'warning: NetworkManager could not activate %s on %s\n' \
        "${connection_name}" "${network_iface}"
    return 0
}

