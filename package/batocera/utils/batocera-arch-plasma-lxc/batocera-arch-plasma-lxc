#!/bin/bash
set -euo pipefail

export LANG=C
export LC_ALL=C

CONTAINER="${BATOCERA_ARCH_PLASMA_CONTAINER:-arch-plasma}"
LXC_PATH="${BATOCERA_ARCH_PLASMA_LXC_PATH:-/userdata/system/lxc}"
STATE_DIR="${BATOCERA_ARCH_PLASMA_STATE_DIR:-/userdata/system/arch-plasma-lxc}"
STATE_FILE="${STATE_DIR}/settings"
LOG="${BATOCERA_ARCH_PLASMA_LOG:-/userdata/system/logs/arch-plasma-lxc.log}"
HOST_RUNTIME_DIR="${BATOCERA_ARCH_PLASMA_RUNTIME:-/userdata/system/.runtime-arch-plasma}"
CONTAINER_RUNTIME_DIR="/batocera-runtime"
HOST_USERDATA_DIR="${BATOCERA_ARCH_PLASMA_HOST_USERDATA:-/userdata}"
CONTAINER_HOST_USERDATA="${BATOCERA_ARCH_PLASMA_CONTAINER_HOST_USERDATA:-/host/userdata}"
ES_SERVICE="/etc/init.d/S31emulationstation"
SESSION_SUPERVISOR_NAME="${BATOCERA_ARCH_PLASMA_SESSION_NAME:-arch-plasma-lxc}"
PORTS_DIR="${BATOCERA_ARCH_PLASMA_LAUNCHER_DIR:-/userdata/roms/emulator}"
LAUNCHER="${PORTS_DIR}/Start_Arch_Plasma_LXC.sh"
GAMELIST="${PORTS_DIR}/gamelist.xml"
DEFAULT_USER="batocera"
DEFAULT_PASSWORD="linux"
ARCH_IMAGE_ARCH="${BATOCERA_ARCH_PLASMA_IMAGE_ARCH:-amd64}"
ARCH_IMAGE_RELEASE="${BATOCERA_ARCH_PLASMA_IMAGE_RELEASE:-current}"
SSH_FORWARD_ENABLE="${BATOCERA_ARCH_PLASMA_SSH_FORWARD_ENABLE:-true}"
SSH_FORWARD_PORT="${BATOCERA_ARCH_PLASMA_SSH_FORWARD_PORT:-2222}"
CONTAINER_SSH_PORT="${BATOCERA_ARCH_PLASMA_CONTAINER_SSH_PORT:-22}"
PLASMA_RENDERER="${BATOCERA_ARCH_PLASMA_RENDERER:-raw}"
if [ -n "${BATOCERA_ARCH_PLASMA_SESSION_TYPE:-}" ]; then
    PLASMA_SESSION_TYPE="${BATOCERA_ARCH_PLASMA_SESSION_TYPE}"
elif [ "${PLASMA_RENDERER}" = "gamescope" ]; then
    PLASMA_SESSION_TYPE="x11"
else
    PLASMA_SESSION_TYPE="wayland"
fi

mkdir -p "$(dirname "${LOG}")" "${STATE_DIR}"

log() {
    printf '[%s] %s\n' "$(date '+%F %T')" "$*" >> "${LOG}"
}

prepare_setup_log() {
    local previous="${LOG}.previous"

    mkdir -p "$(dirname "${LOG}")"
    if [ -s "${LOG}" ]; then
        mv -f "${LOG}" "${previous}" 2>/dev/null || true
    fi
    : > "${LOG}"
    log "setup log started for ${CONTAINER}"
}

die() {
    log "ERROR: $*"
    printf '%s\n' "ERROR: $*" >&2
    exit 1
}

close_inherited_frontend_lock() {
    { exec 9>&-; } 2>/dev/null || true
}

clear_inherited_overlay_env() {
    unset LD_PRELOAD
    unset LD_AUDIT
    unset MANGOHUD
    unset MANGOHUD_CONFIG
    unset MANGOHUD_CONFIGFILE
    unset MANGOHUD_DLSYM
    unset MANGOAPP_CONFIG
}

close_inherited_frontend_lock
clear_inherited_overlay_env

read_first_existing_file() {
    local path

    for path in "$@"; do
        [ -r "${path}" ] || continue
        tr -d '\0' < "${path}" 2>/dev/null | head -n 1
        return 0
    done

    return 1
}

is_asus_rog_ally() {
    local dmi

    dmi="$(read_first_existing_file \
        /sys/class/dmi/id/product_name \
        /sys/class/dmi/id/product_version \
        /sys/class/dmi/id/board_name 2>/dev/null || true)"

    case "${dmi}" in
        *"ROG Ally"*|*"RC71L"*|*"RC72L"*)
            return 0
            ;;
    esac

    return 1
}

configure_device_display_defaults() {
    is_asus_rog_ally || return 0

    if [ -z "${BATOCERA_ARCH_PLASMA_OUTPUT_SCALE+x}" ]; then
        export BATOCERA_ARCH_PLASMA_OUTPUT_SCALE="1"
    fi

    log "applying ASUS ROG Ally display defaults: scale=${BATOCERA_ARCH_PLASMA_OUTPUT_SCALE}"
}

run_detached() {
    if command -v setsid >/dev/null 2>&1; then
        setsid "$@" </dev/null >>"${LOG}" 2>&1 &
    else
        nohup "$@" </dev/null >>"${LOG}" 2>&1 &
    fi
}

have_tty() {
    [ -t 0 ] && [ -t 1 ]
}

save_state() {
    local user="$1"

    umask 077
    {
        printf 'PLASMA_USER=%s\n' "${user}"
        printf 'CONTAINER=%s\n' "${CONTAINER}"
        printf 'LXC_PATH=%s\n' "${LXC_PATH}"
        printf 'SSH_FORWARD_PORT=%s\n' "${SSH_FORWARD_PORT}"
    } > "${STATE_FILE}"
}

load_state() {
    PLASMA_USER="${DEFAULT_USER}"
    if [ -r "${STATE_FILE}" ]; then
        # shellcheck disable=SC1090
        . "${STATE_FILE}"
    fi
    PLASMA_USER="${PLASMA_USER:-${DEFAULT_USER}}"
}

validate_username() {
    local user="$1"
    [[ "${user}" =~ ^[a-z_][a-z0-9_-]{0,31}$ ]]
}

dialog_input() {
    local title="$1"
    local text="$2"
    local default_value="$3"

    dialog --stdout --title "${title}" --inputbox "${text}" 9 60 "${default_value}"
}

dialog_password() {
    local title="$1"
    local text="$2"
    local default_value="$3"

    dialog --stdout --insecure --title "${title}" --passwordbox "${text}" 9 60 "${default_value}"
}

prompt_credentials() {
    local user password confirm

    command -v dialog >/dev/null 2>&1 || die "dialog is not installed"

    while :; do
        user="$(dialog_input "Arch Plasma LXC" "Default desktop username:" "${PLASMA_USER:-${DEFAULT_USER}}")" || return 1
        if validate_username "${user}"; then
            break
        fi
        dialog --title "Arch Plasma LXC" --msgbox "Use a Linux username beginning with a lowercase letter or underscore. Allowed later characters: lowercase letters, numbers, underscore, hyphen." 10 70
    done

    while :; do
        password="$(dialog_password "Arch Plasma LXC" "Default password for ${user}:" "${DEFAULT_PASSWORD}")" || return 1
        confirm="$(dialog_password "Arch Plasma LXC" "Confirm password for ${user}:" "${password}")" || return 1
        if [ "${password}" = "${confirm}" ] && [ -n "${password}" ]; then
            break
        fi
        dialog --title "Arch Plasma LXC" --msgbox "Passwords did not match, or the password was empty." 8 58
    done

    PLASMA_USER="${user}"
    PLASMA_PASSWORD="${password}"
}

container_rootfs() {
    printf '%s/%s/rootfs\n' "${LXC_PATH}" "${CONTAINER}"
}

container_config() {
    printf '%s/%s/config\n' "${LXC_PATH}" "${CONTAINER}"
}

container_exists() {
    [ -d "$(container_rootfs)" ] && [ -f "$(container_config)" ]
}

container_has_base_os() {
    [ -f "$(container_rootfs)/etc/os-release" ] || [ -f "$(container_rootfs)/usr/lib/os-release" ]
}

destroy_incomplete_container() {
    local reason="$1"

    container_exists || return 0
    container_has_base_os && return 0

    log "destroying incomplete container ${CONTAINER}: ${reason}"
    lxc-stop -P "${LXC_PATH}" -n "${CONTAINER}" -k >>"${LOG}" 2>&1 || true
    lxc-destroy -P "${LXC_PATH}" -n "${CONTAINER}" -f >>"${LOG}" 2>&1 || true
    rm -rf "${LXC_PATH:?}/${CONTAINER}" >>"${LOG}" 2>&1 || true
}

container_running() {
    [ "$(lxc-info -P "${LXC_PATH}" -n "${CONTAINER}" -sH 2>/dev/null | tr -d '[:space:]')" = "RUNNING" ]
}

start_lxc_network() {
    if ip link show lxcbr0 >/dev/null 2>&1; then
        return 0
    fi

    mkdir -p /etc/default
    cat > /etc/default/lxc-net <<'EOF'
USE_LXC_BRIDGE="true"
LXC_BRIDGE="lxcbr0"
LXC_ADDR="10.0.3.1"
LXC_NETMASK="255.255.255.0"
LXC_NETWORK="10.0.3.0/24"
LXC_DHCP_RANGE="10.0.3.2,10.0.3.254"
LXC_DHCP_MAX="253"
LXC_IPV6_ENABLE="false"
LXC_IPV6_NAT="false"
LXC_USE_NFT="false"
EOF

    if [ -r /etc/init.d/lxc-net ]; then
        sh /etc/init.d/lxc-net start >>"${LOG}" 2>&1 || true
    fi

    ip link show lxcbr0 >/dev/null 2>&1 || die "lxcbr0 did not come up"
}

container_ipv4() {
    container_running || return 1

    lxc-info -P "${LXC_PATH}" -n "${CONTAINER}" -iH 2>/dev/null | \
        awk '/^[0-9]+\./ { print; exit }'
}

configure_host_ssh_forward() {
    local container_ip chain="BATOCERA_ARCH_PLASMA"

    case "${SSH_FORWARD_ENABLE}" in
        0|false|False|FALSE|no|No|NO|off|Off|OFF)
            return 0
            ;;
    esac

    [[ "${SSH_FORWARD_PORT}" =~ ^[0-9]+$ ]] || {
        log "warning: invalid Arch Plasma SSH forward port: ${SSH_FORWARD_PORT}"
        return 0
    }
    [[ "${CONTAINER_SSH_PORT}" =~ ^[0-9]+$ ]] || {
        log "warning: invalid Arch Plasma container SSH port: ${CONTAINER_SSH_PORT}"
        return 0
    }

    command -v iptables >/dev/null 2>&1 || {
        log "warning: iptables is unavailable; Arch Plasma SSH forward not installed"
        return 0
    }

    container_ip="$(container_ipv4 || true)"
    if [ -z "${container_ip}" ]; then
        log "warning: container has no IPv4 address yet; Arch Plasma SSH forward not installed"
        return 0
    fi

    sysctl -w net.ipv4.ip_forward=1 >/dev/null 2>&1 || true

    iptables -t nat -N "${chain}" 2>/dev/null || true
    iptables -t nat -F "${chain}" 2>/dev/null || true
    iptables -t nat -C PREROUTING -p tcp --dport "${SSH_FORWARD_PORT}" -j "${chain}" >/dev/null 2>&1 || \
        iptables -t nat -I PREROUTING 1 -p tcp --dport "${SSH_FORWARD_PORT}" -j "${chain}" 2>>"${LOG}" || true
    iptables -t nat -A "${chain}" -p tcp --dport "${SSH_FORWARD_PORT}" \
        -j DNAT --to-destination "${container_ip}:${CONTAINER_SSH_PORT}" 2>>"${LOG}" || true

    iptables -N "${chain}" 2>/dev/null || true
    iptables -F "${chain}" 2>/dev/null || true
    iptables -C FORWARD -j "${chain}" >/dev/null 2>&1 || \
        iptables -I FORWARD 1 -j "${chain}" 2>>"${LOG}" || true
    iptables -A "${chain}" -p tcp -d "${container_ip}" --dport "${CONTAINER_SSH_PORT}" -j ACCEPT 2>>"${LOG}" || true
    iptables -A "${chain}" -p tcp -s "${container_ip}" --sport "${CONTAINER_SSH_PORT}" -j ACCEPT 2>>"${LOG}" || true

    log "Arch Plasma SSH forward: host tcp/${SSH_FORWARD_PORT} -> ${container_ip}:${CONTAINER_SSH_PORT}"
}

ensure_runtime_dir() {
    configure_device_display_defaults

    mkdir -p "${HOST_RUNTIME_DIR}/pulse" "${HOST_RUNTIME_DIR}/udev"
    chown 1000:1000 "${HOST_RUNTIME_DIR}" "${HOST_RUNTIME_DIR}/pulse" 2>/dev/null || true
    chmod 700 "${HOST_RUNTIME_DIR}" 2>/dev/null || true
    chmod 755 "${HOST_RUNTIME_DIR}/pulse" 2>/dev/null || true

    sync_udev_database

    # Batocera's PipeWire runs as root. Widen the session sockets so the
    # unprivileged Arch desktop user can connect through the bind mounts.
    chmod 777 /run/pipewire-0 /run/pipewire-0-manager /run/pulse/native 2>/dev/null || true
    chmod 777 /run/seatd.sock 2>/dev/null || true
    chmod -R a+rwX /dev/dri /dev/input /dev/snd 2>/dev/null || true
}

sync_udev_database() {
    [ -d /run/udev/data ] || return 0

    rm -rf "${HOST_RUNTIME_DIR}/udev.new" "${HOST_RUNTIME_DIR}/udev.old" 2>/dev/null || true
    mkdir -p "${HOST_RUNTIME_DIR}/udev.new"

    cp -a /run/udev/data "${HOST_RUNTIME_DIR}/udev.new/" 2>/dev/null || return 0
    for name in links tags static_node-tags rules.d; do
        [ -e "/run/udev/${name}" ] || continue
        cp -a "/run/udev/${name}" "${HOST_RUNTIME_DIR}/udev.new/" 2>/dev/null || true
    done

    if [ -d "${HOST_RUNTIME_DIR}/udev" ]; then
        mv "${HOST_RUNTIME_DIR}/udev" "${HOST_RUNTIME_DIR}/udev.old" 2>/dev/null || true
    fi
    mv "${HOST_RUNTIME_DIR}/udev.new" "${HOST_RUNTIME_DIR}/udev" 2>/dev/null || true
    rm -rf "${HOST_RUNTIME_DIR}/udev.old" "${HOST_RUNTIME_DIR}/udev.new" 2>/dev/null || true
}

configure_lxc() {
    local cfg
    cfg="$(container_config)"
    [ -f "${cfg}" ] || die "missing LXC config at ${cfg}"

    sed -i '/# BEGIN batocera arch plasma/,/# END batocera arch plasma/d' "${cfg}"
    sed -i '/^[[:space:]]*lxc\.apparmor\./d' "${cfg}"

    cat >> "${cfg}" <<EOF

# BEGIN batocera arch plasma
lxc.cap.drop =
lxc.cgroup2.devices.allow = c 4:* rwm
lxc.cgroup2.devices.allow = c 10:* rwm
lxc.cgroup2.devices.allow = c 13:* rwm
lxc.cgroup2.devices.allow = c 29:* rwm
lxc.cgroup2.devices.allow = c 116:* rwm
lxc.cgroup2.devices.allow = c 226:* rwm
lxc.mount.entry = /dev/dri dev/dri none rbind,optional,create=dir 0 0
lxc.mount.entry = /dev/input dev/input none rbind,optional,create=dir 0 0
lxc.mount.entry = /dev/snd dev/snd none rbind,optional,create=dir 0 0
lxc.mount.entry = /dev/tty0 dev/tty0 none bind,optional,create=file 0 0
lxc.mount.entry = /dev/fuse dev/fuse none bind,optional,create=file 0 0
lxc.mount.entry = /etc/resolv.conf etc/resolv.conf none bind,ro,optional,create=file 0 0
lxc.mount.entry = /tmp/.X11-unix tmp/.X11-unix none rbind,optional,create=dir 0 0
lxc.mount.entry = ${HOST_RUNTIME_DIR} ${CONTAINER_RUNTIME_DIR#/} none rbind,optional,create=dir 0 0
lxc.mount.entry = ${HOST_USERDATA_DIR} ${CONTAINER_HOST_USERDATA#/} none rbind,optional,create=dir 0 0
lxc.mount.entry = /run/seatd.sock ${CONTAINER_RUNTIME_DIR#/}/seatd.sock none bind,optional,create=file 0 0
lxc.mount.entry = /run/pipewire-0 ${CONTAINER_RUNTIME_DIR#/}/pipewire-0 none bind,optional,create=file 0 0
lxc.mount.entry = /run/pipewire-0-manager ${CONTAINER_RUNTIME_DIR#/}/pipewire-0-manager none bind,optional,create=file 0 0
lxc.mount.entry = /run/pulse/native ${CONTAINER_RUNTIME_DIR#/}/pulse/native none bind,optional,create=file 0 0
# END batocera arch plasma
EOF
}

configure_container_dns() {
    local rootfs resolv

    rootfs="$(container_rootfs)"
    [ -d "${rootfs}/etc" ] || return 0

    resolv="${rootfs}/etc/resolv.conf"
    if [ -L "${resolv}" ] && [ ! -e "${resolv}" ]; then
        rm -f "${resolv}" 2>/dev/null || true
    fi

    if [ -s /etc/resolv.conf ]; then
        cp -f /etc/resolv.conf "${resolv}" 2>>"${LOG}" || true
    else
        {
            printf 'nameserver 1.1.1.1\n'
            printf 'nameserver 8.8.8.8\n'
        } > "${resolv}" 2>>"${LOG}" || true
    fi
    chmod 0644 "${resolv}" 2>/dev/null || true
}

create_container() {
    mkdir -p "${LXC_PATH}"
    start_lxc_network
    ensure_runtime_dir

    destroy_incomplete_container "base image is missing"

    if container_exists; then
        configure_lxc
        configure_container_dns
        return 0
    fi

    log "creating Arch container ${CONTAINER}"
    lxc-create -P "${LXC_PATH}" -n "${CONTAINER}" -t download -- \
        --dist archlinux --release "${ARCH_IMAGE_RELEASE}" --arch "${ARCH_IMAGE_ARCH}" >>"${LOG}" 2>&1
    configure_lxc
    configure_container_dns
}

start_container() {
    start_lxc_network
    ensure_runtime_dir
    configure_container_dns
    configure_lxc

    if container_running && ! container_has_session_mounts; then
        restart_container_for_config_reload
    fi

    if ! container_running; then
        log "starting LXC container ${CONTAINER}"
        lxc-start -P "${LXC_PATH}" -n "${CONTAINER}" -d >>"${LOG}" 2>&1
        lxc-wait -P "${LXC_PATH}" -n "${CONTAINER}" -s RUNNING -t 30 >>"${LOG}" 2>&1 || die "container did not reach RUNNING"
    fi

    if ! container_has_session_mounts; then
        restart_container_for_config_reload
        log "starting LXC container ${CONTAINER}"
        lxc-start -P "${LXC_PATH}" -n "${CONTAINER}" -d >>"${LOG}" 2>&1
        lxc-wait -P "${LXC_PATH}" -n "${CONTAINER}" -s RUNNING -t 30 >>"${LOG}" 2>&1 || die "container did not reach RUNNING"
    fi

    sync_container_udev_database
    configure_host_ssh_forward
}

container_has_session_mounts() {
    container_running || return 1
    lxc-attach -P "${LXC_PATH}" -n "${CONTAINER}" -- /bin/sh -lc \
        "[ -e /dev/dri/card0 ] && [ -d /dev/input ] && [ -d /dev/snd ] && [ -S /batocera-runtime/seatd.sock ] && [ -d ${CONTAINER_HOST_USERDATA} ]" \
        >/dev/null 2>&1
}

sync_container_udev_database() {
    local items=()
    local name

    container_running || return 0
    [ -d /run/udev ] || return 0

    for name in data links tags static_node-tags rules.d; do
        [ -e "/run/udev/${name}" ] && items+=("${name}")
    done
    [ "${#items[@]}" -gt 0 ] || return 0

    lxc-attach -P "${LXC_PATH}" -n "${CONTAINER}" -- /bin/sh -lc \
        'rm -rf /run/udev/data /run/udev/links /run/udev/tags /run/udev/static_node-tags /run/udev/rules.d; mkdir -p /run/udev' \
        >>"${LOG}" 2>&1 || return 0

    if ! tar -C /run/udev -cf - "${items[@]}" 2>/dev/null | \
        lxc-attach -P "${LXC_PATH}" -n "${CONTAINER}" -- tar -C /run/udev -xf - >>"${LOG}" 2>&1; then
        log "warning: could not copy host udev database into ${CONTAINER}"
    fi
}

start_container_udev_sync_loop() {
    (
        while container_running; do
            sync_container_udev_database
            sleep 1
        done
    ) &
    UDEV_SYNC_PID="$!"
}

stop_container_udev_sync_loop() {
    local pid="$1"

    [ -n "${pid}" ] || return 0
    kill "${pid}" 2>/dev/null || true
    wait "${pid}" 2>/dev/null || true
}

restart_container_for_config_reload() {
    log "restarting LXC container ${CONTAINER} to apply session device mounts"
    lxc-stop -P "${LXC_PATH}" -n "${CONTAINER}" >>"${LOG}" 2>&1 || true
    lxc-wait -P "${LXC_PATH}" -n "${CONTAINER}" -s STOPPED -t 15 >>"${LOG}" 2>&1 || true
    if container_running; then
        lxc-stop -P "${LXC_PATH}" -n "${CONTAINER}" -k >>"${LOG}" 2>&1 || true
        lxc-wait -P "${LXC_PATH}" -n "${CONTAINER}" -s STOPPED -t 10 >>"${LOG}" 2>&1 || true
    fi
}

wait_for_container_command() {
    local i

    for i in $(seq 1 90); do
        if lxc-attach -P "${LXC_PATH}" -n "${CONTAINER}" -- /bin/sh -lc 'command -v pacman >/dev/null 2>&1' >/dev/null 2>&1; then
            return 0
        fi
        sleep 1
    done

    die "container is running but not attachable"
}

provision_container() {
    local user="$1"
    local password="$2"

    wait_for_container_command

    log "provisioning Arch Plasma packages"
lxc-attach -P "${LXC_PATH}" -n "${CONTAINER}" --clear-env \
        -v "PLASMA_USER=${user}" -v "PLASMA_PASSWORD=${password}" -- /bin/bash -s >>"${LOG}" 2>&1 <<'EOF'
set -euo pipefail

export LANG=C
export LC_ALL=C
export PATH=/usr/local/sbin:/usr/local/bin:/usr/bin:/usr/sbin:/bin:/sbin

if [ -f /etc/pacman.conf ]; then
    sed -i \
        -e 's/^[[:space:]]*DownloadUser[[:space:]]*=/#DownloadUser =/' \
        -e 's/^[#[:space:]]*DisableSandboxFilesystem/DisableSandboxFilesystem/' \
        -e 's/^[#[:space:]]*DisableDownloadTimeout/DisableDownloadTimeout/' \
        -e 's/^[#[:space:]]*DisableSandboxSyscalls/DisableSandboxSyscalls/' \
        /etc/pacman.conf
fi

configure_arch_mirrors() {
    [ -d /etc/pacman.d ] || return 0
    if [ -f /etc/pacman.d/mirrorlist ] && [ ! -f /etc/pacman.d/mirrorlist.batocera-bak ]; then
        cp -f /etc/pacman.d/mirrorlist /etc/pacman.d/mirrorlist.batocera-bak || true
    fi

    cat > /etc/pacman.d/mirrorlist <<'MIRRORS'
Server = https://geo.mirror.pkgbuild.com/$repo/os/$arch
Server = https://mirror.rackspace.com/archlinux/$repo/os/$arch
Server = https://mirror.leaseweb.com/archlinux/$repo/os/$arch
Server = https://mirrors.kernel.org/archlinux/$repo/os/$arch
MIRRORS
}

pacman_cmd() {
    if pacman --help 2>/dev/null | grep -q -- '--disable-download-timeout'; then
        pacman --disable-download-timeout "$@"
    else
        pacman "$@"
    fi
}

pacman_retry() {
    local attempt

    for attempt in 1 2 3; do
        if pacman_cmd "$@"; then
            return 0
        fi
        sleep $((attempt * 5))
        pacman_cmd -Syy --noconfirm >/dev/null 2>&1 || true
    done

    return 1
}

configure_arch_mirrors

if ! pacman-key --list-keys >/dev/null 2>&1; then
    pacman-key --init
fi
pacman-key --populate archlinux >/dev/null 2>&1 || true
pacman_retry -Syy --noconfirm --needed archlinux-keyring
required_packages=(
    bash sudo shadow dropbear openssh dbus dbus-broker polkit polkit-kde-agent xorg-xwayland \
    xorg-xauth xorg-xrdb kwin-x11 \
    plasma-desktop plasma-workspace plasma-pa systemsettings discover \
    dolphin konsole kate ark gwenview okular spectacle kcalc \
    plasma-systemmonitor kscreen kio-extras packagekit packagekit-qt6 \
    flatpak \
    pipewire pipewire-pulse pipewire-alsa pipewire-jack wireplumber \
    qt6-multimedia-ffmpeg tesseract-data-eng tesseract-data-osd \
    mesa \
    noto-fonts ttf-dejavu
)
optional_packages=(
    plasma-keyboard maliit-keyboard squeekboard
    vulkan-radeon vulkan-intel vulkan-mesa-layers
)

pacman_retry -Syu --noconfirm --needed "${required_packages[@]}"
for package in "${optional_packages[@]}"; do
    if pacman -Si "${package}" >/dev/null 2>&1; then
        pacman_retry -S --noconfirm --needed "${package}"
    fi
done

if command -v flatpak >/dev/null 2>&1; then
    flatpak remote-add --if-not-exists --system flathub https://dl.flathub.org/repo/flathub.flatpakrepo || true
    flatpak update --appstream --system -y || true
fi

if ! id "${PLASMA_USER}" >/dev/null 2>&1; then
    existing_uid_user="$(getent passwd 1000 | cut -d: -f1 || true)"
    if [ -n "${existing_uid_user}" ]; then
        existing_home="$(getent passwd "${existing_uid_user}" | cut -d: -f6)"
        if [ "${existing_home}" != "/home/${PLASMA_USER}" ] && [ ! -e "/home/${PLASMA_USER}" ]; then
            usermod -l "${PLASMA_USER}" -d "/home/${PLASMA_USER}" -m -s /bin/bash "${existing_uid_user}"
        else
            usermod -l "${PLASMA_USER}" -d "/home/${PLASMA_USER}" -s /bin/bash "${existing_uid_user}"
        fi
        existing_gid="$(id -g "${PLASMA_USER}" 2>/dev/null || true)"
        existing_group="$(getent group "${existing_gid}" | cut -d: -f1 || true)"
