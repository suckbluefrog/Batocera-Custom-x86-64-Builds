    fi

    pkill -TERM -x openbox >/dev/null 2>&1 || true
    pkill -TERM -x xinit >/dev/null 2>&1 || true
    pkill -TERM -x startx >/dev/null 2>&1 || true
    pkill -TERM -x X >/dev/null 2>&1 || true
    pkill -TERM -x Xorg >/dev/null 2>&1 || true

    for i in $(seq 1 30); do
        if ! xorg_frontend_running; then
            clear_stale_xorg_locks
            return 0
        fi
        sleep 0.1
    done

    if xorg_frontend_running; then
        log "force-killing leftover Xorg frontend before Arch Plasma DRM launch"
        pkill -KILL -x openbox >/dev/null 2>&1 || true
        pkill -KILL -x xinit >/dev/null 2>&1 || true
        pkill -KILL -x startx >/dev/null 2>&1 || true
        pkill -KILL -x X >/dev/null 2>&1 || true
        pkill -KILL -x Xorg >/dev/null 2>&1 || true
    fi

    clear_stale_xorg_locks
}

stop_frontend_for_drm() {
    if [ -x "${ES_SERVICE}" ]; then
        log "stopping EmulationStation frontend before Arch Plasma launch"
        "${ES_SERVICE}" stop >>"${LOG}" 2>&1 || true
    fi

    stop_xorg_frontend_for_drm

    if ! wait_for_frontend_stop; then
        log "frontend did not stop cleanly; force-killing display frontend"
        stop_xorg_frontend_for_drm
        pkill -KILL -x labwc >/dev/null 2>&1 || true
        pkill -KILL -x sway >/dev/null 2>&1 || true
        clear_stale_frontend_locks
        clear_stale_xorg_locks
    fi

    clear_stale_frontend_locks
}

restore_frontend() {
    if frontend_ready; then
        log "EmulationStation already running after Arch Plasma exit"
        return 0
    fi

    ensure_labwc_keyboard_layout
    stop_xorg_frontend_for_drm
    clear_stale_xorg_locks
    clear_stale_frontend_locks
    if [ -x "${ES_SERVICE}" ]; then
        log "restoring EmulationStation after Arch Plasma exit"
        clear_frontend_restore_env
        "${ES_SERVICE}" start >>"${LOG}" 2>&1 || "${ES_SERVICE}" restart >>"${LOG}" 2>&1 || true
    fi

    if wait_for_frontend_start 80; then
        return 0
    fi

    if command -v labwc-launch >/dev/null 2>&1; then
        log "frontend service did not spawn EmulationStation; starting labwc-launch fallback"
        stop_incomplete_frontend_restore
        clear_stale_xorg_locks
        clear_stale_frontend_locks --force
        clear_frontend_restore_env
        run_detached labwc-launch
        if ! wait_for_frontend_start 120; then
            log "EmulationStation did not return after labwc-launch fallback"
        fi
    fi
}

start_session_supervisor() {
    [[ "${BATOCERA_ARCH_PLASMA_SESSION_SUPERVISOR:-0}" == "1" ]] || return 0
    command -v batocera-steam-session-supervisor >/dev/null 2>&1 || return 0
    batocera-steam-session-supervisor start "${SESSION_SUPERVISOR_NAME}" >>"${LOG}" 2>&1 || true
}

recover_frontend_with_supervisor() {
    [[ "${BATOCERA_ARCH_PLASMA_SESSION_SUPERVISOR:-0}" == "1" ]] || return 0
    command -v batocera-steam-session-supervisor >/dev/null 2>&1 || return 0
    batocera-steam-session-supervisor recover "${SESSION_SUPERVISOR_NAME}-cleanup" >>"${LOG}" 2>&1 || true
}

detach_from_frontend_session() {
    local child_pid child_rc

    [[ "${BATOCERA_ARCH_PLASMA_DETACHED:-0}" != "1" ]] || return 0
    command -v setsid >/dev/null 2>&1 || return 0

    log "detaching Arch Plasma launcher from frontend process group"
    export BATOCERA_ARCH_PLASMA_DETACHED=1

    set +e
    nohup setsid "$0" "$@" >>"${LOG}" 2>&1 </dev/null &
    child_pid="$!"
    wait "${child_pid}"
    child_rc="$?"
    exit "${child_rc}"
}

terminate_plasma_session() {
    local user="$1"

    if ! container_running; then
        return 0
    fi

    log "terminating Plasma user session for ${user}"
    lxc-attach -P "${LXC_PATH}" -n "${CONTAINER}" --clear-env -v "PLASMA_USER=${user}" -- /bin/bash -s >>"${LOG}" 2>&1 <<'EOF' || true
set +e
uid="$(id -u "${PLASMA_USER}" 2>/dev/null || true)"
[ -n "${uid}" ] || exit 0

patterns='startplasma|plasma_session|plasmashell|kwin_wayland|ksmserver|kded|kactivity|xdg-desktop-portal|xdg-document-portal|baloo|kglobalaccel|krunner|konsole|dolphin|pipewire|wireplumber'
pkill -TERM -u "${uid}" -f "${patterns}" 2>/dev/null || true
for _ in $(seq 1 20); do
    if ! pgrep -u "${uid}" -f "${patterns}" >/dev/null 2>&1; then
        break
    fi
    sleep 0.2
done
pkill -KILL -u "${uid}" -f "${patterns}" 2>/dev/null || true

root_patterns='batocera-start-plasma-root|batocera-plasma-session-wrapper|kwin_wayland.*batocera-plasma-session-wrapper'
pkill -TERM -f "${root_patterns}" 2>/dev/null || true
for _ in $(seq 1 20); do
    if ! pgrep -f "${root_patterns}" >/dev/null 2>&1; then
        exit 0
    fi
    sleep 0.2
done
pkill -KILL -f "${root_patterns}" 2>/dev/null || true
EOF
}

detect_resolution() {
    local value

    if command -v batocera-resolution >/dev/null 2>&1; then
        value="$(batocera-resolution currentResolution 2>/dev/null || true)"
        if [[ "${value}" =~ ^([0-9]+)x([0-9]+)$ ]]; then
            printf '%s %s\n' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}"
            return 0
        fi
    fi

    printf '1280 720\n'
}

detect_refresh_rate() {
    local value

    if command -v batocera-resolution >/dev/null 2>&1; then
        value="$(batocera-resolution refreshRate 2>/dev/null || true)"
        if [[ "${value}" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
            awk -v rate="${value}" 'BEGIN { printf "%d\n", int(rate + 0.5) }'
            return 0
        fi
    fi

    printf '60\n'
}

launch_plasma_session() {
    local user="$1"
    local uid gid runtime_dir runtime_parent udev_sync_pid session_rc

    start_container
    wait_for_container_command

    uid="$(lxc-attach -P "${LXC_PATH}" -n "${CONTAINER}" -- id -u "${user}" 2>/dev/null || true)"
    [ -n "${uid}" ] || die "container user ${user} does not exist"
    gid="$(lxc-attach -P "${LXC_PATH}" -n "${CONTAINER}" -- id -g "${user}" 2>/dev/null || true)"
    [ -n "${gid}" ] || gid="${uid}"

    ensure_runtime_dir
    if [ "${PLASMA_SESSION_TYPE}" = "wayland" ]; then
        runtime_dir="/run/batocera-plasma/${uid}"
    else
        runtime_dir="/run/user/${uid}"
    fi
    runtime_parent="$(dirname "${runtime_dir}")"

    lxc-attach -P "${LXC_PATH}" -n "${CONTAINER}" -- /bin/sh -lc \
        "install -d -m 0755 '${runtime_parent}' && install -d -m 0700 -o '${uid}' -g '${gid}' '${runtime_dir}'" >>"${LOG}" 2>&1

    export BATOCERA_ARCH_PLASMA_LXC_PATH="${LXC_PATH}"
    export BATOCERA_ARCH_PLASMA_CONTAINER="${CONTAINER}"
    export BATOCERA_ARCH_PLASMA_USER="${user}"

    log "launching Arch Plasma with ${PLASMA_RENDERER} KWin renderer (${PLASMA_SESSION_TYPE})"
    if command -v batocera-mouse >/dev/null 2>&1; then
        batocera-mouse show >/dev/null 2>&1 || true
    fi

    if [ "${PLASMA_SESSION_TYPE}" = "wayland" ]; then
        UDEV_SYNC_PID=""
        start_container_udev_sync_loop
        udev_sync_pid="${UDEV_SYNC_PID}"
        set +e
        lxc-attach -P "${LXC_PATH}" -n "${CONTAINER}" --clear-env \
            -v "PLASMA_USER=${user}" \
            -v "PLASMA_UID=${uid}" \
            -v "PLASMA_GID=${gid}" \
            -v "LANG=C.UTF-8" \
            -v "XDG_RUNTIME_DIR=${runtime_dir}" \
            -v "BATOCERA_ARCH_PLASMA_SESSION_TYPE=${PLASMA_SESSION_TYPE}" \
            -v "KWIN_DRM_DEVICES=${BATOCERA_ARCH_PLASMA_DRM_DEVICES:-/dev/dri/card0}" \
            -v "LIBSEAT_BACKEND=seatd" \
            -v "SEATD_SOCK=/batocera-runtime/seatd.sock" \
            -v "PIPEWIRE_REMOTE=/batocera-runtime/pipewire-0" \
            -v "PULSE_SERVER=unix:/batocera-runtime/pulse/native" \
            -v "BATOCERA_ARCH_PLASMA_OUTPUT_SCALE=${BATOCERA_ARCH_PLASMA_OUTPUT_SCALE:-}" \
            -- /usr/local/bin/batocera-start-plasma-root
        session_rc="$?"
        set -e
        stop_container_udev_sync_loop "${udev_sync_pid}"
        return "${session_rc}"
    else
        lxc-attach -P "${LXC_PATH}" -n "${CONTAINER}" --clear-env \
            -v "USER=${user}" \
            -v "LOGNAME=${user}" \
            -v "HOME=/home/${user}" \
            -v "LANG=C.UTF-8" \
            -v "XDG_RUNTIME_DIR=${runtime_dir}" \
            -v "BATOCERA_ARCH_PLASMA_SESSION_TYPE=${PLASMA_SESSION_TYPE}" \
            -v "KWIN_DRM_DEVICES=${BATOCERA_ARCH_PLASMA_DRM_DEVICES:-/dev/dri/card0}" \
            -v "LIBSEAT_BACKEND=seatd" \
            -v "SEATD_SOCK=/batocera-runtime/seatd.sock" \
            -v "PIPEWIRE_REMOTE=/batocera-runtime/pipewire-0" \
            -v "PULSE_SERVER=unix:/batocera-runtime/pulse/native" \
            -v "BATOCERA_ARCH_PLASMA_OUTPUT_SCALE=${BATOCERA_ARCH_PLASMA_OUTPUT_SCALE:-}" \
            -- /usr/bin/runuser -u "${user}" --preserve-environment -- /usr/local/bin/batocera-start-plasma
    fi
}

cleanup_session() {
    local rc=$?
    if [ "${CLEANUP_DONE:-0}" = "1" ]; then
        exit "${rc}"
    fi
    CLEANUP_DONE=1
    trap - EXIT INT TERM

    set +e
    load_state
    log "Arch Plasma session exited with status ${rc}"
    terminate_plasma_session "${PLASMA_USER}"
    if command -v batocera-mouse >/dev/null 2>&1; then
        batocera-mouse hide >/dev/null 2>&1 || true
    fi
    restore_frontend
    recover_frontend_with_supervisor
    exit "${rc}"
}

run_session() {
    load_state

    if ! container_ready; then
        die "container is not installed yet; launch from Ports once to run setup"
    fi

    detach_from_frontend_session --session

    trap cleanup_session EXIT INT TERM
    stop_frontend_for_drm
    clear_session_display_env
    start_session_supervisor
    launch_plasma_session "${PLASMA_USER}"
}

terminal_setup_then_launch() {
    load_state
    prompt_credentials
    if ! run_with_visible_log install_or_update_container; then
        printf '\n%s\n' "Arch Plasma LXC setup failed."
        printf '%s\n' "The last log lines are shown above and saved in ${LOG}."
        printf '%s' "Press Enter to close..."
        read -r _ || true
        return 1
    fi
    install_launcher

    printf '%s\n' "Arch Plasma is installed."
    printf '%s\n' "Relaunch Arch Plasma LXC from the launcher to start the desktop."
    sleep 8
}

run_with_visible_log() {
    local rc
    local tail_pid=""

    prepare_setup_log
    clear 2>/dev/null || true
    printf '%s\n' "Arch Plasma LXC setup is running."
    printf '%s\n' "This can take a while while the Arch image and Plasma packages download."
    printf '%s\n\n' "Live log: ${LOG}"

    tail -n 40 -f "${LOG}" &
    tail_pid="$!"

    set +e
    "$@"
    rc="$?"
    set -e

    kill "${tail_pid}" 2>/dev/null || true
    wait "${tail_pid}" 2>/dev/null || true
    printf '\n'

    return "${rc}"
}

ensure_setup_terminal() {
    if have_tty; then
        terminal_setup_then_launch
        return
    fi

    if [ -z "${DISPLAY:-}" ] && command -v getLocalXDisplay >/dev/null 2>&1; then
        export DISPLAY="$(getLocalXDisplay)"
    fi

    command -v xterm >/dev/null 2>&1 || die "xterm is required for first-run setup when no tty is attached"
    exec xterm -fullscreen -bg black -fg white -fa "DejaVu Sans Mono" -fs 12 \
        -T "Arch Plasma LXC setup" -e /bin/bash -lc '
            script="$1"
            "$script" --setup-terminal
            rc="$?"
            if [ "$rc" -ne 0 ]; then
                clear
                printf "%s\n\n" "Arch Plasma LXC setup failed with exit code ${rc}."
                printf "%s\n\n" "Last log lines from /userdata/system/logs/arch-plasma-lxc.log:"
                tail -120 /userdata/system/logs/arch-plasma-lxc.log 2>/dev/null || true
                printf "\n%s" "Press Enter to close..."
                read -r _ || true
            fi
            exit "$rc"
        ' bash "$0"
}

install_launcher() {
    mkdir -p "${PORTS_DIR}"
    cat > "${LAUNCHER}" <<EOF
#!/bin/bash
set -euo pipefail
exec /usr/bin/batocera-arch-plasma-lxc "\$@"
EOF
    chmod 0755 "${LAUNCHER}"

    if [ ! -f "${GAMELIST}" ]; then
        printf '<gameList>\n</gameList>\n' > "${GAMELIST}"
    fi

    if ! grep -q '<path>\./Start_Arch_Plasma_LXC\.sh</path>' "${GAMELIST}"; then
        tmp="$(mktemp)"
        awk '
            /<\/gameList>/ && !done {
                print "\t<game>"
                print "\t\t<path>./Start_Arch_Plasma_LXC.sh</path>"
                print "\t\t<name>Arch Plasma LXC</name>"
                print "\t\t<desc>Launches an Arch Linux KDE Plasma desktop in LXC with direct KWin DRM rendering.</desc>"
                print "\t\t<image>./images/arch-plasma-lxc.svg</image>"
                print "\t\t<thumbnail>./images/arch-plasma-lxc.svg</thumbnail>"
                print "\t\t<genre>Desktop</genre>"
                print "\t\t<lang>en</lang>"
                print "\t</game>"
                done=1
            }
            { print }
        ' "${GAMELIST}" > "${tmp}"
        mv "${tmp}" "${GAMELIST}"
    fi

    sed -i \
        's#<desc>Launches an Arch Linux KDE Plasma desktop in LXC through a Batocera Gamescope DRM session\.</desc>#<desc>Launches an Arch Linux KDE Plasma desktop in LXC with direct KWin DRM rendering.</desc>#' \
        "${GAMELIST}" 2>/dev/null || true

    # Leave the running frontend alone. The gamelist entry is written directly;
    # ES will pick it up on the next normal refresh/restart.
}

usage() {
    cat <<EOF
usage: $0 [--install-launcher|--repair-config|--provision-from-state|--setup-terminal|--configure|--session|--help]

Default mode installs/configures the Arch Plasma container if needed, then
starts a direct KWin DRM session and restores EmulationStation on exit.
EOF
}

case "${1:-}" in
    --install-launcher)
        install_launcher
        ;;
    --repair-config)
        repair_existing_container_config
        ;;
    --provision-from-state)
        provision_from_saved_state
        ;;
    --setup-terminal|--configure)
        terminal_setup_then_launch
        ;;
    --session)
        run_session
        ;;
    --help|-h)
        usage
        ;;
    "")
        install_launcher
        if container_ready; then
            run_session
        else
            ensure_setup_terminal
        fi
        ;;
    *)
        usage >&2
        exit 2
        ;;
esac
