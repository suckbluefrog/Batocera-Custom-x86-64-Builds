cp -f /usr/share/applications/batocera-return-to-es.desktop "/home/${PLASMA_USER}/Desktop/Return to Batocera.desktop"
chmod 0755 /usr/share/applications/batocera-return-to-es.desktop "/home/${PLASMA_USER}/Desktop/Return to Batocera.desktop"
chown "${PLASMA_USER}:${PLASMA_USER}" "/home/${PLASMA_USER}/Desktop/Return to Batocera.desktop" 2>/dev/null || true

cat > /usr/share/applications/batocera-switch-plasma-mobile.desktop <<'EOS'
[Desktop Entry]
Type=Application
