pacman_retry() {
    local attempt

    for attempt in 1 2 3; do
        write_pacman_mirrorlist "${attempt}"
        printf 'pacman transaction attempt %s/3\n' "${attempt}"
        if pacman "$@"; then
            return 0
        fi
        rm -f /var/cache/pacman/pkg/*.part /var/lib/pacman/sync/*.part 2>/dev/null || true
        sleep "$((attempt * 2))"
    done

    return 1
}

