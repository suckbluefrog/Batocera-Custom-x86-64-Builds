#!/bin/bash
set -euo pipefail

session_type="${BATOCERA_ARCH_PLASMA_SESSION_TYPE:-x11}"

export KDE_FULL_SESSION=true
export NO_AT_BRIDGE=1
export LIBSEAT_BACKEND="${LIBSEAT_BACKEND:-seatd}"
export SEATD_SOCK="${SEATD_SOCK:-/batocera-runtime/seatd.sock}"
export PIPEWIRE_REMOTE="${PIPEWIRE_REMOTE:-pipewire-0}"
export PULSE_SERVER="${PULSE_SERVER:-unix:${XDG_RUNTIME_DIR}/pulse/native}"
export XDG_DATA_DIRS="${HOME}/.local/share/flatpak/exports/share:/var/lib/flatpak/exports/share:${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"

mkdir -p "${HOME}/.config" "${HOME}/.local/share" "${XDG_RUNTIME_DIR}" "${XDG_RUNTIME_DIR}/pulse"
chmod 700 "${XDG_RUNTIME_DIR}" 2>/dev/null || true

# runuser/PAM starts systemd --user in /run/user/$UID, while KWin and Plasma
# intentionally share Batocera's private runtime and D-Bus. Expose only the
# user-manager control socket in the private runtime so systemctl --user works
# from Konsole without moving the desktop off its shared session bus.
standard_runtime="/run/user/$(id -u)"
if [ "${XDG_RUNTIME_DIR}" != "${standard_runtime}" ] && \
        [ ! -e "${XDG_RUNTIME_DIR}/systemd" ] && \
        [ ! -L "${XDG_RUNTIME_DIR}/systemd" ]; then
    ln -s "${standard_runtime}/systemd" "${XDG_RUNTIME_DIR}/systemd" 2>/dev/null || true
fi

if [ -e /batocera-runtime/host-gpu/libEGL_mesa.so.0 ]; then
    export LD_LIBRARY_PATH="/batocera-runtime/host-gpu${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
    export LIBGL_DRIVERS_PATH=/batocera-host/usr/lib/dri
    export GBM_BACKENDS_PATH=/batocera-host/usr/lib/gbm
fi

case "${session_type}" in
    wayland)
        export XDG_SESSION_TYPE=wayland
        export XDG_CURRENT_DESKTOP=KDE
        export XDG_SESSION_DESKTOP=KDE
        export DESKTOP_SESSION=plasmawayland
        export QT_QPA_PLATFORM=wayland
        export GDK_BACKEND=wayland,x11
        export SDL_VIDEODRIVER=wayland
        export CLUTTER_BACKEND=wayland
        export MOZ_ENABLE_WAYLAND=1
        export KWIN_DRM_DEVICES="${KWIN_DRM_DEVICES:-/dev/dri/card0}"
        unset DISPLAY
        unset XAUTHORITY
        if command -v dbus-run-session >/dev/null 2>&1; then
            exec dbus-run-session -- startplasma-wayland
        fi
        exec startplasma-wayland
        ;;
    x11)
        export XDG_SESSION_TYPE=x11
        export XDG_CURRENT_DESKTOP=KDE
        export XDG_SESSION_DESKTOP=KDE
        export DESKTOP_SESSION=plasma
        export QT_QPA_PLATFORM=xcb
        export GDK_BACKEND=x11
        export SDL_VIDEODRIVER=x11
        unset WAYLAND_DISPLAY
        if command -v dbus-run-session >/dev/null 2>&1; then
            exec dbus-run-session -- startplasma-x11
        fi
        exec startplasma-x11
        ;;
    *)
        printf 'unsupported Plasma session type: %s\n' "${session_type}" >&2
        exit 2
        ;;
esac
EOS
