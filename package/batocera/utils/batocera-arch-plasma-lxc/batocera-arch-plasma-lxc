    local user="$1"
    local password="$2"

    wait_for_container_command

    log "provisioning ${PLASMA_LABEL} packages"
    lxc-attach -P "${LXC_PATH}" -n "${CONTAINER}" --clear-env \
        -v "PLASMA_USER=${user}" -v "PLASMA_PASSWORD=${password}" -- /bin/bash -s >>"${LOG}" 2>&1 <<'EOF'
