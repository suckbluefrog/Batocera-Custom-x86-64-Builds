#!/bin/bash
set -u

selector="${BATOCERA_ARCH_PLASMA_FORCE_OUTPUT:-}"
mode="${BATOCERA_ARCH_PLASMA_FORCE_OUTPUT_MODE:-}"
fallback_mode="${BATOCERA_ARCH_PLASMA_FORCE_OUTPUT_MODE_FALLBACK:-}"
disable_others="${BATOCERA_ARCH_PLASMA_DISABLE_OTHER_OUTPUTS:-0}"
log="${BATOCERA_ARCH_PLASMA_LAYOUT_LOG:-/batocera-runtime/plasma-output-layout.log}"

[ -n "${selector}${mode}${fallback_mode}" ] || exit 0
command -v kscreen-doctor >/dev/null 2>&1 || exit 0

find_kscreen_output_id() {
    local output_file="$1"
    local pattern="$2"

    [ -n "${pattern}" ] || return 1

    awk -v pattern="${pattern}" '
        BEGIN {
            pattern = tolower(pattern)
        }
        /^Output: / {
            if (id != "" && found) {
                print id
                exit
            }
            id = $2
            found = (index(tolower($0), pattern) > 0)
            next
        }
        id != "" && index(tolower($0), pattern) > 0 {
            found = 1
        }
        END {
            if (id != "" && found) {
                print id
            }
        }
    ' "${output_file}" | head -n 1
}

find_largest_kscreen_output_id() {
    local output_file="$1"

    awk '
        /^Output: / {
            id = $2
            connected = 0
            next
        }
        id != "" && /^[[:space:]]*connected/ {
            connected = 1
            next
        }
        id != "" && /^[[:space:]]*(Modes:|Geometry:)/ {
            line = $0
            while (match(line, /[0-9]+x[0-9]+/)) {
                split(substr(line, RSTART, RLENGTH), dims, "x")
                area = dims[1] * dims[2]
                if (connected && area > best_area) {
                    best_area = area
                    best_id = id
                }
                line = substr(line, RSTART + RLENGTH)
            }
        }
        END {
            if (best_id != "") {
                print best_id
            }
        }
    ' "${output_file}" | head -n 1
}

apply_forced_output_layout_once() {
    local output_file output_ids output_id target_id=""

    output_file="/tmp/batocera-kscreen-layout-user-$$.out"
    NO_COLOR=1 TERM=dumb kscreen-doctor -o 2>&1 | sed -E 's/\x1B\[[0-9;]*[[:alpha:]]//g' > "${output_file}" || {
        cat "${output_file}" 2>/dev/null || true
        rm -f "${output_file}" 2>/dev/null || true
        return 1
    }

    printf '%s\n' "--- kscreen-doctor -o ---"
    cat "${output_file}" 2>/dev/null || true

    if [ "${selector}" = "largest" ] || [ "${selector}" = "top" ]; then
        target_id="$(find_largest_kscreen_output_id "${output_file}" 2>/dev/null || true)"
    fi
    [ -n "${target_id}" ] || target_id="$(find_kscreen_output_id "${output_file}" "${mode}" 2>/dev/null || true)"
    [ -n "${target_id}" ] || target_id="$(find_kscreen_output_id "${output_file}" "${fallback_mode}" 2>/dev/null || true)"
    [ -n "${target_id}" ] || target_id="$(find_kscreen_output_id "${output_file}" "${selector}" 2>/dev/null || true)"
    output_ids="$(awk '/^Output: / { print $2 }' "${output_file}" 2>/dev/null || true)"
    rm -f "${output_file}" 2>/dev/null || true

    [ -n "${target_id}" ] || {
        printf 'no matching output found for selector=%s mode=%s fallback=%s\n' "${selector}" "${mode}" "${fallback_mode}"
        return 1
    }

    printf 'forcing output id=%s selector=%s mode=%s fallback=%s disable_others=%s\n' \
        "${target_id}" "${selector}" "${mode}" "${fallback_mode}" "${disable_others}"

    kscreen-doctor "output.${target_id}.enable" >/dev/null 2>&1 || true
    if [ -n "${mode}" ]; then
        kscreen-doctor "output.${target_id}.mode.${mode}" >/dev/null 2>&1 || \
            { [ -n "${fallback_mode}" ] && kscreen-doctor "output.${target_id}.mode.${fallback_mode}" >/dev/null 2>&1; } || true
    elif [ -n "${fallback_mode}" ]; then
        kscreen-doctor "output.${target_id}.mode.${fallback_mode}" >/dev/null 2>&1 || true
    fi
    kscreen-doctor "output.${target_id}.position.0,0" >/dev/null 2>&1 || true
    kscreen-doctor "output.${target_id}.primary" >/dev/null 2>&1 || true

    if [ "${disable_others}" = "1" ]; then
        for output_id in ${output_ids}; do
            [ "${output_id}" != "${target_id}" ] || continue
            printf 'disabling output id=%s\n' "${output_id}"
            kscreen-doctor "output.${output_id}.disable" >/dev/null 2>&1 || true
        done
    fi
}

mkdir -p "$(dirname "${log}")" 2>/dev/null || true
: > "${log}" 2>/dev/null || true
for _ in $(seq 1 90); do
    apply_forced_output_layout_once >> "${log}" 2>&1 || true
    sleep 1
done

exit 0
EOS
chmod 0755 /usr/local/bin/batocera-force-plasma-output

cat > /usr/local/bin/batocera-plasma-session-payload <<'EOS'
#!/bin/bash
set -euo pipefail

if [ "${BATOCERA_PLASMA_SHARED_DBUS:-0}" != "1" ] && \
        [ "${1:-}" != "--inside-dbus" ] && command -v dbus-run-session >/dev/null 2>&1; then
    # runuser/PAM may inject the systemd user bus without importing this raw
    # KWin session's Wayland environment. Services activated on that stale bus
    # then start without a display and Plasma aborts loading the desktop.
    unset DBUS_SESSION_BUS_ADDRESS
    exec dbus-run-session -- "$0" --inside-dbus
fi

export LANG="${LANG:-C.UTF-8}"
if [ "${LANG}" = "C" ] || [ "${LANG}" = "POSIX" ]; then
    export LANG=C.UTF-8
fi
export LC_ALL="${LC_ALL:-${LANG}}"
if [ "${LC_ALL}" = "C" ] || [ "${LC_ALL}" = "POSIX" ]; then
    export LC_ALL="${LANG}"
fi
export KDE_FULL_SESSION=true
export NO_AT_BRIDGE=1
export XDG_SESSION_TYPE=wayland
export XDG_CURRENT_DESKTOP=KDE
export XDG_SESSION_DESKTOP=KDE
export XDG_MENU_PREFIX=plasma-
export DESKTOP_SESSION=plasmawayland
export QT_QPA_PLATFORM=wayland
export GDK_BACKEND=wayland,x11
export SDL_VIDEODRIVER=wayland
export CLUTTER_BACKEND=wayland
export MOZ_ENABLE_WAYLAND=1
export PIPEWIRE_REMOTE="${PIPEWIRE_REMOTE:-/batocera-runtime/pipewire-0}"
export PULSE_SERVER="${PULSE_SERVER:-unix:/batocera-runtime/pulse/native}"

mkdir -p "${HOME}/.config" "${HOME}/.local/share" "${XDG_RUNTIME_DIR}" "${XDG_RUNTIME_DIR}/pulse"
chmod 700 "${XDG_RUNTIME_DIR}" 2>/dev/null || true

# runuser/PAM starts systemd --user in /run/user/$UID, while KWin and Plasma
# intentionally share Batocera's private runtime and D-Bus. Expose only the
# user-manager control socket in the private runtime so systemctl --user works
# from Konsole without moving the desktop off its shared session bus.
standard_runtime="/run/user/$(id -u)"
if [ "${XDG_RUNTIME_DIR}" != "${standard_runtime}" ] && \
        [ ! -e "${XDG_RUNTIME_DIR}/systemd" ] && \
        [ ! -L "${XDG_RUNTIME_DIR}/systemd" ]; then
    ln -s "${standard_runtime}/systemd" "${XDG_RUNTIME_DIR}/systemd" 2>/dev/null || true
fi

seed_input_defaults() {
    local pointer_accel="${BATOCERA_ARCH_PLASMA_POINTER_ACCEL:-}"

    [ -n "${pointer_accel}" ] || return 0

    if [ ! -f "${HOME}/.config/kcminputrc" ]; then
        {
            printf '[Mouse]\n'
            printf '\n[Libinput][defaults]\n'
            printf 'PointerAcceleration=%s\n' "${pointer_accel}"
            printf 'PointerAccelerationProfile=1\n'
        } > "${HOME}/.config/kcminputrc"
    fi
}

run_if_available() {
    command -v "$1" >/dev/null 2>&1 || return 0
    "$@" &
}

run_first_available() {
    local candidate

    for candidate in "$@"; do
        if [ -x "${candidate}" ] || command -v "${candidate}" >/dev/null 2>&1; then
            "${candidate}" &
            return 0
        fi
    done
}

wait_for_session_bus_name() {
    local name="$1"

    [ -n "${DBUS_SESSION_BUS_ADDRESS:-}" ] || return 1
    command -v busctl >/dev/null 2>&1 || return 1
    for _ in $(seq 1 50); do
        if busctl --address="${DBUS_SESSION_BUS_ADDRESS}" --no-pager list 2>/dev/null | \
                awk -v wanted="${name}" '$1 == wanted { found=1 } END { exit !found }'; then
            return 0
        fi
        sleep 0.1
    done
    return 1
}

start_portal_services() {
    # These binaries live outside PATH on both Arch and Ubuntu. Start the KDE
    # backend first, on the same private bus and Wayland display as Plasma, so
    # the frontend discovers Settings/FileChooser/OpenURI at initialization.
    run_first_available \
        /usr/lib/xdg-desktop-portal-kde \
        /usr/libexec/xdg-desktop-portal-kde \
        /usr/lib/*-linux-gnu/libexec/xdg-desktop-portal-kde \
        /usr/lib/*/libexec/xdg-desktop-portal-kde \
        xdg-desktop-portal-kde
    wait_for_session_bus_name org.freedesktop.impl.portal.desktop.kde || true
    run_first_available \
        /usr/lib/xdg-desktop-portal \
        /usr/libexec/xdg-desktop-portal \
        /usr/lib/*-linux-gnu/libexec/xdg-desktop-portal \
        /usr/lib/*/libexec/xdg-desktop-portal \
        xdg-desktop-portal
    wait_for_session_bus_name org.freedesktop.portal.Desktop || true
}

start_polkit_agent() {
    local agent

    for agent in \
        /usr/lib/polkit-kde-authentication-agent-1 \
        /usr/libexec/polkit-kde-authentication-agent-1 \
        /usr/lib/*-linux-gnu/libexec/polkit-kde-authentication-agent-1 \
        /usr/lib/*/libexec/polkit-kde-authentication-agent-1 \
        polkit-kde-authentication-agent-1
    do
        if [ -x "${agent}" ] || command -v "${agent}" >/dev/null 2>&1; then
            "${agent}" &
            return 0
        fi
    done
}

start_plasma_shell_session() {
    local initial_shell_pid missing_count=0

    start_portal_services
    start_polkit_agent
    run_if_available kded6
    run_first_available kactivitymanagerd /usr/lib/kactivitymanagerd /usr/libexec/kactivitymanagerd \
        /usr/lib/*-linux-gnu/libexec/kactivitymanagerd /usr/lib/*/libexec/kactivitymanagerd
    run_first_available kglobalacceld /usr/lib/kglobalacceld /usr/libexec/kglobalacceld \
        /usr/lib/*-linux-gnu/libexec/kglobalacceld /usr/lib/*/libexec/kglobalacceld
    run_if_available batocera-force-plasma-output

    # Plasma Mobile is available through the desktop shortcut, but every new
    # session must start with the conventional desktop shell.
    plasmashell -p org.kde.plasma.desktop &
    initial_shell_pid="$!"

    # KWin's --exit-with-session watches this payload. Keep it alive while a
    # replacement desktop/mobile plasmashell owns the session, and exit only
    # after every plasmashell has been gone for a short grace period.
    while :; do
        if [ -e "${XDG_RUNTIME_DIR}/batocera-return-to-es" ]; then
            break
        fi
        if pgrep -u "$(id -u)" -x plasmashell >/dev/null 2>&1; then
            missing_count=0
        else
            missing_count=$((missing_count + 1))
            [ "${missing_count}" -lt 10 ] || break
        fi
        sleep 0.2
    done

    wait "${initial_shell_pid}" 2>/dev/null || true
}

trap 'jobs -pr | xargs -r kill 2>/dev/null || true' EXIT INT TERM

rm -f "${XDG_RUNTIME_DIR}/batocera-return-to-es" 2>/dev/null || true
seed_input_defaults

start_plasma_shell_session
EOS
chmod 0755 /usr/local/bin/batocera-plasma-session-payload

cat > /usr/local/bin/batocera-return-to-es <<'EOS'
#!/bin/bash
set +e

uid="$(id -u)"
marker="${XDG_RUNTIME_DIR:-/run/user/${uid}}/batocera-return-to-es"
: > "${marker}" 2>/dev/null || true
pkill -TERM -u "${uid}" -x plasmashell 2>/dev/null || true
for _ in $(seq 1 50); do
    pgrep -u "${uid}" -f 'batocera-plasma-session-payload' >/dev/null 2>&1 || exit 0
    sleep 0.1
done
pkill -TERM -u "${uid}" -f 'batocera-plasma-session-payload' 2>/dev/null || true
EOS
chmod 0755 /usr/local/bin/batocera-return-to-es

cat > /usr/local/bin/batocera-plasma-shell-mode <<'EOS'
#!/bin/bash
set -euo pipefail

mode="${1:-}"
mobile_config="${HOME}/.config/plasma-mobile"
log_file="${XDG_RUNTIME_DIR:-/tmp}/batocera-plasma-shell-mode.log"

strip_mobile_config_dir() {
    local value entry result="" old_ifs

    value="${XDG_CONFIG_DIRS:-/etc/xdg}"
    old_ifs="${IFS}"
    IFS=:
    for entry in ${value}; do
        [ -n "${entry}" ] || continue
        [ "${entry}" = "${mobile_config}" ] && continue
        result="${result:+${result}:}${entry}"
    done
    IFS="${old_ifs}"
    printf '%s\n' "${result:-/etc/xdg}"
}

command -v plasmashell >/dev/null 2>&1 || exit 127
desktop_config_dirs="$(strip_mobile_config_dir)"

case "${mode}" in
    mobile)
        [ -d /usr/share/plasma/shells/org.kde.plasma.mobileshell ] || {
            command -v kdialog >/dev/null 2>&1 && kdialog --error 'Plasma Mobile is not installed.'
            exit 1
        }
        install -d -m 0700 "${mobile_config}"
        mobile_config_dirs="${mobile_config}:${desktop_config_dirs}"
        if command -v plasma-mobile-envmanager >/dev/null 2>&1; then
            env QT_QPA_PLATFORM=offscreen \
                XDG_CONFIG_DIRS="${mobile_config_dirs}" \
                plasma-mobile-envmanager --apply-settings >>"${log_file}" 2>&1 || true
        fi
        nohup env \
            QT_QPA_PLATFORMTHEME=KDE \
            EGL_PLATFORM=wayland \
            QT_QUICK_CONTROLS_STYLE=org.kde.breeze \
            QT_ENABLE_GLYPH_CACHE_WORKAROUND=1 \
            QT_QUICK_CONTROLS_MOBILE=true \
            PLASMA_INTEGRATION_USE_PORTAL=1 \
            PLASMA_PLATFORM=phone:handset \
            PLASMA_DEFAULT_SHELL=org.kde.plasma.mobileshell \
            XDG_CONFIG_DIRS="${mobile_config_dirs}" \
            plasmashell -p org.kde.plasma.mobileshell --replace >>"${log_file}" 2>&1 &
        ;;
    desktop)
        [ -d /usr/share/plasma/shells/org.kde.plasma.desktop ] || exit 1
        nohup env \
            -u EGL_PLATFORM \
            -u QT_QUICK_CONTROLS_STYLE \
            -u QT_ENABLE_GLYPH_CACHE_WORKAROUND \
            -u QT_QUICK_CONTROLS_MOBILE \
            -u PLASMA_INTEGRATION_USE_PORTAL \
            -u PLASMA_PLATFORM \
            QT_QPA_PLATFORMTHEME=KDE \
            PLASMA_DEFAULT_SHELL=org.kde.plasma.desktop \
            XDG_CONFIG_DIRS="${desktop_config_dirs}" \
            plasmashell -p org.kde.plasma.desktop --replace >>"${log_file}" 2>&1 &
        ;;
    *)
        printf 'usage: %s {mobile|desktop}\n' "$0" >&2
        exit 2
        ;;
esac
EOS
chmod 0755 /usr/local/bin/batocera-plasma-shell-mode

install -d -m 0755 /usr/share/applications /host
install -d -m 0755 -o "${PLASMA_USER}" -g "${PLASMA_USER}" "/home/${PLASMA_USER}/Desktop"
[ -e /host/userdata ] || install -d -m 0755 /host/userdata
ln -sfn /host/userdata "/home/${PLASMA_USER}/Host userdata"
ln -sfn /host/userdata "/home/${PLASMA_USER}/Desktop/Host userdata"
chown -h "${PLASMA_USER}:${PLASMA_USER}" "/home/${PLASMA_USER}/Host userdata" "/home/${PLASMA_USER}/Desktop/Host userdata" 2>/dev/null || true
if [ -f /etc/xdg/menus/plasma-applications.menu ] && [ ! -e /etc/xdg/menus/applications.menu ]; then
    ln -s plasma-applications.menu /etc/xdg/menus/applications.menu
