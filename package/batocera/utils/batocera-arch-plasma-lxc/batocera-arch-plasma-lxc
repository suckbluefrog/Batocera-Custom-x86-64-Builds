stop_thor_touch_mouse_bridge() {
    local pid pidfile

    is_ayn_thor || is_ayn_odin || return 0
    pidfile="${HOST_RUNTIME_DIR}/thor-touch-mouse.pid"

    if [ -s "${pidfile}" ]; then
        pid="$(cat "${pidfile}" 2>/dev/null || true)"
        if [ -n "${pid}" ] && [ -d "/proc/${pid}" ] && tr '\0' ' ' < "/proc/${pid}/cmdline" 2>/dev/null | grep -q 'thor-touch-mouse.py'; then
            kill "${pid}" 2>/dev/null || true
            for _ in $(seq 1 20); do
                [ ! -d "/proc/${pid}" ] && break
                sleep 0.1
            done
            [ -d "/proc/${pid}" ] && kill -KILL "${pid}" 2>/dev/null || true
        fi
    fi

    pgrep -f "${HOST_RUNTIME_DIR}/thor-touch-mouse.py" 2>/dev/null | while read -r pid; do
        [ -n "${pid}" ] || continue
        kill "${pid}" 2>/dev/null || true
    done
    rm -f "${pidfile}" 2>/dev/null || true
}

synthesize_thor_touch_mouse_udev_record() {
    local udev_root="$1"
    local event_sys device name devnode hex_major hex_minor major minor input_name data_dir

    is_ayn_thor || is_ayn_odin || return 0
    [ -d "${udev_root}/data" ] || return 0

    for event_sys in /sys/class/input/event*; do
        [ -e "${event_sys}" ] || continue
        device="$(readlink -f "${event_sys}/device" 2>/dev/null || true)"
        [ -n "${device}" ] || continue
        name="$(cat "${device}/name" 2>/dev/null || true)"
        [ "${name}" = "thor-top-touch-mouse" ] || continue
        devnode="/dev/input/${event_sys##*/}"
        [ -e "${devnode}" ] || continue
        read -r hex_major hex_minor <<EOF
$(stat -c '%t %T' "${devnode}" 2>/dev/null)
EOF
        major="$((16#${hex_major}))"
        minor="$((16#${hex_minor}))"
        input_name="$(basename "${device}")"
        data_dir="${udev_root}/data"
        {
            printf 'E:DEVNAME=%s\n' "${devnode}"
            printf 'E:ID_INPUT=1\n'
            printf 'E:ID_INPUT_MOUSE=1\n'
            printf 'E:LIBINPUT_DEVICE_GROUP=3/1/1:thor-top-touch-mouse\n'
        } > "${data_dir}/c${major}:${minor}"
        {
            printf 'E:ID_INPUT=1\n'
            printf 'E:ID_INPUT_MOUSE=1\n'
            printf 'E:LIBINPUT_DEVICE_GROUP=3/1/1:thor-top-touch-mouse\n'
        } > "${data_dir}/+input:${input_name}"
        log "added AYN pointer bridge udev record for ${devnode}"
        return 0
    done
}

sync_udev_database() {
    local matrix

    [ -d /run/udev/data ] || return 0

    rm -rf "${HOST_RUNTIME_DIR}/udev.new" "${HOST_RUNTIME_DIR}/udev.old" 2>/dev/null || true
    mkdir -p "${HOST_RUNTIME_DIR}/udev.new"

    cp -a /run/udev/data "${HOST_RUNTIME_DIR}/udev.new/" 2>/dev/null || return 0
    for name in links tags static_node-tags rules.d; do
        [ -e "/run/udev/${name}" ] || continue
        cp -a "/run/udev/${name}" "${HOST_RUNTIME_DIR}/udev.new/" 2>/dev/null || true
    done
    synthesize_thor_touch_mouse_udev_record "${HOST_RUNTIME_DIR}/udev.new"

    matrix="$(touch_calibration_matrix 2>/dev/null || true)"
    apply_touch_calibration_to_udev_tree "${HOST_RUNTIME_DIR}/udev.new" "${matrix}"
    apply_touch_keep_pattern_to_udev_tree "${HOST_RUNTIME_DIR}/udev.new"

    if [ -d "${HOST_RUNTIME_DIR}/udev" ]; then
        mv "${HOST_RUNTIME_DIR}/udev" "${HOST_RUNTIME_DIR}/udev.old" 2>/dev/null || true
    fi
    mv "${HOST_RUNTIME_DIR}/udev.new" "${HOST_RUNTIME_DIR}/udev" 2>/dev/null || true
    rm -rf "${HOST_RUNTIME_DIR}/udev.old" "${HOST_RUNTIME_DIR}/udev.new" 2>/dev/null || true
}

configure_lxc() {
    local cfg tmp
    cfg="$(container_config)"
    [ -f "${cfg}" ] || die "missing LXC config at ${cfg}"

    tmp="$(mktemp)"
    if tr -d '\000' < "${cfg}" > "${tmp}" 2>/dev/null; then
        if ! cmp -s "${cfg}" "${tmp}" 2>/dev/null; then
            cat "${tmp}" > "${cfg}"
            log "removed NUL bytes from LXC config ${cfg}"
        fi
    fi
    rm -f "${tmp}" 2>/dev/null || true

    sed -i '/# BEGIN batocera arch plasma/,/# END batocera arch plasma/d' "${cfg}"
    sed -i '/^[[:space:]]*lxc\.apparmor\./d' "${cfg}"

    cat >> "${cfg}" <<EOF

# BEGIN batocera arch plasma
# Bubblewrap needs uncovered proc/sys mounts so an unprivileged user namespace
# can remount them. Do not include LXC's nesting.conf: Batocera builds LXC
# without AppArmor support, so its lxc.apparmor.profile line is invalid here.
# Flatpak also asks Bubblewrap to disable deeper user namespaces from inside its
# first user namespace. That requires proc/sys/user to be writable there;
# LXC's default proc:mixed mount makes the sysctl read-only.
lxc.mount.auto = proc:rw
lxc.mount.entry = proc dev/.lxc/proc proc create=dir,optional 0 0
lxc.mount.entry = sys dev/.lxc/sys sysfs create=dir,optional 0 0
lxc.cap.drop =
lxc.cgroup2.devices.allow = c 4:* rwm
lxc.cgroup2.devices.allow = c 10:* rwm
lxc.cgroup2.devices.allow = c 13:* rwm
lxc.cgroup2.devices.allow = c 29:* rwm
lxc.cgroup2.devices.allow = c 116:* rwm
lxc.cgroup2.devices.allow = c 226:* rwm
lxc.mount.entry = /dev/dri dev/dri none rbind,optional,create=dir 0 0
lxc.mount.entry = /dev/input dev/input none rbind,optional,create=dir 0 0
lxc.mount.entry = /dev/snd dev/snd none rbind,optional,create=dir 0 0
lxc.mount.entry = /dev/tty0 dev/tty0 none bind,optional,create=file 0 0
lxc.mount.entry = /dev/fuse dev/fuse none bind,optional,create=file 0 0
lxc.mount.entry = ${HOST_RESOLV_CONF} etc/resolv.conf none bind,ro,optional,create=file 0 0
lxc.mount.entry = /tmp/.X11-unix tmp/.X11-unix none rbind,optional,create=dir 0 0
lxc.mount.entry = ${HOST_RUNTIME_DIR} ${CONTAINER_RUNTIME_DIR#/} none rbind,optional,create=dir 0 0
lxc.mount.entry = /usr/lib ${CONTAINER_HOST_LIB_DIR#/} none rbind,ro,optional,create=dir 0 0
lxc.mount.entry = ${HOST_USERDATA_DIR} ${CONTAINER_HOST_USERDATA#/} none rbind,optional,create=dir 0 0
lxc.mount.entry = /run/seatd.sock ${CONTAINER_RUNTIME_DIR#/}/seatd.sock none bind,optional,create=file 0 0
lxc.mount.entry = /run/pipewire-0 ${CONTAINER_RUNTIME_DIR#/}/pipewire-0 none bind,optional,create=file 0 0
lxc.mount.entry = /run/pipewire-0-manager ${CONTAINER_RUNTIME_DIR#/}/pipewire-0-manager none bind,optional,create=file 0 0
lxc.mount.entry = /run/pulse/native ${CONTAINER_RUNTIME_DIR#/}/pulse/native none bind,optional,create=file 0 0
# END batocera arch plasma
EOF
}

configure_container_dns() {
    local rootfs resolv

    rootfs="$(container_rootfs)"

    mkdir -p "$(dirname "${HOST_RESOLV_CONF}")"
    # Keep this inode stable while it is bind-mounted into a running
    # container. Replacing it with mv leaves LXC attached to a deleted inode,
    # which makes nested Bubblewrap mounts (including Flatpak extra-data
    # helpers such as Chrome's apply_extra) fail.
    {
        printf 'nameserver 1.1.1.1\n'
        printf 'nameserver 8.8.8.8\n'
        printf 'nameserver 10.0.3.1\n'
        printf 'options timeout:2 attempts:5 single-request-reopen\n'
    } > "${HOST_RESOLV_CONF}" 2>>"${LOG}" || true
    chmod 0644 "${HOST_RESOLV_CONF}" 2>/dev/null || true

    [ -d "${rootfs}/etc" ] || return 0

    resolv="${rootfs}/etc/resolv.conf"
    if [ -L "${resolv}" ] && [ ! -e "${resolv}" ]; then
        rm -f "${resolv}" 2>/dev/null || true
    fi

    cp -f "${HOST_RESOLV_CONF}" "${resolv}" 2>>"${LOG}" || true
    chmod 0644 "${resolv}" 2>/dev/null || true
}

download_rootfs_image() {
    local image_tmp="$1"
    local url index_tmp latest_dir dynamic_url

    for url in ${PLASMA_ROOTFS_URL} ${PLASMA_ROOTFS_FALLBACK_URLS}; do
        [ -n "${url}" ] || continue
        log "downloading ${PLASMA_DIST} rootfs from ${url}"
        rm -f "${image_tmp}"
        if curl -fL --retry 3 --retry-delay 2 --connect-timeout 30 \
                --speed-time 60 --speed-limit 1024 \
                "${url}" -o "${image_tmp}" >>"${LOG}" 2>&1; then
            if unsquashfs -s "${image_tmp}" >/dev/null 2>&1; then
                return 0
            fi
            log "warning: downloaded rootfs from ${url} is not valid squashfs"
        else
            log "warning: rootfs download failed from ${url}"
        fi
    done

    if [ -n "${PLASMA_ROOTFS_INDEX_URL}" ]; then
        index_tmp="${image_tmp}.index"
        rm -f "${index_tmp}"
        log "resolving latest ${PLASMA_DIST} rootfs from ${PLASMA_ROOTFS_INDEX_URL}"
        if curl -fL --retry 3 --retry-delay 2 --connect-timeout 30 \
            --speed-time 60 --speed-limit 1024 \
            "${PLASMA_ROOTFS_INDEX_URL}" -o "${index_tmp}" >>"${LOG}" 2>&1; then
            latest_dir="$(sed -n 's/.*href="\([^"]*\)\/".*/\1/p' "${index_tmp}" | \
                grep -E '^20[0-9]{6}_[0-9]{2}(%3A|:)[0-9]{2}$' | sort | tail -n 1 || true)"
            if [ -n "${latest_dir}" ]; then
                dynamic_url="${PLASMA_ROOTFS_INDEX_URL%/}/${latest_dir}/rootfs.squashfs"
                log "downloading latest ${PLASMA_DIST} rootfs from ${dynamic_url}"
                rm -f "${image_tmp}"
                if curl -fL --retry 3 --retry-delay 2 --connect-timeout 30 \
                    --speed-time 60 --speed-limit 1024 \
                    "${dynamic_url}" -o "${image_tmp}" >>"${LOG}" 2>&1 && \
                    unsquashfs -s "${image_tmp}" >/dev/null 2>&1; then
                    rm -f "${index_tmp}"
                    return 0
                fi
            fi
        fi
        rm -f "${index_tmp}"
    fi

    rm -f "${image_tmp}"
    return 1
}

create_container_from_squashfs() {
    local container_dir rootfs image image_tmp

    command -v curl >/dev/null 2>&1 || die "curl is required for direct rootfs downloads"
    command -v unsquashfs >/dev/null 2>&1 || die "unsquashfs is required for direct rootfs downloads"

    container_dir="${LXC_PATH}/${CONTAINER}"
    rootfs="${container_dir}/rootfs"
    image="${STATE_DIR}/rootfs.squashfs"
    image_tmp="${image}.part"

    mkdir -p "${STATE_DIR}" "${container_dir}"
    if ! unsquashfs -s "${image}" >/dev/null 2>&1; then
        download_rootfs_image "${image_tmp}" || die "could not download a valid ${PLASMA_DIST} rootfs"
        mv -f "${image_tmp}" "${image}"
    fi

    rm -rf "${rootfs}"
    unsquashfs -f -d "${rootfs}" "${image}" >>"${LOG}" 2>&1 || die "could not extract ${PLASMA_DIST} rootfs"
    cat > "${container_dir}/config" <<EOF
# Direct rootfs image: ${PLASMA_ROOTFS_URL}
lxc.include = /usr/share/lxc/config/common.conf
lxc.arch = linux64
lxc.rootfs.path = dir:${rootfs}
lxc.uts.name = ${CONTAINER}
lxc.net.0.type = veth
lxc.net.0.link = lxcbr0
lxc.net.0.flags = up
EOF
}

create_container() {
    mkdir -p "${LXC_PATH}"
    start_lxc_network
    ensure_runtime_dir

    destroy_incomplete_container "base image is missing"

    if container_exists; then
        if ! container_has_expected_distribution; then
            die "existing container ${CONTAINER} is not ${PLASMA_LABEL} (${PLASMA_OS_ID}); remove ${LXC_PATH}/${CONTAINER} before launching this variant"
        fi
        configure_lxc
        configure_container_dns
        return 0
    fi

    log "creating ${PLASMA_DIST} container ${CONTAINER}"
    if [ -n "${PLASMA_ROOTFS_URL}" ]; then
        create_container_from_squashfs
    else
        lxc-create -P "${LXC_PATH}" -n "${CONTAINER}" -t download -- \
            --dist "${PLASMA_DIST}" --release "${PLASMA_IMAGE_RELEASE}" --arch "${ARCH_IMAGE_ARCH}" >>"${LOG}" 2>&1
    fi
    configure_lxc
    configure_container_dns
}

container_has_expected_distribution() {
    local rootfs container_os_id

    rootfs="$(container_rootfs)"
    [ -r "${rootfs}/etc/os-release" ] || return 1
    container_os_id="$(awk -F= '$1 == "ID" { gsub(/"/, "", $2); print $2; exit }' "${rootfs}/etc/os-release")"
    [ "${container_os_id}" = "${PLASMA_OS_ID}" ]
}

start_container() {
    start_lxc_network
    ensure_runtime_dir
    configure_container_dns
    configure_lxc

    if container_running && ! container_has_session_mounts; then
        restart_container_for_config_reload || die "container could not be restarted to apply session device mounts"
    fi

    if ! container_running; then
        log "starting LXC container ${CONTAINER}"
        lxc-start -P "${LXC_PATH}" -n "${CONTAINER}" -d >>"${LOG}" 2>&1
        lxc-wait -P "${LXC_PATH}" -n "${CONTAINER}" -s RUNNING -t 30 >>"${LOG}" 2>&1 || die "container did not reach RUNNING"
    fi

    if ! container_has_session_mounts; then
        restart_container_for_config_reload || die "container could not be restarted to apply session device mounts"
        log "starting LXC container ${CONTAINER}"
        lxc-start -P "${LXC_PATH}" -n "${CONTAINER}" -d >>"${LOG}" 2>&1
        lxc-wait -P "${LXC_PATH}" -n "${CONTAINER}" -s RUNNING -t 30 >>"${LOG}" 2>&1 || die "container did not reach RUNNING"
    fi

    sync_container_udev_database
}

container_has_session_mounts() {
    container_running || return 1
    lxc-attach -P "${LXC_PATH}" -n "${CONTAINER}" -- /bin/sh -lc \
        "[ -e /dev/dri/card0 ] && [ -d /dev/input ] && [ -d /dev/snd ] && [ -S /batocera-runtime/seatd.sock ] && [ -d /dev/.lxc/proc ] && [ -d /dev/.lxc/sys ] && [ -d ${CONTAINER_HOST_LIB_DIR} ] && [ -d ${CONTAINER_HOST_USERDATA} ] && [ /etc/resolv.conf -ef ${CONTAINER_RUNTIME_DIR}/resolv.conf ]" \
        >/dev/null 2>&1
}

sync_container_udev_database() {
    local items=()
    local name udev_source

    container_running || return 0
    if [ -d "${HOST_RUNTIME_DIR}/udev/data" ]; then
        udev_source="${HOST_RUNTIME_DIR}/udev"
    else
        udev_source="/run/udev"
    fi
    [ -d "${udev_source}" ] || return 0

    for name in data links tags static_node-tags rules.d; do
        [ -e "${udev_source}/${name}" ] && items+=("${name}")
    done
    [ "${#items[@]}" -gt 0 ] || return 0

    lxc-attach -P "${LXC_PATH}" -n "${CONTAINER}" -- /bin/sh -lc \
        'rm -rf /run/udev/data /run/udev/links /run/udev/tags /run/udev/static_node-tags /run/udev/rules.d; mkdir -p /run/udev' \
        >>"${LOG}" 2>&1 || return 0

    if ! tar -C "${udev_source}" -cf - "${items[@]}" 2>/dev/null | \
        lxc-attach -P "${LXC_PATH}" -n "${CONTAINER}" -- tar -C /run/udev -xf - >>"${LOG}" 2>&1; then
        log "warning: could not copy host udev database into ${CONTAINER}"
    fi
}

start_container_udev_sync_loop() {
    (
        while container_running; do
            sync_udev_database
            sync_container_udev_database
            sleep 1
        done
    ) &
    UDEV_SYNC_PID="$!"
}

stop_container_udev_sync_loop() {
    local pid="$1"

    [ -n "${pid}" ] || return 0
    kill "${pid}" 2>/dev/null || true
    wait "${pid}" 2>/dev/null || true
}

run_lxc_stop_bounded() {
    local timeout_s="$1"
    local stop_pid limit i
    shift

    "$@" >>"${LOG}" 2>&1 &
    stop_pid="$!"
    limit=$((timeout_s * 10))

    for i in $(seq 1 "${limit}"); do
        if ! kill -0 "${stop_pid}" 2>/dev/null; then
            wait "${stop_pid}" 2>/dev/null || true
            return 0
        fi
        if ! container_running; then
            kill "${stop_pid}" 2>/dev/null || true
            return 0
        fi
        sleep 0.1
    done

    log "warning: LXC stop command timed out after ${timeout_s}s; killing pid ${stop_pid}"
    kill "${stop_pid}" 2>/dev/null || true
    sleep 0.2
    kill -KILL "${stop_pid}" 2>/dev/null || true
}

restart_container_for_config_reload() {
    log "restarting LXC container ${CONTAINER} to apply session device mounts"
    run_lxc_stop_bounded 10 lxc-stop -P "${LXC_PATH}" -n "${CONTAINER}"
    lxc-wait -P "${LXC_PATH}" -n "${CONTAINER}" -s STOPPED -t 5 >>"${LOG}" 2>&1 || true
    if container_running; then
        log "graceful LXC stop did not complete; force-stopping ${CONTAINER}"
        run_lxc_stop_bounded 10 lxc-stop -P "${LXC_PATH}" -n "${CONTAINER}" -k
        lxc-wait -P "${LXC_PATH}" -n "${CONTAINER}" -s STOPPED -t 5 >>"${LOG}" 2>&1 || true
    fi
    if container_running; then
        log "ERROR: LXC container ${CONTAINER} did not stop for config reload"
        return 1
    fi
    return 0
}

wait_for_container_command() {
    local i

    for i in $(seq 1 90); do
        if lxc-attach -P "${LXC_PATH}" -n "${CONTAINER}" -- /bin/sh -lc 'command -v pacman >/dev/null 2>&1 || command -v apt-get >/dev/null 2>&1' >/dev/null 2>&1; then
            return 0
        fi
        sleep 1
    done

    die "container is running but not attachable"
}

