xorg_frontend_running() {
    pgrep -x X >/dev/null 2>&1 || \
    pgrep -x Xorg >/dev/null 2>&1 || \
    pgrep -x xinit >/dev/null 2>&1 || \
    pgrep -x startx >/dev/null 2>&1
}

display_compositor_running() {
    pgrep -x labwc >/dev/null 2>&1 || \
    pgrep -x sway >/dev/null 2>&1 || \
    pgrep -x openbox >/dev/null 2>&1 || \
    xorg_frontend_running
}

frontend_ready() {
    emulationstation_running && display_compositor_running
}

clear_stale_frontend_locks() {
    if [ "${1:-}" != "--force" ] && { frontend_running || xorg_frontend_running; }; then
        return 0
    fi
    rm -f \
        /run/emulationstation-standalone \
        /run/emulationstation-standalone.lock \
        /var/run/emulationstation-standalone \
        /var/run/emulationstation-standalone.lock \
        /tmp/es-resume.fifo \
        /tmp/suspend.please \
        2>/dev/null || true
}

clear_stale_xorg_locks() {
    if xorg_frontend_running; then
        return 0
    fi
    rm -f /tmp/.X[0-9]*-lock /tmp/.X11-unix/X[0-9]* 2>/dev/null || true
}

wait_for_frontend_stop() {
    local i

    for i in $(seq 1 100); do
        if ! frontend_running && ! xorg_frontend_running; then
            clear_stale_frontend_locks
            clear_stale_xorg_locks
            return 0
        fi
        sleep 0.1
    done

    return 1
}

clear_frontend_restore_env() {
    local name

    for name in "${!BATOCERA_STEAM_@}"; do
        unset "${name}"
    done
    for name in "${!GAMESCOPE_@}"; do
        unset "${name}"
    done

    unset STEAM_DECK STEAMOS STEAM_GAMEPADUI STEAM_FORCE_DESKTOPUI
    unset STEAM_GAME SteamGameId SteamAppId STEAM_USE_MANGOAPP
    unset STEAM_MANGOAPP_PRESETS_SUPPORTED GAMESCOPE_DISPLAY
    unset GAMESCOPE_WAYLAND_DISPLAY GAMESCOPE_SESSION WLR_DRM_DEVICES
    unset WLR_LIBINPUT_NO_DEVICES SDL_NOMOUSE
}

wait_for_frontend_start() {
    local attempts="${1:-80}"
    local i

    for i in $(seq 1 "${attempts}"); do
        if frontend_ready; then
            return 0
        fi
        sleep 0.25
    done

    return 1
}

stop_incomplete_frontend_restore() {
    local i

    frontend_ready && return 0

    pkill -TERM -f '(^|/)emulationstation-standalone([[:space:]]|$)' >/dev/null 2>&1 || true
    pkill -TERM -x emulationstation >/dev/null 2>&1 || true
    pkill -TERM -x labwc >/dev/null 2>&1 || true
    pkill -TERM -x sway >/dev/null 2>&1 || true

    for i in $(seq 1 30); do
        if ! frontend_running && ! xorg_frontend_running; then
            clear_stale_frontend_locks --force
            return 0
        fi
        sleep 0.1
    done

    pkill -KILL -f '(^|/)emulationstation-standalone([[:space:]]|$)' >/dev/null 2>&1 || true
    pkill -KILL -x emulationstation >/dev/null 2>&1 || true
    pkill -KILL -x labwc >/dev/null 2>&1 || true
    pkill -KILL -x sway >/dev/null 2>&1 || true
    clear_stale_frontend_locks --force
}

ensure_labwc_keyboard_layout() {
    local keyboard language

    command -v batocera-settings-get >/dev/null 2>&1 || return 0
    command -v batocera-settings-set >/dev/null 2>&1 || return 0

    keyboard="$(batocera-settings-get system.kblayout 2>/dev/null || true)"
    [ -n "${keyboard}" ] && return 0

    language="$(batocera-settings-get system.language 2>/dev/null || true)"
    case "${language:-en_US}" in
