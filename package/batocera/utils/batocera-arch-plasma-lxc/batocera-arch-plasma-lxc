        if [ -n "${pid}" ] && [ -d "/proc/${pid}" ] && tr '\0' ' ' < "/proc/${pid}/cmdline" 2>/dev/null | grep -q 'thor-touch-mouse.py'; then
            return 0
        fi
    fi

    write_thor_touch_mouse_bridge
    THOR_TOUCH_EVENT="${event_path}" \
        THOR_GAMEPAD_EVENT="${gamepad_path}" \
