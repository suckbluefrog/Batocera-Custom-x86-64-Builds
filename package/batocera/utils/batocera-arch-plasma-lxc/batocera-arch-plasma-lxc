    "PIPEWIRE_REMOTE=${PIPEWIRE_REMOTE:-/batocera-runtime/pipewire-0}"
    "PULSE_SERVER=${PULSE_SERVER:-unix:/batocera-runtime/pulse/native}"
    "LD_LIBRARY_PATH=${LD_LIBRARY_PATH:-}"
    "LIBGL_DRIVERS_PATH=${LIBGL_DRIVERS_PATH:-}"
    "GBM_BACKENDS_PATH=${GBM_BACKENDS_PATH:-}"
    "BATOCERA_ARCH_PLASMA_OUTPUT_SCALE=${BATOCERA_ARCH_PLASMA_OUTPUT_SCALE:-}"
    "BATOCERA_ARCH_PLASMA_FORCE_OUTPUT=${BATOCERA_ARCH_PLASMA_FORCE_OUTPUT:-}"
    "BATOCERA_ARCH_PLASMA_FORCE_OUTPUT_MODE=${BATOCERA_ARCH_PLASMA_FORCE_OUTPUT_MODE:-}"
    "BATOCERA_ARCH_PLASMA_FORCE_OUTPUT_MODE_FALLBACK=${BATOCERA_ARCH_PLASMA_FORCE_OUTPUT_MODE_FALLBACK:-}"
    "BATOCERA_ARCH_PLASMA_DISABLE_OTHER_OUTPUTS=${BATOCERA_ARCH_PLASMA_DISABLE_OTHER_OUTPUTS:-}"
