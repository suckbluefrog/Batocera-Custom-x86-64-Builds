    chmod 0755 "/home/${PLASMA_USER}/Desktop/${desktop_file}"
    chown "${PLASMA_USER}:${PLASMA_USER}" "/home/${PLASMA_USER}/Desktop/${desktop_file}" 2>/dev/null || true
done

touch /var/lib/batocera-arch-plasma-ready
touch /var/lib/batocera-plasma-ready-v8
EOF
}

container_ready() {
    container_exists || return 1

    if [ -f "$(container_rootfs)/var/lib/batocera-plasma-ready-v8" ]; then
        return 0
    fi

    container_running && \
        lxc-attach -P "${LXC_PATH}" -n "${CONTAINER}" -- test -f /var/lib/batocera-plasma-ready-v8 >/dev/null 2>&1
}

ensure_private_session_bus_wrapper() {
    local rootfs payload real_payload

    rootfs="$(container_rootfs)"
    payload="${rootfs}/usr/local/bin/batocera-plasma-session-payload"
    real_payload="${rootfs}/usr/local/bin/batocera-plasma-session-payload.real"
    [ -x "${payload}" ] || return 0

    if grep -qF 'batocera-shared-session-bus-wrapper-v2' "${payload}" 2>/dev/null; then
        return 0
    fi

    if ! grep -qF 'batocera-private-session-bus-wrapper-v1' "${payload}" 2>/dev/null || \
            [ ! -x "${real_payload}" ]; then
        cp -f "${payload}" "${real_payload}"
    fi
    chmod 0755 "${real_payload}"
    cat > "${payload}" <<'EOS'
#!/bin/bash
# batocera-shared-session-bus-wrapper-v2
set -e
if [ "${BATOCERA_PLASMA_SHARED_DBUS:-0}" = "1" ] && \
        [ -n "${DBUS_SESSION_BUS_ADDRESS:-}" ]; then
    exec /usr/local/bin/batocera-plasma-session-payload.real --inside-dbus "$@"
fi
unset DBUS_SESSION_BUS_ADDRESS
if command -v dbus-run-session >/dev/null 2>&1; then
    exec dbus-run-session -- /usr/local/bin/batocera-plasma-session-payload.real --inside-dbus "$@"
fi
exec /usr/local/bin/batocera-plasma-session-payload.real --inside-dbus "$@"
EOS
    chmod 0755 "${payload}"
    log "installed shared Plasma session-bus wrapper in ${CONTAINER}"
}

ensure_polkit_helper_permissions() {
    local helper

    helper="$(container_rootfs)/usr/lib/polkit-1/polkit-agent-helper-1"
    [ -f "${helper}" ] || return 0
    chown root:root "${helper}" 2>/dev/null || true
    chmod 4755 "${helper}" 2>/dev/null || true
}

install_or_update_container() {
    log "setup requested for ${CONTAINER}"
    create_container
    start_container
    provision_container "${PLASMA_USER}" "${PLASMA_PASSWORD}"
    save_state "${PLASMA_USER}"
}

repair_existing_container_config() {
    container_exists || die "container ${CONTAINER} does not exist at ${LXC_PATH}"
    start_lxc_network
    ensure_runtime_dir
    configure_lxc
    configure_container_dns
    sync_container_udev_database
    log "refreshed LXC config and DNS for ${CONTAINER}"
}

provision_from_saved_state() {
    load_state
    PLASMA_PASSWORD="${BATOCERA_ARCH_PLASMA_PASSWORD:-${DEFAULT_PASSWORD}}"
    install_or_update_container
    install_launcher
}

frontend_running() {
    pgrep -x emulationstation >/dev/null 2>&1 || \
    pgrep -f '(^|/)emulationstation-standalone([[:space:]]|$)' >/dev/null 2>&1 || \
    pgrep -x labwc >/dev/null 2>&1 || \
    pgrep -x sway >/dev/null 2>&1 || \
    pgrep -x openbox >/dev/null 2>&1
}

emulationstation_running() {
    pgrep -x emulationstation >/dev/null 2>&1 || \
    pgrep -f '(^|[[:space:]/])emulationstation([[:space:]]|$)' >/dev/null 2>&1 || \
    pgrep -f '(^|/)emulationstation-standalone([[:space:]]|$)' >/dev/null 2>&1
}

xorg_frontend_running() {
    pgrep -x X >/dev/null 2>&1 || \
    pgrep -x Xorg >/dev/null 2>&1 || \
    pgrep -x xinit >/dev/null 2>&1 || \
    pgrep -x startx >/dev/null 2>&1
}

display_compositor_running() {
    pgrep -x labwc >/dev/null 2>&1 || \
    pgrep -x sway >/dev/null 2>&1 || \
    pgrep -x openbox >/dev/null 2>&1 || \
    xorg_frontend_running
}

frontend_ready() {
    emulationstation_running && display_compositor_running
}

clear_stale_frontend_locks() {
    if [ "${1:-}" != "--force" ] && { frontend_running || xorg_frontend_running; }; then
        return 0
    fi
    rm -f \
        /run/emulationstation-standalone \
        /run/emulationstation-standalone.lock \
        /var/run/emulationstation-standalone \
        /var/run/emulationstation-standalone.lock \
        /tmp/es-resume.fifo \
        /tmp/suspend.please \
        2>/dev/null || true
}

clear_stale_xorg_locks() {
    if xorg_frontend_running; then
        return 0
    fi
    rm -f /tmp/.X[0-9]*-lock /tmp/.X11-unix/X[0-9]* 2>/dev/null || true
}

wait_for_frontend_stop() {
    local i

    for i in $(seq 1 100); do
        if ! frontend_running && ! xorg_frontend_running; then
            clear_stale_frontend_locks
            clear_stale_xorg_locks
            return 0
        fi
        sleep 0.1
    done

    return 1
}

clear_frontend_restore_env() {
    local name

    for name in "${!BATOCERA_STEAM_@}"; do
        unset "${name}"
    done
    for name in "${!GAMESCOPE_@}"; do
        unset "${name}"
    done

    unset STEAM_DECK STEAMOS STEAM_GAMEPADUI STEAM_FORCE_DESKTOPUI
    unset STEAM_GAME SteamGameId SteamAppId STEAM_USE_MANGOAPP
    unset STEAM_MANGOAPP_PRESETS_SUPPORTED GAMESCOPE_DISPLAY
    unset GAMESCOPE_WAYLAND_DISPLAY GAMESCOPE_SESSION WLR_DRM_DEVICES
    unset WLR_LIBINPUT_NO_DEVICES SDL_NOMOUSE
    clear_inherited_overlay_env
}

wait_for_frontend_start() {
    local attempts="${1:-80}"
    local i

    for i in $(seq 1 "${attempts}"); do
        if frontend_ready; then
            return 0
        fi
        sleep 0.25
    done

    return 1
}

stop_incomplete_frontend_restore() {
    local i

    frontend_ready && return 0

    pkill -TERM -f '(^|/)emulationstation-standalone([[:space:]]|$)' >/dev/null 2>&1 || true
    pkill -TERM -x emulationstation >/dev/null 2>&1 || true
    pkill -TERM -x labwc >/dev/null 2>&1 || true
    pkill -TERM -x sway >/dev/null 2>&1 || true

    for i in $(seq 1 30); do
        if ! frontend_running && ! xorg_frontend_running; then
            clear_stale_frontend_locks --force
            return 0
        fi
        sleep 0.1
    done

    pkill -KILL -f '(^|/)emulationstation-standalone([[:space:]]|$)' >/dev/null 2>&1 || true
    pkill -KILL -x emulationstation >/dev/null 2>&1 || true
    pkill -KILL -x labwc >/dev/null 2>&1 || true
    pkill -KILL -x sway >/dev/null 2>&1 || true
    clear_stale_frontend_locks --force
}

ensure_labwc_keyboard_layout() {
    local keyboard language

    command -v batocera-settings-get >/dev/null 2>&1 || return 0
    command -v batocera-settings-set >/dev/null 2>&1 || return 0

    keyboard="$(batocera-settings-get system.kblayout 2>/dev/null || true)"
    [ -n "${keyboard}" ] && return 0

    language="$(batocera-settings-get system.language 2>/dev/null || true)"
    case "${language:-en_US}" in
        en|en_*|en-*)
            log "system.kblayout is unset for English locale; setting it to us for labwc"
            batocera-settings-set system.kblayout us >>"${LOG}" 2>&1 || true
            ;;
    esac
}

clear_session_display_env() {
    unset DISPLAY
    unset WAYLAND_DISPLAY
    unset SWAYSOCK
    unset XAUTHORITY
    unset LABWC_PID
    unset WLR_XWAYLAND_NO_AUTH
    unset GAMESCOPE_DISPLAY
    unset GAMESCOPE_WAYLAND_DISPLAY
    unset GAMESCOPE_SESSION
    unset DBUS_SESSION_BUS_ADDRESS
}

stop_xorg_frontend_for_drm() {
    local i

    if xorg_frontend_running; then
        log "stopping leftover Xorg frontend before ${PLASMA_LABEL} DRM launch"
    fi

    pkill -TERM -x openbox >/dev/null 2>&1 || true
    pkill -TERM -x xinit >/dev/null 2>&1 || true
    pkill -TERM -x startx >/dev/null 2>&1 || true
    pkill -TERM -x X >/dev/null 2>&1 || true
    pkill -TERM -x Xorg >/dev/null 2>&1 || true

    for i in $(seq 1 30); do
        if ! xorg_frontend_running; then
            clear_stale_xorg_locks
            return 0
        fi
        sleep 0.1
    done

    if xorg_frontend_running; then
        log "force-killing leftover Xorg frontend before ${PLASMA_LABEL} DRM launch"
        pkill -KILL -x openbox >/dev/null 2>&1 || true
        pkill -KILL -x xinit >/dev/null 2>&1 || true
        pkill -KILL -x startx >/dev/null 2>&1 || true
        pkill -KILL -x X >/dev/null 2>&1 || true
        pkill -KILL -x Xorg >/dev/null 2>&1 || true
    fi

    clear_stale_xorg_locks
}

stop_frontend_for_drm() {
    if [ -x "${ES_SERVICE}" ]; then
        log "stopping EmulationStation frontend before ${PLASMA_LABEL} launch"
        "${ES_SERVICE}" stop >>"${LOG}" 2>&1 || true
    fi

    stop_xorg_frontend_for_drm

    if ! wait_for_frontend_stop; then
        log "frontend did not stop cleanly; force-killing display frontend"
        stop_xorg_frontend_for_drm
        pkill -KILL -x labwc >/dev/null 2>&1 || true
        pkill -KILL -x sway >/dev/null 2>&1 || true
        clear_stale_frontend_locks
        clear_stale_xorg_locks
    fi

    clear_stale_frontend_locks
}

restore_frontend() {
    if frontend_ready; then
        log "EmulationStation already running after ${PLASMA_LABEL} exit"
        return 0
    fi

    ensure_labwc_keyboard_layout
    stop_xorg_frontend_for_drm
    clear_stale_xorg_locks
    clear_stale_frontend_locks

    if command -v batocera-steam-frontend-recover >/dev/null 2>&1; then
        log "restoring EmulationStation through Odin Steam frontend recover helper"
        clear_frontend_restore_env
        batocera-steam-frontend-recover --reason "${SESSION_SUPERVISOR_NAME}-cleanup" >>"${LOG}" 2>&1 || true
        if wait_for_frontend_start 80; then
            return 0
        fi
    fi

    if [ -x "${ES_SERVICE}" ]; then
        log "restoring EmulationStation after ${PLASMA_LABEL} exit"
        clear_frontend_restore_env
        "${ES_SERVICE}" start >>"${LOG}" 2>&1 || "${ES_SERVICE}" restart >>"${LOG}" 2>&1 || true
    fi

    if wait_for_frontend_start 80; then
        return 0
    fi

    if command -v labwc-launch >/dev/null 2>&1; then
        log "frontend service did not spawn EmulationStation; starting labwc-launch fallback"
        stop_incomplete_frontend_restore
        clear_stale_xorg_locks
        clear_stale_frontend_locks --force
        clear_frontend_restore_env
        run_detached labwc-launch
        if ! wait_for_frontend_start 120; then
            log "EmulationStation did not return after labwc-launch fallback"
        fi
    fi

    if ! frontend_ready && command -v sway-launch >/dev/null 2>&1; then
        log "frontend service did not spawn EmulationStation; starting sway-launch fallback"
        stop_incomplete_frontend_restore
        clear_stale_xorg_locks
        clear_stale_frontend_locks --force
        clear_frontend_restore_env
        run_detached sway-launch
        if ! wait_for_frontend_start 120; then
            log "EmulationStation did not return after sway-launch fallback"
        fi
    fi
}

start_session_supervisor() {
    [[ "${BATOCERA_ARCH_PLASMA_SESSION_SUPERVISOR:-0}" == "1" ]] || return 0
    command -v batocera-steam-session-supervisor >/dev/null 2>&1 || return 0
    batocera-steam-session-supervisor start "${SESSION_SUPERVISOR_NAME}" >>"${LOG}" 2>&1 || true
}

recover_frontend_with_supervisor() {
    [[ "${BATOCERA_ARCH_PLASMA_SESSION_SUPERVISOR:-0}" == "1" ]] || return 0
    command -v batocera-steam-session-supervisor >/dev/null 2>&1 || return 0
    batocera-steam-session-supervisor recover "${SESSION_SUPERVISOR_NAME}-cleanup" >>"${LOG}" 2>&1 || true
}

detach_from_frontend_session() {
    local child_pid child_rc

    [[ "${BATOCERA_ARCH_PLASMA_DETACHED:-0}" != "1" ]] || return 0
    command -v setsid >/dev/null 2>&1 || return 0

    log "detaching ${PLASMA_LABEL} launcher from frontend process group"
    export BATOCERA_ARCH_PLASMA_DETACHED=1

    set +e
    nohup setsid "$0" "$@" >>"${LOG}" 2>&1 </dev/null &
    child_pid="$!"
    wait "${child_pid}"
    child_rc="$?"
    exit "${child_rc}"
}

terminate_plasma_session() {
    local user="$1"

    if ! container_running; then
        return 0
    fi

    log "terminating Plasma user session for ${user}"
    lxc-attach -P "${LXC_PATH}" -n "${CONTAINER}" --clear-env -v "PLASMA_USER=${user}" -- /bin/bash -s >>"${LOG}" 2>&1 <<'EOF' || true
set +e
uid="$(id -u "${PLASMA_USER}" 2>/dev/null || true)"
[ -n "${uid}" ] || exit 0

patterns='startplasma|plasma_session|plasmashell|plasma_waitforname|kwin_wayland|ksmserver|kded|kactivity|xdg-desktop-portal|xdg-document-portal|baloo|kglobalaccel|krunner|konsole|dolphin|pipewire|wireplumber'
pkill -TERM -u "${uid}" -f "${patterns}" 2>/dev/null || true
for _ in $(seq 1 20); do
    if ! pgrep -u "${uid}" -f "${patterns}" >/dev/null 2>&1; then
        break
    fi
    sleep 0.2
done
pkill -KILL -u "${uid}" -f "${patterns}" 2>/dev/null || true

root_patterns='batocera-start-plasma-root|batocera-plasma-session-wrapper|kwin_wayland.*batocera-plasma-session-wrapper'
pkill -TERM -f "${root_patterns}" 2>/dev/null || true
for _ in $(seq 1 20); do
    if ! pgrep -f "${root_patterns}" >/dev/null 2>&1; then
        exit 0
    fi
    sleep 0.2
done
pkill -KILL -f "${root_patterns}" 2>/dev/null || true
EOF
}

detect_resolution() {
    local value

    if command -v batocera-resolution >/dev/null 2>&1; then
        value="$(batocera-resolution currentResolution 2>/dev/null || true)"
        if [[ "${value}" =~ ^([0-9]+)x([0-9]+)$ ]]; then
            printf '%s %s\n' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}"
            return 0
        fi
    fi

    printf '1280 720\n'
}

detect_refresh_rate() {
    local value

    if command -v batocera-resolution >/dev/null 2>&1; then
        value="$(batocera-resolution refreshRate 2>/dev/null || true)"
        if [[ "${value}" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
            awk -v rate="${value}" 'BEGIN { printf "%d\n", int(rate + 0.5) }'
            return 0
        fi
    fi

    printf '60\n'
}

launch_plasma_session() {
    local user="$1"
    local uid gid runtime_dir runtime_parent udev_sync_pid session_rc runuser_cmd

    start_container
    wait_for_container_command
    container_has_session_mounts || die "container session device mounts are missing after start"

    uid="$(lxc-attach -P "${LXC_PATH}" -n "${CONTAINER}" -- id -u "${user}" 2>/dev/null || true)"
    [ -n "${uid}" ] || die "container user ${user} does not exist"
    gid="$(lxc-attach -P "${LXC_PATH}" -n "${CONTAINER}" -- id -g "${user}" 2>/dev/null || true)"
    [ -n "${gid}" ] || gid="${uid}"

    ensure_runtime_dir
    # The pointer bridge grabs the gamepad while Plasma owns the display. Do
    # not start it during provisioning, or ES loses controller input when the
    # setup window returns to the frontend.
    start_thor_touch_mouse_bridge
    sync_udev_database
    if [ "${PLASMA_SESSION_TYPE}" = "wayland" ]; then
        runtime_dir="/run/batocera-plasma/${uid}"
    else
        runtime_dir="/run/user/${uid}"
    fi
    runtime_parent="$(dirname "${runtime_dir}")"

    lxc-attach -P "${LXC_PATH}" -n "${CONTAINER}" -- /bin/sh -lc \
        "install -d -m 0755 '${runtime_parent}' && install -d -m 0700 -o '${uid}' -g '${gid}' '${runtime_dir}'" >>"${LOG}" 2>&1

    export BATOCERA_ARCH_PLASMA_LXC_PATH="${LXC_PATH}"
    export BATOCERA_ARCH_PLASMA_CONTAINER="${CONTAINER}"
    export BATOCERA_ARCH_PLASMA_USER="${user}"

    log "launching ${PLASMA_LABEL} with ${PLASMA_RENDERER} KWin renderer (${PLASMA_SESSION_TYPE})"
    if command -v batocera-mouse >/dev/null 2>&1; then
        batocera-mouse show >/dev/null 2>&1 || true
    fi

    if [ "${PLASMA_SESSION_TYPE}" = "wayland" ]; then
        UDEV_SYNC_PID=""
        start_container_udev_sync_loop
        udev_sync_pid="${UDEV_SYNC_PID}"
        set +e
        lxc-attach -P "${LXC_PATH}" -n "${CONTAINER}" --clear-env \
            -v "PLASMA_USER=${user}" \
            -v "PLASMA_UID=${uid}" \
            -v "PLASMA_GID=${gid}" \
            -v "LANG=C.UTF-8" \
            -v "XDG_RUNTIME_DIR=${runtime_dir}" \
            -v "BATOCERA_ARCH_PLASMA_SESSION_TYPE=${PLASMA_SESSION_TYPE}" \
            -v "KWIN_DRM_DEVICES=${BATOCERA_ARCH_PLASMA_DRM_DEVICES:-/dev/dri/card0}" \
            -v "LIBSEAT_BACKEND=seatd" \
            -v "SEATD_SOCK=/batocera-runtime/seatd.sock" \
            -v "PIPEWIRE_REMOTE=/batocera-runtime/pipewire-0" \
            -v "PULSE_SERVER=unix:/batocera-runtime/pulse/native" \
            -v "BATOCERA_ARCH_PLASMA_OUTPUT_SCALE=${BATOCERA_ARCH_PLASMA_OUTPUT_SCALE:-}" \
            -v "BATOCERA_ARCH_PLASMA_FORCE_OUTPUT=${BATOCERA_ARCH_PLASMA_FORCE_OUTPUT:-}" \
            -v "BATOCERA_ARCH_PLASMA_FORCE_OUTPUT_MODE=${BATOCERA_ARCH_PLASMA_FORCE_OUTPUT_MODE:-}" \
            -v "BATOCERA_ARCH_PLASMA_FORCE_OUTPUT_MODE_FALLBACK=${BATOCERA_ARCH_PLASMA_FORCE_OUTPUT_MODE_FALLBACK:-}" \
            -v "BATOCERA_ARCH_PLASMA_DISABLE_OTHER_OUTPUTS=${BATOCERA_ARCH_PLASMA_DISABLE_OTHER_OUTPUTS:-}" \
            -v "BATOCERA_ARCH_PLASMA_TOUCH_KEEP_PATTERN=${BATOCERA_ARCH_PLASMA_TOUCH_KEEP_PATTERN:-}" \
            -v "BATOCERA_ARCH_PLASMA_TOUCH_OUTPUT_NAME=${BATOCERA_ARCH_PLASMA_TOUCH_OUTPUT_NAME:-}" \
            -v "BATOCERA_ARCH_PLASMA_TOUCH_KWIN_CALIBRATION_MATRIX=${BATOCERA_ARCH_PLASMA_TOUCH_KWIN_CALIBRATION_MATRIX:-}" \
            -v "BATOCERA_ARCH_PLASMA_KWIN_DBUS_SESSION=${BATOCERA_ARCH_PLASMA_KWIN_DBUS_SESSION:-1}" \
            -v "BATOCERA_ARCH_PLASMA_ENABLE_INPUTMETHOD=${BATOCERA_ARCH_PLASMA_ENABLE_INPUTMETHOD:-1}" \
            -v "BATOCERA_ARCH_PLASMA_POINTER_ACCEL=${BATOCERA_ARCH_PLASMA_POINTER_ACCEL:-}" \
            -- /usr/local/bin/batocera-start-plasma-root >>"${LOG}" 2>&1
        session_rc="$?"
        set -e
        stop_container_udev_sync_loop "${udev_sync_pid}"
        return "${session_rc}"
    else
        runuser_cmd="$(lxc-attach -P "${LXC_PATH}" -n "${CONTAINER}" -- /bin/sh -lc 'command -v runuser' 2>/dev/null || true)"
        [ -n "${runuser_cmd}" ] || die "runuser is missing inside ${CONTAINER}"
        lxc-attach -P "${LXC_PATH}" -n "${CONTAINER}" --clear-env \
            -v "USER=${user}" \
            -v "LOGNAME=${user}" \
            -v "HOME=/home/${user}" \
            -v "LANG=C.UTF-8" \
            -v "XDG_RUNTIME_DIR=${runtime_dir}" \
            -v "BATOCERA_ARCH_PLASMA_SESSION_TYPE=${PLASMA_SESSION_TYPE}" \
            -v "KWIN_DRM_DEVICES=${BATOCERA_ARCH_PLASMA_DRM_DEVICES:-/dev/dri/card0}" \
            -v "LIBSEAT_BACKEND=seatd" \
            -v "SEATD_SOCK=/batocera-runtime/seatd.sock" \
            -v "PIPEWIRE_REMOTE=/batocera-runtime/pipewire-0" \
            -v "PULSE_SERVER=unix:/batocera-runtime/pulse/native" \
            -v "BATOCERA_ARCH_PLASMA_ENABLE_INPUTMETHOD=${BATOCERA_ARCH_PLASMA_ENABLE_INPUTMETHOD:-1}" \
            -v "BATOCERA_ARCH_PLASMA_POINTER_ACCEL=${BATOCERA_ARCH_PLASMA_POINTER_ACCEL:-}" \
            -- "${runuser_cmd}" -u "${user}" --preserve-environment -- /usr/local/bin/batocera-start-plasma
    fi
}

cleanup_session() {
    local rc=$?
    if [ "${CLEANUP_DONE:-0}" = "1" ]; then
        exit "${rc}"
    fi
    CLEANUP_DONE=1
    trap - EXIT INT TERM

    set +e
    load_state
    log "${PLASMA_LABEL} session exited with status ${rc}"
    stop_thor_touch_mouse_bridge
    terminate_plasma_session "${PLASMA_USER}"
    if command -v batocera-mouse >/dev/null 2>&1; then
        batocera-mouse hide >/dev/null 2>&1 || true
    fi
    restore_frontend
    recover_frontend_with_supervisor
    exit "${rc}"
}

run_session() {
    load_state

    if ! container_ready; then
        die "container is not installed yet; run the setup launcher once"
    fi

    ensure_polkit_helper_permissions
    ensure_private_session_bus_wrapper

    detach_from_frontend_session --session

    trap cleanup_session EXIT INT TERM
    stop_frontend_for_drm
    clear_session_display_env
    start_session_supervisor
    launch_plasma_session "${PLASMA_USER}"
}

terminal_setup_then_launch() {
    load_state
    prompt_credentials
    if ! run_with_visible_log install_or_update_container; then
        if command -v dialog >/dev/null 2>&1 && have_tty; then
            dialog --title "${PLASMA_LABEL} LXC" --msgbox \
                "Setup failed.\n\nReview ${LOG} for details." 9 62
        elif command -v yad >/dev/null 2>&1 && [ -n "${DISPLAY:-}" ]; then
            yad --center --on-top --title="${PLASMA_LABEL} LXC" \
                --text="Setup failed.\n\nReview ${LOG} for details." \
                --button=OK:0 --width=520 2>/dev/null || true
        else
            printf '\n%s\n' "${PLASMA_LABEL} LXC setup failed."
            printf '%s\n' "The last log lines are shown above and saved in ${LOG}."
            printf '%s' "Press Enter to close..."
            read -r _ || true
        fi
        return 1
    fi
    install_launcher

    # First-run setup normally runs inside a fullscreen xterm. Use dialog on
    # that terminal so the completion prompt cannot be stacked behind it.
    if command -v dialog >/dev/null 2>&1 && have_tty; then
        dialog --title "${PLASMA_LABEL} LXC" --msgbox \
            "Setup complete.\n\nRelaunch ${PLASMA_LABEL} LXC to start the desktop." 9 62
    elif command -v yad >/dev/null 2>&1 && [ -n "${DISPLAY:-}" ]; then
        yad --center --on-top --title="${PLASMA_LABEL} LXC" \
            --text="Setup complete.\n\nRelaunch ${PLASMA_LABEL} LXC to start the desktop." \
            --button=OK:0 --width=520 2>/dev/null || true
    else
        printf '%s\n' "Setup complete. Relaunch ${PLASMA_LABEL} LXC to start the desktop."
    fi
}

run_with_visible_log() {
    local rc
    local tail_pid=""

    prepare_setup_log
    clear 2>/dev/null || true
    printf '%s\n' "${PLASMA_LABEL} LXC setup is running."
    printf '%s\n' "This can take a while while the ${PLASMA_DIST} image and Plasma packages download."
    printf '%s\n\n' "Live log: ${LOG}"

    tail -n 40 -f "${LOG}" &
    tail_pid="$!"

    set +e
    "$@"
    rc="$?"
    set -e

    kill "${tail_pid}" 2>/dev/null || true
    wait "${tail_pid}" 2>/dev/null || true
    printf '\n'

    return "${rc}"
}

ensure_setup_terminal() {
    if have_tty; then
        terminal_setup_then_launch
        return
    fi

    if [ -z "${DISPLAY:-}" ] && command -v getLocalXDisplay >/dev/null 2>&1; then
        export DISPLAY="$(getLocalXDisplay)"
    fi

    command -v xterm >/dev/null 2>&1 || die "xterm is required for first-run setup when no tty is attached"
    exec xterm -fullscreen -bg black -fg white -fa "DejaVu Sans Mono" -fs 12 \
        -T "${PLASMA_LABEL} LXC setup" -e /bin/bash -lc '
            script="$1"
            "$script" --setup-terminal
            rc="$?"
            if [ "$rc" -ne 0 ]; then
                clear
                printf "%s\n\n" "${PLASMA_LABEL} LXC setup failed with exit code ${rc}."
                printf "%s\n\n" "Last log lines from ${LOG}:"
                tail -120 "${LOG}" 2>/dev/null || true
                printf "\n%s" "Press Enter to close..."
                read -r _ || true
            fi
            exit "$rc"
        ' bash "$0"
}

cleanup_legacy_ports_launcher() {
    local tmp

    if [ -f /userdata/system/batocera.conf ]; then
        tmp="$(mktemp)"
        grep -vF \
            -e 'ports["Arch Plasma LXC.sh"].cpu_limit_target_fps=' \
            -e 'ports["Arch Plasma LXC.sh"].hud=' \
            -e 'ports["Arch Plasma LXC.sh"].showFPS=' \
            /userdata/system/batocera.conf > "${tmp}" 2>/dev/null || true
        mv "${tmp}" /userdata/system/batocera.conf
    fi

    if [ -e "${LEGACY_PORTS_LAUNCHER}" ]; then
        rm -f "${LEGACY_PORTS_LAUNCHER}"
        log "removed legacy ports launcher ${LEGACY_PORTS_LAUNCHER}"
    fi

    if [ -f "${LEGACY_PORTS_GAMELIST}" ]; then
        tmp="$(mktemp)"
        awk '
            /<game([[:space:]]|>)/ {
                in_game=1
                block=$0 ORS
                remove=0
                next
            }
            in_game {
                block=block $0 ORS
                if ($0 ~ /<path>[[:space:]]*\.\/Arch Plasma LXC\.sh[[:space:]]*<\/path>/) {
                    remove=1
                }
                if ($0 ~ /<\/game>/) {
                    if (!remove) {
                        printf "%s", block
                    }
                    in_game=0
                    block=""
                    remove=0
                }
                next
            }
            { print }
            END {
                if (in_game && !remove) {
                    printf "%s", block
                }
            }
        ' "${LEGACY_PORTS_GAMELIST}" > "${tmp}" && \
            mv "${tmp}" "${LEGACY_PORTS_GAMELIST}" || rm -f "${tmp}"
    fi
}

install_launcher() {
    cleanup_legacy_ports_launcher
    log "${PLASMA_LABEL} LXC launcher is managed by the packaged emulator menu and F1 desktop entries"
}

usage() {
    cat <<EOF
usage: $0 [--install-launcher|--repair-config|--provision-from-state|--setup-terminal|--configure|--session|--help]

Default mode installs/configures the ${PLASMA_LABEL} container if needed, then
starts a direct KWin DRM session and restores EmulationStation on exit.
EOF
}

case "${1:-}" in
    --install-launcher)
        install_launcher
        ;;
    --repair-config)
        repair_existing_container_config
        ;;
    --provision-from-state)
        provision_from_saved_state
        ;;
    --setup-terminal|--configure)
        terminal_setup_then_launch
        ;;
    --session)
        run_session
        ;;
    --help|-h)
        usage
        ;;
    "")
        install_launcher
        if container_ready; then
            run_session
        else
            ensure_setup_terminal
        fi
        ;;
    *)
        usage >&2
        exit 2
        ;;
esac
