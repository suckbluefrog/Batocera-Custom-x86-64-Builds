cat > /usr/local/bin/batocera-start-plasma-root <<'EOS'
#!/bin/bash
set -euo pipefail

session_type="${BATOCERA_ARCH_PLASMA_SESSION_TYPE:-wayland}"
user="${PLASMA_USER:-${USER:-batocera}}"

if [ "${session_type}" != "wayland" ]; then
    runuser_cmd="$(command -v runuser 2>/dev/null || true)"
    [ -n "${runuser_cmd}" ] || { printf '%s\n' 'runuser is required to start Plasma' >&2; exit 127; }
    exec "${runuser_cmd}" -u "${user}" --preserve-environment -- /usr/local/bin/batocera-start-plasma
fi

uid="${PLASMA_UID:-$(id -u "${user}")}"
gid="${PLASMA_GID:-$(id -g "${user}")}"
runtime_dir="${XDG_RUNTIME_DIR:-/run/batocera-plasma/${uid}}"
runtime_parent="$(dirname "${runtime_dir}")"

install -d -m 0755 "${runtime_parent}"
install -d -m 0700 -o "${uid}" -g "${gid}" "${runtime_dir}"
rm -f "${runtime_dir}"/wayland-* "${runtime_dir}"/wayland-*.lock 2>/dev/null || true

export PLASMA_USER="${user}"
export PLASMA_UID="${uid}"
export PLASMA_GID="${gid}"
export USER=root
export LOGNAME=root
export HOME=/root
export XDG_RUNTIME_DIR="${runtime_dir}"
export XDG_SESSION_TYPE=wayland
export XDG_CURRENT_DESKTOP=KDE
export XDG_SESSION_DESKTOP=KDE
export XDG_MENU_PREFIX=plasma-
export DESKTOP_SESSION=plasmawayland
export KDE_FULL_SESSION=true
export NO_AT_BRIDGE=1
export QT_QPA_PLATFORM=wayland
export KWIN_DRM_DEVICES="${KWIN_DRM_DEVICES:-/dev/dri/card0}"
export LIBSEAT_BACKEND="${LIBSEAT_BACKEND:-seatd}"
export SEATD_SOCK="${SEATD_SOCK:-/batocera-runtime/seatd.sock}"

unset DISPLAY
unset WAYLAND_DISPLAY
unset XAUTHORITY
unset DBUS_SESSION_BUS_ADDRESS

if [ -e /batocera-runtime/host-gpu/libEGL_mesa.so.0 ]; then
    export LD_LIBRARY_PATH="/batocera-runtime/host-gpu${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
    export LIBGL_DRIVERS_PATH=/batocera-host/usr/lib/dri
    export GBM_BACKENDS_PATH=/batocera-host/usr/lib/gbm
fi

apply_static_output_scale() {
    local scale="${BATOCERA_ARCH_PLASMA_OUTPUT_SCALE:-}"
    local user_home="/home/${user}"

    [ -n "${scale}" ] || return 0
    [[ "${scale}" =~ ^[0-9]+([.][0-9]+)?$ ]] || return 0

    install -d -m 0700 -o "${uid}" -g "${gid}" "${user_home}/.config"
    if [ -f "${user_home}/.config/kwinoutputconfig.json" ]; then
        sed -i -E "s/(\"scale\": )[0-9]+([.][0-9]+)?/\1${scale}/g" "${user_home}/.config/kwinoutputconfig.json" 2>/dev/null || true
    fi

    if command -v kwriteconfig6 >/dev/null 2>&1; then
        runuser -u "${user}" -- kwriteconfig6 --file "${user_home}/.config/kwinrc" \
            --group Xwayland --key Scale "${scale}" >/dev/null 2>&1 || true
    fi
}

inputmethod_args=()
if [ "${BATOCERA_ARCH_PLASMA_ENABLE_INPUTMETHOD:-1}" = "1" ]; then
    for inputmethod in plasma-keyboard maliit-keyboard squeekboard; do
        if command -v "${inputmethod}" >/dev/null 2>&1; then
            inputmethod_args=(--inputmethod "$(command -v "${inputmethod}")")
            break
        fi
    done
fi

apply_static_output_scale

if [ "${BATOCERA_ARCH_PLASMA_KWIN_DBUS_SESSION:-1}" = "1" ] && command -v dbus-daemon >/dev/null 2>&1; then
    bus_socket="${runtime_dir}/batocera-session-bus"
    bus_config=/usr/local/share/batocera-plasma/session.conf
    rm -f "${bus_socket}"
    # PAM gives runuser the standard /run/user/$UID runtime. If the private
    # bus inherits that value, D-Bus-activated flatpak-portal looks for the
    # caller's bwrapinfo.json in the wrong .flatpak directory and Zypak cannot
    # resolve Chrome's requesting PID. Override the post-PAM environment so
    # every service activated on this bus shares Plasma's private runtime.
    bus_info="$(runuser -u "${user}" -- /usr/bin/env \
        HOME="/home/${user}" USER="${user}" LOGNAME="${user}" \
        PATH=/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin \
        XDG_RUNTIME_DIR="${runtime_dir}" \
        XDG_CURRENT_DESKTOP=KDE XDG_SESSION_TYPE=wayland \
        DBUS_SESSION_BUS_ADDRESS="unix:path=${bus_socket}" \
        dbus-daemon --config-file="${bus_config}" \
        --address="unix:path=${bus_socket}" \
        --fork --print-address=1 --print-pid=1)"
    bus_address="$(printf '%s\n' "${bus_info}" | sed -n '1p')"
    bus_pid="$(printf '%s\n' "${bus_info}" | sed -n '2p')"
    [ -n "${bus_address}" ] && [[ "${bus_pid}" =~ ^[0-9]+$ ]] && [ -S "${bus_socket}" ] || {
        printf '%s\n' 'failed to start the shared Plasma session bus' >&2
        exit 1
    }

    # KWin must remain root on these DRM stacks, while Plasma applications run
    # as the desktop user. This bus is owned by that user, accepts both local
    # UIDs, and is confined by the mode-0700 runtime directory.
    export DBUS_SESSION_BUS_ADDRESS="${bus_address}"
    export BATOCERA_PLASMA_SHARED_DBUS=1
    cleanup_session_bus() {
        kill "${bus_pid}" 2>/dev/null || true
        rm -f "${bus_socket}" 2>/dev/null || true
    }
    trap cleanup_session_bus EXIT INT TERM
    set +e
    kwin_wayland --drm --xwayland --socket wayland-0 --no-lockscreen "${inputmethod_args[@]}" \
        --exit-with-session /usr/local/bin/batocera-plasma-session-wrapper
    rc="$?"
    set -e
    trap - EXIT INT TERM
    cleanup_session_bus
    exit "${rc}"
fi

exec kwin_wayland --drm --xwayland --socket wayland-0 --no-lockscreen "${inputmethod_args[@]}" \
    --exit-with-session /usr/local/bin/batocera-plasma-session-wrapper
EOS
chmod 0755 /usr/local/bin/batocera-start-plasma-root

cat > /usr/local/bin/batocera-plasma-session-wrapper <<'EOS'
#!/bin/bash
set -euo pipefail

user="${PLASMA_USER:-batocera}"
uid="${PLASMA_UID:-$(id -u "${user}")}"
gid="${PLASMA_GID:-$(id -g "${user}")}"
runuser_cmd="$(command -v runuser 2>/dev/null || true)"
runtime_dir="${XDG_RUNTIME_DIR:-/run/batocera-plasma/${uid}}"
runtime_parent="$(dirname "${runtime_dir}")"
wayland_display="${WAYLAND_DISPLAY:-wayland-0}"

[ -n "${runuser_cmd}" ] || { printf '%s\n' 'runuser is required to start the Plasma user session' >&2; exit 127; }

export WAYLAND_DISPLAY="${wayland_display}"
if [ "$(id -u)" = "${uid}" ]; then
    mkdir -p "${runtime_dir}"
    chmod 0700 "${runtime_dir}" 2>/dev/null || true
else
    install -d -m 0755 "${runtime_parent}"
    install -d -m 0700 -o "${uid}" -g "${gid}" "${runtime_dir}"
fi

for _ in $(seq 1 50); do
    [ -S "${runtime_dir}/${wayland_display}" ] && break
    sleep 0.1
done

chmod 777 "${runtime_dir}/${wayland_display}" "${runtime_dir}/${wayland_display}.lock" 2>/dev/null || true

find_kscreen_output_id() {
    local output_file="$1"
    local pattern="$2"

    [ -n "${pattern}" ] || return 1

    awk -v pattern="${pattern}" '
        BEGIN {
            pattern = tolower(pattern)
        }
        /^Output: / {
            if (id != "" && found) {
                print id
                exit
            }
            id = $2
            found = (index(tolower($0), pattern) > 0)
            next
        }
        id != "" && index(tolower($0), pattern) > 0 {
            found = 1
        }
        END {
            if (id != "" && found) {
                print id
            }
        }
    ' "${output_file}" | head -n 1
}

find_largest_kscreen_output_id() {
    local output_file="$1"

    awk '
        /^Output: / {
            id = $2
            connected = 0
            next
        }
        id != "" && /^[[:space:]]*connected/ {
            connected = 1
            next
        }
        id != "" && /^[[:space:]]*(Modes:|Geometry:)/ {
            line = $0
            while (match(line, /[0-9]+x[0-9]+/)) {
                split(substr(line, RSTART, RLENGTH), dims, "x")
                area = dims[1] * dims[2]
                if (connected && area > best_area) {
                    best_area = area
                    best_id = id
                }
                line = substr(line, RSTART + RLENGTH)
            }
        }
        END {
            if (best_id != "") {
                print best_id
            }
        }
    ' "${output_file}" | head -n 1
}

apply_forced_output_layout() {
    local selector="${BATOCERA_ARCH_PLASMA_FORCE_OUTPUT:-}"
    local mode="${BATOCERA_ARCH_PLASMA_FORCE_OUTPUT_MODE:-}"
    local fallback_mode="${BATOCERA_ARCH_PLASMA_FORCE_OUTPUT_MODE_FALLBACK:-}"
    local disable_others="${BATOCERA_ARCH_PLASMA_DISABLE_OTHER_OUTPUTS:-0}"
    local output_file output_ids output_id target_id=""

    [ -n "${selector}${mode}${fallback_mode}" ] || return 0
    command -v kscreen-doctor >/dev/null 2>&1 || return 0

    output_file="/tmp/batocera-kscreen-layout-$$.out"
    for _ in $(seq 1 30); do
        if NO_COLOR=1 TERM=dumb kscreen-doctor -o 2>/dev/null | sed -E 's/\x1B\[[0-9;]*[[:alpha:]]//g' > "${output_file}"; then
            break
        fi
        sleep 0.1
    done

    if [ "${selector}" = "largest" ] || [ "${selector}" = "top" ]; then
        target_id="$(find_largest_kscreen_output_id "${output_file}" 2>/dev/null || true)"
    fi
    [ -n "${target_id}" ] || target_id="$(find_kscreen_output_id "${output_file}" "${mode}" 2>/dev/null || true)"
    [ -n "${target_id}" ] || target_id="$(find_kscreen_output_id "${output_file}" "${fallback_mode}" 2>/dev/null || true)"
    [ -n "${target_id}" ] || target_id="$(find_kscreen_output_id "${output_file}" "${selector}" 2>/dev/null || true)"
    output_ids="$(awk '/^Output: / { print $2 }' "${output_file}" 2>/dev/null || true)"
    rm -f "${output_file}" 2>/dev/null || true

    [ -n "${target_id}" ] || return 0

    kscreen-doctor "output.${target_id}.enable" >/dev/null 2>&1 || true
    if [ -n "${mode}" ]; then
        kscreen-doctor "output.${target_id}.mode.${mode}" >/dev/null 2>&1 || \
            { [ -n "${fallback_mode}" ] && kscreen-doctor "output.${target_id}.mode.${fallback_mode}" >/dev/null 2>&1; } || true
    elif [ -n "${fallback_mode}" ]; then
        kscreen-doctor "output.${target_id}.mode.${fallback_mode}" >/dev/null 2>&1 || true
    fi
    kscreen-doctor "output.${target_id}.position.0,0" >/dev/null 2>&1 || true
    kscreen-doctor "output.${target_id}.primary" >/dev/null 2>&1 || true

    if [ "${disable_others}" = "1" ]; then
        for output_id in ${output_ids}; do
            [ "${output_id}" != "${target_id}" ] || continue
            kscreen-doctor "output.${output_id}.disable" >/dev/null 2>&1 || true
        done
    fi
}

apply_runtime_output_scale() {
    local scale="${BATOCERA_ARCH_PLASMA_OUTPUT_SCALE:-}"
    local output_file output_ids output_id

    [ -n "${scale}" ] || return 0
    [[ "${scale}" =~ ^[0-9]+([.][0-9]+)?$ ]] || return 0
    command -v kscreen-doctor >/dev/null 2>&1 || return 0

    output_file="/tmp/batocera-kscreen-doctor-$$.out"
    for _ in $(seq 1 20); do
        if kscreen-doctor -o >"${output_file}" 2>/dev/null; then
            break
        fi
        sleep 0.1
    done

    output_ids="$(awk '/^Output: / { print $2 }' "${output_file}" 2>/dev/null || true)"
    rm -f "${output_file}" 2>/dev/null || true
    [ -n "${output_ids}" ] || output_ids="1 2 3 4"

    for output_id in ${output_ids}; do
        kscreen-doctor "output.${output_id}.scale.${scale}" >/dev/null 2>&1 || true
    done
}

find_qdbus_command() {
    local cmd

    for cmd in qdbus6 qdbus; do
        command -v "${cmd}" >/dev/null 2>&1 || continue
        printf '%s\n' "${cmd}"
        return 0
    done

    return 1
}

set_kwin_input_property() {
    local event="$1"
    local property="$2"
    local value="$3"
    local qdbus_cmd

    if command -v busctl >/dev/null 2>&1; then
        busctl --address="${DBUS_SESSION_BUS_ADDRESS}" set-property \
            org.kde.KWin "/org/kde/KWin/InputDevice/${event}" \
            org.kde.KWin.InputDevice "${property}" s "${value}" >/dev/null 2>&1 && return 0
    fi

    qdbus_cmd="$(find_qdbus_command 2>/dev/null || true)"
    [ -n "${qdbus_cmd}" ] || return 1
    "${qdbus_cmd}" org.kde.KWin "/org/kde/KWin/InputDevice/${event}" \
        org.freedesktop.DBus.Properties.Set org.kde.KWin.InputDevice "${property}" "${value}" >/dev/null 2>&1
}

apply_touchscreen_output_mapping() {
    local output_name="${BATOCERA_ARCH_PLASMA_TOUCH_OUTPUT_NAME:-}"
    local kwin_matrix="${BATOCERA_ARCH_PLASMA_TOUCH_KWIN_CALIBRATION_MATRIX:-}"
    local pattern="${BATOCERA_ARCH_PLASMA_TOUCH_KEEP_PATTERN:-}"
    local qdbus_cmd layout_log event ev props sysfs name matched mapped=0

    [ -n "${output_name}" ] || return 0
    [ -n "${pattern}" ] || return 0
    [ -n "${DBUS_SESSION_BUS_ADDRESS:-}" ] || return 0
    qdbus_cmd="$(find_qdbus_command 2>/dev/null || true)"
    [ -n "${qdbus_cmd}" ] || return 0

    layout_log="${BATOCERA_ARCH_PLASMA_LAYOUT_LOG:-/batocera-runtime/plasma-output-layout.log}"
    mkdir -p "$(dirname "${layout_log}")" 2>/dev/null || true

    for _ in $(seq 1 50); do
        "${qdbus_cmd}" org.kde.KWin >/dev/null 2>&1 && break
        sleep 0.1
    done
    if ! "${qdbus_cmd}" org.kde.KWin >/dev/null 2>&1; then
        printf 'KWin DBus service unavailable; touchscreen output mapping skipped\n' >> "${layout_log}" 2>/dev/null || true
        return 0
    fi

    for event in /dev/input/event*; do
        [ -e "${event}" ] || continue
        ev="${event##*/}"
        props="$(udevadm info -q property -n "${event}" 2>/dev/null || true)"
        printf '%s\n' "${props}" | grep -q '^ID_INPUT_TOUCHSCREEN=1' || continue
        sysfs="$(readlink -f "/sys/class/input/${ev}/device" 2>/dev/null || true)"
        name="$(cat "/sys/class/input/${ev}/device/name" 2>/dev/null || true)"

        matched=0
        if { printf '%s\n%s\n%s\n' "${props}" "${sysfs}" "${name}" | grep -Eiq -- "${pattern}"; } 2>/dev/null; then
            matched=1
        fi
        [ "${matched}" = "1" ] || continue

        if set_kwin_input_property "${ev}" outputName "${output_name}"; then
            printf 'mapped touchscreen %s (%s) to output %s\n' "${event}" "${name}" "${output_name}" >> "${layout_log}" 2>/dev/null || true
            mapped=1
        else
            printf 'warning: failed to map touchscreen %s (%s) to output %s\n' "${event}" "${name}" "${output_name}" >> "${layout_log}" 2>/dev/null || true
        fi
        if [ -n "${kwin_matrix}" ]; then
            if set_kwin_input_property "${ev}" calibrationMatrix "${kwin_matrix}"; then
                printf 'mapped touchscreen %s (%s) KWin calibration %s\n' "${event}" "${name}" "${kwin_matrix}" >> "${layout_log}" 2>/dev/null || true
            else
                printf 'warning: failed to set touchscreen %s (%s) KWin calibration %s\n' "${event}" "${name}" "${kwin_matrix}" >> "${layout_log}" 2>/dev/null || true
            fi
        fi
    done

    [ "${mapped}" = "1" ] || printf 'no touchscreen matched output mapping pattern %s\n' "${pattern}" >> "${layout_log}" 2>/dev/null || true
}

apply_forced_output_layout
apply_touchscreen_output_mapping
apply_runtime_output_scale

if [ -n "${XAUTHORITY:-}" ] && [ -e "${XAUTHORITY}" ]; then
